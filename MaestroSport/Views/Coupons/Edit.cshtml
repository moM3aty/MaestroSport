@model MaestroSport.Models.Coupon
@{
    ViewData["Title"] = "تعديل كود خصم";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 900px; margin: 0 auto;">
    <div class="card-premium">
        <h3 style="color: var(--gold); margin-bottom: 25px;"><i class="fas fa-edit"></i> تعديل شروط الكود</h3>

        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="form-group">
                    <label asp-for="Code" class="form-label">رمز الكود</label>
                    <input asp-for="Code" class="form-control" style="text-transform: uppercase; font-family: monospace; font-weight: bold; color: var(--gold);" required />
                </div>
                <div class="form-group">
                    <label asp-for="DiscountPercentage" class="form-label">نسبة الخصم (%)</label>
                    <input asp-for="DiscountPercentage" type="number" step="0.1" class="form-control" />
                </div>
            </div>

            <div class="form-group" style="background: rgba(212, 175, 55, 0.05); padding: 15px; border-radius: 10px; border: 1px dashed var(--gold); margin-bottom: 25px;">
                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer; margin: 0;">
                    <input asp-for="IsFreePiece" type="checkbox" style="width: 20px; height: 20px; accent-color: var(--gold);" />
                    <span style="font-weight: bold; color: var(--gold);">كود يعطي "قطعة مجانية"</span>
                </label>
            </div>

            <h5 style="color: var(--text-dim); border-bottom: 1px solid var(--accent); padding-bottom: 10px; margin-bottom: 20px;">شروط الاستخدام والصلاحية</h5>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                <div class="form-group">
                    <label asp-for="TargetCategoryId" class="form-label">القسم</label>
                    <select asp-for="TargetCategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- جميع الأقسام --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="TargetFabricName" class="form-label">القماش</label>
                    <select asp-for="TargetFabricName" class="form-control" asp-items="ViewBag.Fabrics">
                        <option value="">-- جميع الأقمشة --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="MinQuantity" class="form-label">الحد الأدنى للقطع</label>
                    <input asp-for="MinQuantity" type="number" class="form-control" />
                </div>
            </div>

            <!-- تمت إضافة تاريخ الانتهاء وحالة التفعيل هنا -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                <div class="form-group">
                    <label asp-for="ExpiryDate" class="form-label">تاريخ الانتهاء</label>
                    <input asp-for="ExpiryDate" type="date" class="form-control" />
                    <small style="color: var(--text-dim); display: block; margin-top: 5px;">اتركه فارغاً ليعمل الكوبون بصلاحية مفتوحة.</small>
                </div>

                <div class="form-group" style="display: flex; align-items: center; background: rgba(46, 204, 113, 0.05); padding: 15px; border-radius: 10px; border: 1px dashed #2ecc71;">
                    <label style="display: flex; align-items: center; gap: 15px; cursor: pointer; margin: 0;">
                        <input asp-for="IsActive" type="checkbox" style="width: 20px; height: 20px; accent-color: #2ecc71;" />
                        <span style="font-weight: bold; color: #2ecc71;">تفعيل الكوبون (نشط)</span>
                    </label>
                </div>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--accent);">
                <button type="submit" class="btn-premium btn-gold" style="flex: 1;"><i class="fas fa-save"></i> حفظ التعديلات</button>
                <a asp-action="Index" class="btn-premium btn-outline">إلغاء</a>
            </div>
        </form>
    </div>
</div>