@model MaestroSport.Models.Coupon

@{
    ViewData["Title"] = "إنشاء كود خصم جديد";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 800px; margin: 0 auto;">
    <!-- الرأس -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h2 style="font-weight: 900; color: var(--gold); letter-spacing: -1px;">إضافة عرض جديد</h2>
            <p style="color: #ffffff; opacity: 0.8;">قم بإنشاء كود خصم لجذب المزيد من الزبائن</p>
        </div>
        <a asp-action="Index" class="btn-premium btn-outline">
            <i class="fas fa-arrow-right" style="margin-left: 8px;"></i> العودة للقائمة
        </a>
    </div>

    <div class="card-premium">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4" style="font-weight: bold;"></div>

            <!-- حقل الكود بتصميم مميز -->
            <div class="form-group">
                <label asp-for="Code" class="form-label">رمز الكوبون (يُفضل أحرف كبيرة)</label>
                <div style="position: relative;">
                    <input asp-for="Code" class="form-control"
                           style="text-transform: uppercase; letter-spacing: 3px; font-weight: 900; font-size: 1.4rem; padding-right: 50px; border-style: dashed; border-width: 2px;"
                           placeholder="مثال: GOLDEN20" />
                    <i class="fas fa-ticket-alt" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: var(--gold); font-size: 1.2rem;"></i>
                </div>
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; margin-top: 20px;">
                <!-- قيمة الخصم -->
                <div class="form-group">
                    <label asp-for="DiscountAmount" class="form-label">قيمة الخصم</label>
                    <div style="position: relative;">
                        <input asp-for="DiscountAmount" type="number" step="0.5" class="form-control" style="padding-left: 45px; font-weight: bold;" />
                        <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--gold); font-weight: bold;">ر.ع</span>
                    </div>
                    <span asp-validation-for="DiscountAmount" class="text-danger"></span>
                </div>

                <!-- تاريخ الانتهاء -->
                <div class="form-group">
                    <label asp-for="ExpiryDate" class="form-label">تاريخ انتهاء الصلاحية</label>
                    <input asp-for="ExpiryDate" type="date" class="form-control" />
                    <small style="color: var(--text-dim);">اتركه فارغاً إذا كان الخصم دائماً.</small>
                </div>
            </div>

            <!-- حالة التفعيل -->
            <div class="form-group" style="background: rgba(46, 204, 113, 0.05); padding: 20px; border-radius: 15px; border: 1px dashed #2ecc71; margin-top: 30px;">
                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer;">
                    <input asp-for="IsActive" type="checkbox" checked style="width: 22px; height: 22px; accent-color: #2ecc71; cursor: pointer;" />
                    <div>
                        <span style="font-weight: 900; color: #2ecc71; font-size: 1.1rem;">تفعيل الكود فوراً</span>
                        <p style="font-size: 0.85rem; margin: 0; color: #ffffff;">سيتمكن الزبائن من استخدام هذا الكود بمجرد الحفظ.</p>
                    </div>
                </label>
            </div>

            <!-- أزرار التحكم -->
            <div style="display: flex; gap: 15px; margin-top: 40px; padding-top: 25px; border-top: 1px solid var(--accent);">
                <button type="submit" class="btn-premium btn-gold" style="padding: 15px 50px; font-size: 1.1rem; flex: 1; justify-content: center;">
                    <i class="fas fa-plus-circle" style="margin-left: 10px;"></i> إنشاء الكود الآن
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}