@model IEnumerable<MaestroSport.Models.Coupon>
@{
    ViewData["Title"] = "أكواد الخصم";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card-premium">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 15px;">
        <div>
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-ticket-alt" style="margin-left: 10px;"></i> حملات الخصم الملكية</h3>
            <p style="color: var(--text-dim); font-size: 0.9rem;">أدر كوبونات التخفيض الفعالة لعملائك لتعزيز المبيعات</p>
        </div>
        <a href="/Coupons/Create" class="btn-premium btn-gold">
            <i class="fas fa-plus-circle"></i> إنشاء كود خصم جديد
        </a>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th style="width: 200px;">رمز الكود</th>
                    <th>نسبة الخصم / نوع الهدية</th>
                    <th>تاريخ الانتهاء</th>
                    <th>حالة الكوبون</th>
                    <th style="text-align: left;">خيارات التحكم</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div style="background: rgba(212, 175, 55, 0.05); border: 1px dashed var(--gold); padding: 8px 15px; border-radius: 10px; width: fit-content;">
                                <span style="font-family: 'Courier New', Courier, monospace; font-size: 1.2rem; font-weight: 900; letter-spacing: 2px; color: var(--gold);">@item.Code</span>
                            </div>
                        </td>
                        <td>
                            @if (item.IsFreePiece)
                            {
                                <span style="font-weight: 900; font-size: 1.05rem; color: #f1c40f; background: rgba(241, 196, 15, 0.1); padding: 5px 10px; border-radius: 8px; border: 1px dashed #f1c40f;">
                                    <i class="fas fa-gift"></i> قطعة مجانية
                                </span>
                            }
                            else
                            {
                                <span style="font-weight: 800; font-size: 1.1rem; color: #2ecc71;">@item.DiscountPercentage %</span>
                            }
                        </td>
                        <td>
                            <span style="color: var(--text-dim);">
                                <i class="far fa-calendar-alt" style="margin-left: 5px;"></i>
                                @(item.ExpiryDate?.ToString("yyyy/MM/dd") ?? "صلاحية مفتوحة")
                            </span>
                        </td>
                        <td>
                            @if (item.IsActive && (!item.ExpiryDate.HasValue || item.ExpiryDate >= DateTime.Now))
                            {
                                <span class="badge badge-success">
                                    <i class="fas fa-check-circle" style="margin-left: 5px;"></i> نشط حالياً
                                </span>
                            }
                            else
                            {
                                <span class="badge" style="border: 1px solid #ff4757; color: #ff4757; background: rgba(255, 71, 87, 0.05);">
                                    <i class="fas fa-times-circle" style="margin-left: 5px;"></i> منتهي / معطل
                                </span>
                            }
                        </td>
                        <td style="text-align: left;">
                            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                <a href="/Coupons/Edit/@item.Id" class="btn-premium btn-outline" style="padding: 10px 15px;" title="تعديل">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/Coupons/Delete/@item.Id" class="btn-premium btn-outline"
                                   style="padding: 10px 15px; border-color: #ff4757; color: #ff4757;"
                                   onclick="return confirm('هل تريد حذف هذا الكوبون نهائياً؟')" title="حذف">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 80px; color: var(--text-dim);">
                            <i class="fas fa-tags fa-4x" style="display: block; margin-bottom: 20px; opacity: 0.1;"></i>
                            لا توجد أكواد خصم نشطة حالياً.. ابدأ بإضافة الكود الأول
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>