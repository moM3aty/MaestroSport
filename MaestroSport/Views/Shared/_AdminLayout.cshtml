<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | المايسترو - إدارة</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <link href="~/images/logo.png" rel="icon" type="image/x-icon" />

    <style>
        :root {
            --gold: #D4AF37;
            --gold-gradient: linear-gradient(135deg, #D4AF37 0%, #f3d56a 100%);
            --black: #0a0a0a;
            --dark-card: #151515;
            --accent: #1e1e1e;
            --text-main: #ffffff;
            --text-dim: #b0b0b0;
            --sidebar-width: 260px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; }
        body { font-family: 'Cairo', sans-serif; background-color: var(--black); color: var(--text-main); line-height: 1.6; overflow-x: hidden; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--black); }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 10px; }

        .admin-wrapper { display: flex; min-height: 100vh; }

        .sidebar {
            width: var(--sidebar-width);
            background: var(--dark-card);
            border-left: 1px solid var(--accent);
            position: fixed;
            height: 100vh;
            right: 0;
            top: 0;
            z-index: 1000;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
        }

        .sidebar-brand {
            padding: 30px 20px;
            text-align: center;
            border-bottom: 1px solid var(--accent);
        }

        .sidebar-brand i { font-size: 2.5rem; color: var(--gold); filter: drop-shadow(0 0 10px rgba(212, 175, 55, 0.3)); }
        .sidebar-brand h3 { margin-top: 10px; font-weight: 900; letter-spacing: 1px; color: var(--gold); }

        .nav-menu { list-style: none; padding: 20px 0; flex-grow: 1; overflow-y: auto; }
        .nav-item { padding: 5px 15px; }
        .nav-link {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: var(--text-dim);
            text-decoration: none;
            border-radius: 12px;
            transition: var(--transition);
            font-weight: 600;
        }

        .nav-link i { width: 30px; font-size: 1.2rem; margin-left: 10px; }
        .nav-link:hover { background: var(--accent); color: var(--gold); transform: translateX(-5px); }
        .nav-link.active { background: var(--gold-gradient); color: #000; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3); }

        .main-content {
            margin-right: var(--sidebar-width);
            flex-grow: 1;
            padding: 40px;
            transition: var(--transition);
            width: calc(100% - var(--sidebar-width));
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            background: rgba(21, 21, 21, 0.8);
            backdrop-filter: blur(10px);
            padding: 15px 30px;
            border-radius: 20px;
            border: 1px solid var(--accent);
        }

        .user-info { display: flex; align-items: center; gap: 15px; }
        .user-avatar { width: 45px; height: 45px; border-radius: 50%; border: 2px solid var(--gold); }

        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card {
            background: var(--dark-card);
            padding: 25px;
            border-radius: 20px;
            border-right: 5px solid var(--gold);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition);
        }
        .stat-card:hover { transform: translateY(-5px); border-color: #fff; }
        .stat-val { font-size: 1.8rem; font-weight: 900; color: #fff; }
        .stat-label { color: var(--gold); font-size: 0.8rem; font-weight: bold; text-transform: uppercase; }

        .card-premium {
            background: var(--dark-card);
            border-radius: 25px;
            border: 1px solid var(--accent);
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .table-responsive { overflow-x: auto; width: 100%; }
        table { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        th { text-align: right; padding: 15px; color: var(--gold); font-weight: 800; border-bottom: 2px solid var(--accent); }
        td { padding: 15px; background: rgba(255,255,255,0.02); vertical-align: middle; color: #fff; }
        tr td:first-child { border-radius: 0 15px 15px 0; }
        tr td:last-child { border-radius: 15px 0 0 15px; }

        .btn-premium { padding: 12px 25px; border-radius: 12px; border: none; cursor: pointer; font-weight: bold; transition: var(--transition); display: inline-flex; align-items: center; gap: 10px; text-decoration: none; font-size: 0.9rem; }
        .btn-gold { background: var(--gold-gradient); color: #000; }
        .btn-outline { background: transparent; border: 1px solid var(--gold); color: var(--gold); }

        .form-control { width: 100%; background: var(--accent); border: 1px solid #333; padding: 15px; border-radius: 12px; color: #fff; font-family: inherit; }

        .badge { padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: bold; display: inline-block; }
        .badge-pending { background: rgba(243, 156, 18, 0.1); color: #f39c12; border: 1px solid #f39c12; }
        .badge-success { background: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid #2ecc71; }

        @@media (max-width: 992px) {
            .sidebar { transform: translateX(100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-right: 0; width: 100%; padding: 20px; }
            .menu-toggle { display: block !important; }
        }

        .menu-toggle { display: none; background: none; border: none; color: var(--gold); font-size: 1.5rem; cursor: pointer; }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <aside class="sidebar" id="adminSidebar">
            <div class="sidebar-brand">
                <i class="fas fa-crown"></i>
                <h3>المايسترو</h3>
            </div>
            <ul class="nav-menu">
                <!-- الأدمن يرى كل شيء -->
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a href="/Admin" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                            <i class="fas fa-chart-pie"></i> الإحصائيات
                        </a>
                    </li>
                }

                <!-- العمال والأدمن يرون الطلبات -->
                <li class="nav-item">
                    <a href="/Orders" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")">
                        <i class="fas fa-shopping-bag"></i> الطلبات
                    </a>
                </li>

                <!-- باقي القوائم للأدمن فقط -->
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a href="/Products" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")">
                            <i class="fas fa-tshirt"></i> الموديلات
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Categories" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")">
                            <i class="fas fa-layer-group"></i> الأقسام
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Sizes" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Sizes" ? "active" : "")">
                            <i class="fas fa-ruler-combined"></i> المقاسات
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Coupons" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Coupons" ? "active" : "")">
                            <i class="fas fa-ticket-alt"></i> الكوبونات
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Fabrics" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Fabrics" ? "active" : "")">
                            <i class="fas fa-shirt"></i> القماش
                        </a>
                    </li>
                    <li class="nav-item border-top mt-3 pt-3">
                        <a href="/Settings" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")">
                            <i class="fas fa-cogs"></i> الإعدادات
                        </a>
                    </li>
                }
            </ul>
            <div class="p-4">
                <a href="/Account/Logout" class="nav-link text-danger" style="color: #ff4757;">
                    <i class="fas fa-sign-out-alt"></i> خروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-bar no-print">
                <div style="display: flex; align-items: center; gap: 20px;">
                    <button class="menu-toggle" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
                    <h2 style="font-weight: 900;">@ViewData["Title"]</h2>
                </div>
                <div class="user-info">
                    <div style="text-align: left;" class="no-print">
                        <!-- تظهر الصلاحية واسم المستخدم الحالي -->
                        <p style="font-size: 0.8rem; color: var(--gold); font-weight: bold;">
                            @(User.IsInRole("Admin") ? "مسؤول النظام" : "فريق العمل")
                        </p>
                        <p style="font-weight: bold; text-transform: capitalize;">@User.Identity.Name</p>
                    </div>
                    <img src="~/images/logo.png" onerror="this.src='https://ui-avatars.com/api/?name=@User.Identity.Name&background=D4AF37&color=000'" class="user-avatar" />
                </div>
            </div>

            @RenderBody()
        </main>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById('adminSidebar').classList.toggle('active');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>