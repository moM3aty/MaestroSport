@model MaestroSport.Models.Fabric
@{
    ViewData["Title"] = "إضافة قماش";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 600px; margin: 0 auto;" class="card-premium">
    <h3 style="color: var(--gold); margin-bottom: 20px;">إضافة قماش جديد</h3>
    <form asp-action="Create">
        <div class="form-group mb-3">
            <label class="form-label">اسم القماش</label>
            <input asp-for="Name" class="form-control" placeholder="مثال: ديواني ملكي" required />
        </div>
        <div class="form-group mb-4">
            <label class="form-label">السعر الإضافي (ضع 0 إذا كان مجانياً)</label>
            <input asp-for="AdditionalPrice" type="number" step="0.5" class="form-control" value="0" />
        </div>
        <button type="submit" class="btn-premium btn-gold w-100 justify-content-center">حفظ</button>
    </form>
</div>