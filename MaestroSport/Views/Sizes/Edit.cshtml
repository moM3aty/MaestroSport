@model MaestroSport.Models.Size

@{
    ViewData["Title"] = "تعديل المقاس";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 800px; margin: 0 auto;">
    <!-- الرأس -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h2 style="font-weight: 900; color: var(--gold); letter-spacing: -1px;">تعديل بيانات المقاس</h2>
            <p style="color: #ffffff; opacity: 0.8;">تحديث معلومات المقاس: <span style="color: var(--gold); font-weight: bold;">@Model.Name</span></p>
        </div>
        <a asp-action="Index" class="btn-premium btn-outline">
            <i class="fas fa-arrow-right" style="margin-left: 8px;"></i> العودة للقائمة
        </a>
    </div>

    <div class="card-premium">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4" style="font-weight: bold;"></div>
            <input type="hidden" asp-for="Id" />

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px;">
                <!-- رمز المقاس -->
                <div class="form-group">
                    <label asp-for="Name" class="form-label">رمز المقاس</label>
                    <input asp-for="Name" class="form-control" placeholder="S, M, L..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- اسم المجموعة -->
                <div class="form-group">
                    <label asp-for="GroupName" class="form-label">اسم المجموعة</label>
                    <input asp-for="GroupName" class="form-control" />
                    <span asp-validation-for="GroupName" class="text-danger"></span>
                </div>
            </div>

            <!-- السعر الإضافي -->
            <div class="form-group" style="margin-top: 20px;">
                <label asp-for="AdditionalPrice" class="form-label">السعر الإضافي (ريال عماني)</label>
                <div style="position: relative;">
                    <input asp-for="AdditionalPrice" type="number" step="0.1" class="form-control" style="padding-left: 50px; font-weight: 900; font-size: 1.2rem; color: var(--gold) !important;" />
                    <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--gold); font-weight: bold;">ر.ع</span>
                </div>
                <span asp-validation-for="AdditionalPrice" class="text-danger"></span>
            </div>

            <!-- أزرار التحكم -->
            <div style="display: flex; gap: 15px; margin-top: 40px; padding-top: 25px; border-top: 1px solid var(--accent);">
                <button type="submit" class="btn-premium btn-gold" style="padding: 15px 50px; font-size: 1.1rem; flex: 1; justify-content: center;">
                    <i class="fas fa-check-double" style="margin-left: 10px;"></i> تحديث البيانات الملكية
                </button>
                <a asp-action="Index" class="btn-premium btn-outline" style="padding: 15px 30px;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}