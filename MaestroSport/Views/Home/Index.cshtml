@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>المايسترو للرياضة | الفخامة في التفصيل</title>
    <!-- الأيقونات والخطوط -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* ==========================================================================
                   ULTRA PREMIUM DESIGN SYSTEM (V2.0 - PROFESSIONAL)
                   ========================================================================== */
        :root {
            --gold: #D4AF37;
            --gold-light: #F3E5AB;
            --gold-dark: #aa8c2c;
            --gold-gradient: linear-gradient(135deg, #D4AF37 0%, #aa8c2c 100%);
            --gold-glow: 0 4px 15px rgba(212, 175, 55, 0.25);
            --bg-base: #030303;
            --bg-surface: #0a0a0a;
            --bg-surface-elevated: #141414;
            --border-subtle: rgba(212, 175, 55, 0.1);
            --border-active: rgba(212, 175, 55, 0.4);
            --text-primary: #ffffff;
            --text-secondary: #9e9e9e;
            --text-tertiary: #666666;
            --insta-grad: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --border-radius-lg: 20px;
            --border-radius-md: 12px;
            --border-radius-sm: 8px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-base);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
            background-image: radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
        }

        .text-gold {
            color: var(--gold) !important;
        }

        .hidden {
            display: none !important;
        }

        /* --- Modern Header --- */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(3, 3, 3, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-subtle);
            z-index: 1000;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 75px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.5);
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            transition: var(--transition-smooth);
        }

            .header-brand:hover {
                transform: scale(1.02);
            }

        .header-logo {
            width: 45px;
            height: 45px;
            object-fit: contain;
            filter: drop-shadow(0 0 5px rgba(212,175,55,0.4));
        }

        .header-title-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .header-title {
            font-weight: 900;
            font-size: 1.25rem;
            color: var(--text-primary);
            margin: 0;
            line-height: 1.1;
            letter-spacing: -0.5px;
        }

        .header-subtitle {
            font-size: 0.75rem;
            color: var(--gold);
            letter-spacing: 1px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .header-actions {
            display: flex;
            gap: 15px;
        }

        /* --- Main Layout --- */
        main {
            padding-top: 75px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .container {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* --- Announcement Bar --- */
        .announcement-wrapper {
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-subtle);
            padding: 8px 0;
            display: flex;
            align-items: center;
        }

        .announcement-bar {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .announcement-icon {
            color: var(--gold);
            font-size: 1.1rem;
            animation: pulse 2s infinite;
        }

        .announcement-bar marquee {
            flex-grow: 1;
            color: var(--gold-light);
            font-weight: 600;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
        }
        @@keyframes pulse {
            0%

        {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.7;
            transform: scale(1.1);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }

        }

        /* --- Hero Promo Banner --- */
        .hero-banner-container {
            margin: 25px auto 40px auto;
            border-radius: var(--border-radius-lg);
            overflow: hidden;
            position: relative;
            border: 1px solid var(--border-active);
            box-shadow: var(--gold-glow);
            background-color: var(--bg-surface-elevated);
        }
        @@media (max-width: 768px) {
            .hero-banner-container

        {
            aspect-ratio: 16/9;
            margin-top: 15px;
            margin-bottom: 30px;
        }

        }

        .hero-banner-img {
            width: 100%;
            display: block;
            transition: transform 0.5s;
        }

        .hero-banner-container:hover .hero-banner-img {
            transform: scale(1.02);
        }

        /* --- Section Titles --- */
        .section-header {
            margin-bottom: 25px;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--text-primary);
            position: relative;
            padding-right: 15px;
            line-height: 1.2;
        }

            .section-title::before {
                content: '';
                position: absolute;
                right: 0;
                top: 10%;
                bottom: 10%;
                width: 4px;
                background: var(--gold-gradient);
                border-radius: 4px;
            }

        .section-subtitle {
            font-size: 0.9rem;
            color: var(--text-secondary);
            font-weight: 400;
            padding-right: 15px;
        }

        /* --- Horizontal Categories --- */
        .categories-scroll-wrapper {
            display: flex;
            overflow-x: auto;
            gap: 15px;
            padding-bottom: 15px;
            margin-bottom: 40px;
            scrollbar-width: none;
            -ms-overflow-style: none;
            scroll-behavior: smooth;
        }

            .categories-scroll-wrapper::-webkit-scrollbar {
                display: none;
            }

        .category-pill {
            flex: 0 0 auto;
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            padding: 12px 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: var(--transition-smooth);
        }

            .category-pill:hover, .category-pill.active {
                background: var(--gold-gradient);
                color: var(--bg-base);
                border-color: transparent;
                box-shadow: var(--gold-glow);
                transform: translateY(-3px);
            }

            .category-pill i {
                font-size: 1.3rem;
                color: var(--gold);
                transition: var(--transition-smooth);
            }

            .category-pill:hover i, .category-pill.active i {
                color: var(--bg-base);
            }

            .category-pill span {
                font-weight: 800;
                font-size: 1rem;
                white-space: nowrap;
            }

        /* --- Products Grid --- */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 50px;
        }
        @@media (min-width: 768px) {
            .products-grid

        {
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
        }

        }
        @@media (min-width: 1024px) {
            .products-grid

        {
            grid-template-columns: repeat(4, 1fr);
        }

        }

        .product-card {
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: var(--transition-smooth);
            position: relative;
            cursor: pointer;
        }

            .product-card:hover {
                border-color: var(--border-active);
                transform: translateY(-8px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.6), 0 0 20px rgba(212,175,55,0.05);
            }

        .product-img-container {
            position: relative;
            width: 100%;
            padding-top: 130%;
            background: var(--bg-surface-elevated);
            overflow: hidden;
        }

            .product-img-container img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            }

        .product-card:hover .product-img-container img {
            transform: scale(1.1);
        }

        .badge-custom {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 4px 10px;
            border-radius: var(--border-radius-md);
            font-size: 0.75rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 5px;
            z-index: 2;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        .product-info {
            padding: 15px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            background: linear-gradient(to top, var(--bg-surface) 80%, transparent);
            position: relative;
            z-index: 2;
        }

        .product-title {
            font-size: 1.05rem;
            font-weight: 800;
            margin-bottom: 8px;
            line-height: 1.4;
            color: var(--text-primary);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
            padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .price-container {
            display: flex;
            flex-direction: column;
        }

        .product-price {
            font-size: 1.3rem;
            font-weight: 900;
            color: var(--gold);
            line-height: 1;
            display: flex;
            align-items: baseline;
            gap: 3px;
        }

            .product-price small {
                font-size: 0.7rem;
                color: var(--text-secondary);
                font-weight: 600;
            }

        .btn-order-action {
            background: var(--bg-surface-elevated);
            color: var(--gold);
            border: 1px solid var(--gold);
            width: 42px;
            height: 42px;
            border-radius: var(--border-radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            transition: var(--transition-smooth);
        }

            .product-card:hover .btn-order-action, .btn-order-action:active {
                background: var(--gold-gradient);
                color: var(--bg-base);
                box-shadow: var(--gold-glow);
            }

        /* --- Instagram Banner --- */
        .insta-banner-card {
            background: var(--bg-surface);
            border-radius: var(--border-radius-lg);
            padding: 2px;
            position: relative;
            overflow: hidden;
            margin-bottom: 60px;
        }

            .insta-banner-card::before {
                content: '';
                position: absolute;
                inset: 0;
                background: var(--insta-grad);
                opacity: 0.6;
                filter: blur(25px);
                z-index: 0;
            }

        .insta-banner-inner {
            position: relative;
            background: var(--bg-surface);
            border-radius: 18px;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            z-index: 1;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .insta-icon-large {
            font-size: 4rem;
            background: var(--insta-grad);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
        }

        .insta-btn {
            margin-top: 20px;
            background: var(--insta-grad);
            color: #fff !important;
            text-decoration: none;
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 8px 25px rgba(220, 39, 67, 0.4);
            transition: transform 0.3s;
        }

            .insta-btn:hover {
                transform: scale(1.05);
            }

        /* --- Professional Footer --- */
        .premium-footer {
            background: #050505;
            border-top: 1px solid var(--border-subtle);
            padding: 60px 0 20px 0;
            margin-top: auto;
            position: relative;
            overflow: hidden;
        }

            .premium-footer::before {
                content: '';
                position: absolute;
                top: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 50%;
                height: 1px;
                background: var(--gold-gradient);
                opacity: 0.5;
            }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }
        @@media (min-width: 768px) {
            .footer-grid

        {
            grid-template-columns: 2fr 1fr 1fr;
            gap: 30px;
        }

        }

        .footer-col-brand .footer-logo {
            width: 80px;
            margin-bottom: 20px;
            filter: drop-shadow(0 0 10px rgba(212,175,55,0.3));
        }

        .footer-col-brand p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.8;
            max-width: 400px;
        }

        .footer-title {
            color: var(--text-primary);
            font-size: 1.2rem;
            font-weight: 800;
            margin-bottom: 20px;
            position: relative;
            padding-right: 15px;
        }

            .footer-title::before {
                content: '';
                position: absolute;
                right: 0;
                top: 5px;
                bottom: 5px;
                width: 3px;
                background: var(--gold);
                border-radius: 3px;
            }

        .footer-links {
            list-style: none;
        }

            .footer-links li {
                margin-bottom: 12px;
            }

            .footer-links a {
                color: var(--text-secondary);
                text-decoration: none;
                transition: var(--transition-smooth);
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .footer-links a:hover {
                    color: var(--gold);
                    transform: translateX(-5px);
                }

            .footer-links i {
                font-size: 0.8rem;
                color: var(--gold);
            }

        .footer-contact p {
            color: var(--text-secondary);
            margin-bottom: 15px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.95rem;
        }

        .footer-contact i {
            color: var(--gold);
            font-size: 1.2rem;
            margin-top: 3px;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 25px;
            border-top: 1px solid rgba(255,255,255,0.05);
            color: var(--text-tertiary);
            font-size: 0.9rem;
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-items: center;
        }

            .footer-bottom span {
                font-weight: bold;
                color: var(--text-secondary);
            }

        /* --- Advanced Bottom Sheet Modal (Unchanged Layout, Refined UI) --- */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

            .modal-overlay.show {
                opacity: 1;
                pointer-events: auto;
            }

        .modal-content {
            background: var(--bg-surface);
            width: 100%;
            max-width: 600px;
            max-height: 92vh;
            overflow-y: auto;
            border-radius: 30px 30px 0 0;
            padding: 0 25px 30px 25px;
            border-top: 1px solid var(--border-active);
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
            display: flex;
            flex-direction: column;
            box-shadow: 0 -10px 40px rgba(0,0,0,0.8);
        }
        @@media (min-width: 768px) {
            .modal-overlay

        {
            align-items: center;
        }

        .modal-content {
            border-radius: 24px;
            border: 1px solid var(--border-active);
            max-height: 85vh;
        }

        }

        .modal-overlay.show .modal-content {
            transform: translateY(0);
        }

        .modal-header-sticky {
            position: sticky;
            top: 0;
            background: var(--bg-surface);
            padding: 20px 0 15px 0;
            z-index: 10;
            border-bottom: 1px solid var(--border-subtle);
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .modal-drag-handle {
            width: 50px;
            height: 5px;
            background: var(--bg-surface-elevated);
            border-radius: 5px;
            margin-bottom: 15px;
        }

        .modal-header-content {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 1.25rem;
            font-weight: 900;
            color: var(--gold);
            margin: 0;
        }

        .close-btn {
            background: var(--bg-surface-elevated);
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            color: var(--text-primary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: 0.3s;
        }

            .close-btn:hover {
                background: #ff4757;
                color: #fff;
            }

        .form-section {
            margin-bottom: 25px;
        }

        .section-label {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
            color: var(--text-primary);
            font-weight: 800;
            font-size: 1rem;
        }

            .section-label i {
                color: var(--gold);
            }

        .input-modern {
            width: 100%;
            padding: 15px;
            background: var(--bg-base);
            border: 1px solid var(--border-subtle);
            color: #fff;
            border-radius: var(--border-radius-md);
            font-family: inherit;
            font-size: 1rem;
            transition: var(--transition-smooth);
        }

            .input-modern:focus {
                border-color: var(--gold);
                box-shadow: var(--gold-glow);
                outline: none;
            }

        .size-selector-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
            gap: 10px;
        }

        .size-btn-modern {
            background: var(--bg-base);
            border: 1px solid var(--border-subtle);
            color: var(--text-primary);
            padding: 12px 5px;
            border-radius: var(--border-radius-md);
            cursor: pointer;
            text-align: center;
            font-weight: 800;
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .size-btn-modern.active {
                background: var(--gold-gradient);
                color: var(--bg-base);
                border-color: transparent;
                box-shadow: var(--gold-glow);
            }

        .size-extra-price {
            font-size: 0.7rem;
            opacity: 0.8;
            margin-top: 4px;
        }

        .size-btn-modern.active .size-extra-price {
            color: rgba(0,0,0,0.7);
            font-weight: 900;
        }

        .add-action-row {
            display: flex;
            gap: 15px;
            margin-top: 15px;
            align-items: stretch;
        }

        .qty-control-modern {
            display: flex;
            align-items: center;
            background: var(--bg-base);
            border-radius: var(--border-radius-md);
            border: 1px solid var(--border-subtle);
            padding: 5px;
        }

        .qty-btn-modern {
            background: transparent;
            border: none;
            color: var(--gold);
            width: 40px;
            height: 40px;
            font-size: 1.2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .qty-input-modern {
            width: 40px;
            background: transparent;
            border: none;
            color: #fff;
            text-align: center;
            font-weight: 900;
            font-size: 1.2rem;
            pointer-events: none;
        }

        .btn-add-cart {
            flex-grow: 1;
            background: var(--bg-surface-elevated);
            border: 1px solid var(--gold);
            color: var(--gold);
            border-radius: var(--border-radius-md);
            font-weight: 900;
            font-size: 1.1rem;
            cursor: pointer;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-add-cart:active {
                background: var(--gold-gradient);
                color: var(--bg-base);
            }

        .cart-container {
            background: var(--bg-base);
            border-radius: var(--border-radius-md);
            padding: 15px;
            margin-top: 15px;
            border: 1px dashed var(--border-active);
        }

        .cart-item-modern {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

            .cart-item-modern:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

        .cart-item-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .cart-item-size {
            background: var(--bg-surface-elevated);
            padding: 5px 12px;
            border-radius: 8px;
            color: var(--gold);
            font-weight: 900;
        }

        .cart-item-qty {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        .btn-del-cart {
            background: rgba(255,71,87,0.1);
            color: #ff4757;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .file-upload-wrapper {
            position: relative;
        }

        .file-upload-input {
            width: 100%;
            padding: 15px;
            background: var(--bg-base);
            border: 1px dashed var(--gold);
            border-radius: var(--border-radius-md);
            color: var(--text-primary);
            cursor: pointer;
        }

            .file-upload-input::file-selector-button {
                background: var(--bg-surface-elevated);
                color: var(--gold);
                border: 1px solid var(--gold);
                padding: 8px 16px;
                border-radius: 8px;
                font-weight: bold;
                margin-left: 15px;
                cursor: pointer;
                transition: 0.3s;
            }

        .modal-footer-sticky {
            position: sticky;
            bottom: 0;
            background: var(--bg-surface);
            padding: 20px 0 0 0;
            margin-top: auto;
            border-top: 1px solid var(--border-subtle);
        }

        .price-summary {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .price-summary-label {
            color: var(--text-primary);
            font-weight: 800;
            font-size: 1.1rem;
        }

        .price-summary-value {
            font-size: 2rem;
            font-weight: 900;
            color: var(--gold);
            line-height: 1;
        }

        .price-summary-currency {
            font-size: 1rem;
            font-weight: 700;
            color: var(--gold);
            margin-right: 5px;
        }

        .btn-checkout {
            width: 100%;
            background: var(--gold-gradient);
            color: var(--bg-base);
            border: none;
            padding: 18px;
            border-radius: var(--border-radius-md);
            font-size: 1.25rem;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: var(--gold-glow);
            transition: var(--transition-smooth);
        }

            .btn-checkout:active {
                transform: scale(0.98);
            }

        /* Custom SweetAlert */
        .swal2-popup-custom {
            background: var(--bg-surface-elevated) !important;
            border: 1px solid var(--border-active) !important;
            border-radius: var(--border-radius-lg) !important;
            color: #fff !important;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="#" class="header-brand" onclick="toggleView('categories')">
            <img src="~/images/logo.png" alt="المايسترو" class="header-logo" onerror="this.src='https://placehold.co/100/111/D4AF37?text=M'">
            <div class="header-title-container">
                <h1 class="header-title">المايسترو</h1>
                <span class="header-subtitle">للرياضة</span>
            </div>
        </a>
        <div class="header-actions">
            <!-- مساحة للأزرار المستقبلية -->
        </div>
    </header>

    <main>
        <!-- Announcement Bar -->
        <div class="announcement-wrapper">
            <div class="announcement-bar">
                <i class="fas fa-bolt announcement-icon"></i>
                <marquee behavior="scroll" direction="right" scrollamount="5">@ViewBag.AnnouncementBar</marquee>
            </div>
        </div>

        <div class="container">
            <!-- Dynamic Promo Banner -->
            <div class="hero-banner-container" id="main-promo-banner" style="display: none;">
                <img id="banner-img" src="" alt="عروض المايسترو" class="hero-banner-img">
            </div>

            <!-- Categories Section -->
            <section id="categories-screen" class="active-screen">

                <div class="section-header">
                    <h2 class="section-title">التصنيفات الملكية</h2>
                    <span class="section-subtitle">اختر القسم وابدأ رحلة التفصيل</span>
                </div>

                <div class="categories-scroll-wrapper" id="categories-scroll">
                    <!-- Injected via JS -->
                </div>

                <div class="section-header" style="margin-top: 20px;">
                    <h2 class="section-title" id="current-category-title">أحدث الموديلات</h2>
                    <span class="section-subtitle">تشكيلة واسعة من التصاميم الحصرية</span>
                </div>

                <!-- Products Grid -->
                <div id="products-list" class="products-grid">
                    <!-- Products Injected via JS -->
                </div>

                <!-- Instagram Premium Banner -->
                <div class="insta-banner-card">
                    <div class="insta-banner-inner">
                        <i class="fab fa-instagram insta-icon-large"></i>
                        <h3 style="font-size: 1.8rem; font-weight: 900; margin-bottom: 8px; color: #fff;">مجتمع المايسترو</h3>
                        <p style="color: var(--text-secondary); font-size: 1rem; margin-bottom: 25px; max-width: 400px;">انضم إلينا على إنستجرام لتكون أول من يرى أحدث تصاميمنا وعروضنا الخاصة.</p>
                        <a href="https://www.instagram.com/almystro_sport" target="_blank" class="insta-btn">
                            <i class="fab fa-instagram"></i> تابعنا الآن | @@almystro_sport
                        </a>
                    </div>
                </div>
            </section>
        </div>

        <!-- Professional Footer -->
        <footer class="premium-footer">
            <div class="container">
                <div class="footer-grid">
                    <div class="footer-col-brand">
                        <img src="~/images/logo.png" alt="المايسترو للرياضة" class="footer-logo" onerror="this.style.display='none'">
                        <p>المايسترو للرياضة هو وجهتك الأولى لتفصيل الملابس الرياضية الفاخرة. نجمع بين جودة الأقمشة، دقة التصميم، واحترافية التنفيذ لنقدم لك منتجاً يليق بالأبطال.</p>
                    </div>

                    <div class="footer-col-links">
                        <h3 class="footer-title">روابط سريعة</h3>
                        <ul class="footer-links">
                            <li><a href="#" onclick="window.scrollTo(0,0);"><i class="fas fa-chevron-left"></i> الرئيسية</a></li>
                            <li><a href="#" onclick="window.scrollTo(0,0);"><i class="fas fa-chevron-left"></i> تصفح الأقسام</a></li>
                            <li><a href="https://www.instagram.com/almystro_sport" target="_blank"><i class="fas fa-chevron-left"></i> معرض الأعمال (إنستجرام)</a></li>
                        </ul>
                    </div>

                    <div class="footer-col-contact">
                        <h3 class="footer-title">تواصل معنا</h3>
                        <div class="footer-contact">
                            <p><i class="fas fa-map-marker-alt"></i> <span>سلطنة عمان<br>محافظة جنوب الشرقية<br>جعلان بني بوعلي</span></p>
                            <p><i class="fab fa-instagram"></i> <span style="direction: ltr;">@@almystro_sport</span></p>
                        </div>
                    </div>
                </div>

                <div class="footer-bottom">
                    <p>&copy; 2026 <span>المايسترو للرياضة</span>. جميع الحقوق محفوظة.</p>
                    <p style="font-size: 0.8rem; opacity: 0.6;">صُمم وطور بواسطه GMTWEB</p>
                </div>
            </div>
        </footer>

        <!-- Advanced Bottom Sheet Modal -->
        <div id="order-modal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header-sticky">
                    <div class="modal-drag-handle"></div>
                    <div class="modal-header-content">
                        <h3 id="modal-item-name" class="modal-title">تفاصيل الطلب</h3>
                        <button class="close-btn" onclick="closeModal()"><i class="fas fa-times"></i></button>
                    </div>
                </div>

                <div class="order-form-body">

                    <div id="custom-design-alert" class="hidden" style="background: rgba(212,175,55,0.08); border: 1px dashed var(--gold); padding: 15px; border-radius: var(--border-radius-md); margin-bottom: 25px; display: flex; gap: 12px; align-items: center;">
                        <i class="fas fa-gem text-gold fa-2x"></i>
                        <div>
                            <strong class="text-gold" style="font-size: 1.1rem;">تصميم خاص</strong><br>
                            <span style="color:var(--text-primary); font-size:0.9rem;">يضاف 2 ر.ع لرسوم التصميم للقطعة.</span><br>
                            <span style="color:var(--text-secondary); font-size:0.8rem;">(مجانًا للطلبات من 11 قطعة فأكثر)</span>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-label"><i class="fas fa-address-card"></i> بيانات الاستلام</div>
                        <input type="text" id="customer-name" class="input-modern" placeholder="الاسم الكريم" style="margin-bottom: 12px;">
                        <input type="tel" id="customer-phone" class="input-modern" placeholder="رقم الهاتف للتواصل (مثال: 90000000)">
                    </div>

                    <div class="form-section">
                        <div class="section-label"><i class="fas fa-ruler-combined"></i> تحديد المقاسات</div>
                        <div id="size-options-grid" class="size-selector-grid"></div>

                        <div class="add-action-row">
                            <div class="qty-control-modern">
                                <button type="button" class="qty-btn-modern" onclick="changeQty(-1)"><i class="fas fa-minus"></i></button>
                                <input type="number" id="selected-qty" class="qty-input-modern" value="1" readonly>
                                <button type="button" class="qty-btn-modern" onclick="changeQty(1)"><i class="fas fa-plus"></i></button>
                            </div>
                            <button type="button" class="btn-add-cart" onclick="addSizeToSelection()">
                                إضافة <i class="fas fa-cart-plus"></i>
                            </button>
                        </div>

                        <div id="selected-sizes-list" class="cart-container hidden"></div>
                    </div>

                    <div id="custom-image-section" class="form-section hidden">
                        <div class="section-label"><i class="fas fa-cloud-upload-alt"></i> إرفاق التصميم أو الشعار (اختياري)</div>
                        <div class="file-upload-wrapper">
                            <input type="file" id="custom-image-input" accept="image/*" class="file-upload-input">
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-label"><i class="fas fa-layer-group"></i> اختيار القماش</div>
                        <select id="fabric-select" class="input-modern" onchange="calculateLiveTotal()">
                            <option value="0" data-name="قماش رياضي قياسي">رياضي قياسي (مشمول)</option>
                            <option value="3" data-name="قماش ديواني ملكي">ديواني ملكي (+3 ر.ع)</option>
                            <option value="5" data-name="قماش نخب أول أصلي">نخب أول أصلي (+5 ر.ع)</option>
                            <option value="2" data-name="قماش تبريد مسامي">تبريد مسامي (+2 ر.ع)</option>
                        </select>
                    </div>

                    <div class="form-section">
                        <div class="section-label"><i class="fas fa-pen-nib"></i> تفاصيل إضافية</div>
                        <textarea id="order-notes" class="input-modern" rows="3" placeholder="اكتب الأسماء، الأرقام المطلوبة على الظهر، أو أي ملاحظات لتفصيل طلبك بدقة..."></textarea>
                    </div>

                    <div class="form-section" style="display: flex; gap: 10px;">
                        <input type="text" id="coupon-input" class="input-modern" placeholder="لديك كود خصم؟">
                        <button type="button" onclick="applyCouponLogic()" style="background:var(--bg-surface-elevated); border:1px solid var(--gold); color:var(--gold); border-radius:var(--border-radius-md); padding:0 25px; font-weight:900; cursor:pointer; transition: 0.3s;">تطبيق</button>
                    </div>
                </div>

                <div class="modal-footer-sticky">
                    <div class="price-summary">
                        <span class="price-summary-label">الإجمالي النهائي:</span>
                        <div>
                            <span class="price-summary-value" id="total-price-display">0</span>
                            <span class="price-summary-currency">ر.ع</span>
                        </div>
                    </div>
                    <button class="btn-checkout" onclick="submitOrderProcess()" id="submit-btn">
                        تأكيد وإرسال الطلب <i class="fas fa-check-circle"></i>
                    </button>
                </div>
            </div>
        </div>

    </main>

    <script>
        const categoriesData = @Html.Raw(ViewBag.CategoriesJson ?? "[]");
        const sizesData = @Html.Raw(ViewBag.SizesJson ?? "[]");
        const promoBannerUrl = '@Html.Raw(ViewBag.PromoBannerUrl ?? "")';

        let currentProduct = null;
        let appliedDiscount = 0;
        let activeCouponCode = "";
        let currentSelectedSizeId = null;
        let orderItems = [];
        let activeCategoryId = null;

        window.onload = () => {
            initPromoBanner();
            renderCategoriesScroll();
            if(categoriesData.length > 0) {
                loadCategory(categoriesData[0].Id);
            }
        };

        function initPromoBanner() {
            const bannerContainer = document.getElementById('main-promo-banner');
            const bannerImg = document.getElementById('banner-img');
            if(promoBannerUrl && promoBannerUrl !== "") {
                bannerImg.src = "/" + promoBannerUrl;
                bannerContainer.style.display = "block";
            }
        }

        function toast(title, icon = 'success') {
            Swal.fire({ title: title, icon: icon, timer: 2500, showConfirmButton: false, toast: true, position: 'top', background: '#141414', color: '#ffffff', customClass: { popup: 'swal2-popup-custom' } });
        }

        function renderCategoriesScroll() {
            const container = document.getElementById('categories-scroll');
            if (!container) return;
            container.innerHTML = "";
            categoriesData.forEach((cat, index) => {
                const isActive = index === 0 ? 'active' : '';
                container.innerHTML += `
                    <div class="category-pill ${isActive}" id="cat-pill-${cat.Id}" onclick="loadCategory(${cat.Id})">
                        <i class="fas ${cat.IconClass}"></i>
                        <span>${cat.Name}</span>
                    </div>`;
            });
        }

        function loadCategory(catId) {
            const cat = categoriesData.find(c => c.Id === catId);
            if (!cat) return;

            activeCategoryId = catId;

            document.querySelectorAll('.category-pill').forEach(el => el.classList.remove('active'));
            const activePill = document.getElementById(`cat-pill-${catId}`);
            if(activePill) activePill.classList.add('active');

            document.getElementById('current-category-title').innerText = cat.Name;

            const list = document.getElementById('products-list');
            list.innerHTML = "";

            if (!cat.Products || cat.Products.length === 0) {
                list.innerHTML = `<div style="grid-column: 1/-1; text-align:center; padding: 80px 20px; color:var(--text-secondary); background: var(--bg-surface); border-radius: var(--border-radius-lg); border: 1px dashed var(--border-subtle);"><i class="fas fa-boxes fa-4x" style="opacity:0.3; margin-bottom:20px; color:var(--gold);"></i><p style="font-size: 1.2rem; font-weight: bold;">تشكيلة جديدة قريباً!</p><p style="font-size: 0.9rem;">نقوم بتجهيز أحدث الموديلات لهذا القسم.</p></div>`;
            } else {
                cat.Products.forEach(item => {
                    list.innerHTML += `
                        <div class="product-card" onclick="openOrderModal(${item.Id})">
                            <div class="product-img-container">
                                ${item.IsCustomDesign ? '<div class="badge-custom"><i class="fas fa-crown"></i> خاص</div>' : ''}
                                <img src="/${item.ImageUrl}" onerror="this.src='https://placehold.co/400x500/1e1e1e/D4AF37?text=Maestro'">
                            </div>
                            <div class="product-info">
                                <h3 class="product-title">${item.Name}</h3>
                                <div class="product-footer">
                                    <div class="price-container">
                                        <span class="product-price">${item.BasePrice} <small>ر.ع</small></span>
                                    </div>
                                    <div class="btn-order-action"><i class="fas fa-cart-plus"></i></div>
                                </div>
                            </div>
                        </div>`;
                });
            }
        }

        // --- Modal Logic ---
        function openOrderModal(productId) {
            categoriesData.forEach(c => {
                const found = c.Products.find(p => p.Id === productId);
                if (found) currentProduct = found;
            });
            if (!currentProduct) return;

            document.getElementById('modal-item-name').innerText = currentProduct.Name;

            const alertElement = document.getElementById('custom-design-alert');
            const imageSection = document.getElementById('custom-image-section');

            if(currentProduct.IsCustomDesign) {
                alertElement.classList.remove('hidden');
                imageSection.classList.remove('hidden');
            } else {
                alertElement.classList.add('hidden');
                imageSection.classList.add('hidden');
            }

            // Reset
            orderItems = []; currentSelectedSizeId = null; appliedDiscount = 0; activeCouponCode = "";
            document.getElementById('selected-qty').value = 1;
            document.getElementById('custom-image-input').value = "";
            document.getElementById('order-notes').value = "";
            document.getElementById('fabric-select').value = "0";
            document.getElementById('coupon-input').value = "";

            renderSizeOptions();
            renderSelectedSizes();
            calculateLiveTotal();

            const overlay = document.getElementById('order-modal');
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            setTimeout(() => overlay.classList.add('show'), 10);
        }

        function closeModal() {
            const overlay = document.getElementById('order-modal');
            overlay.classList.remove('show');
            document.body.style.overflow = '';
            setTimeout(() => overlay.classList.add('hidden'), 400);
        }

        function renderSizeOptions() {
            const container = document.getElementById('size-options-grid');
            container.innerHTML = "";
            sizesData.forEach((s, idx) => {
                if(idx === 0) currentSelectedSizeId = s.Id;
                let extra = parseFloat(s.AdditionalPrice);
                let extraText = extra > 0 ? `+${extra}` : (extra < 0 ? `${extra}` : "");
                container.innerHTML += `
                    <div class="size-btn-modern ${idx === 0 ? 'active' : ''}" onclick="selectSizeBtn(${s.Id}, this)">
                        ${s.Name}
                        ${extraText ? `<span class="size-extra-price">${extraText}</span>` : ''}
                    </div>`;
            });
        }

        function selectSizeBtn(id, btnElement) {
            currentSelectedSizeId = id;
            document.querySelectorAll('.size-btn-modern').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');
        }

        function changeQty(delta) {
            let input = document.getElementById('selected-qty');
            let val = parseInt(input.value) + delta;
            input.value = val < 1 ? 1 : val;
        }

        function addSizeToSelection() {
            if(!currentSelectedSizeId) return;
            const qty = parseInt(document.getElementById('selected-qty').value);
            const sizeObj = sizesData.find(s => s.Id === currentSelectedSizeId);

            const existing = orderItems.find(i => i.SizeId === currentSelectedSizeId);
            if(existing) existing.Quantity += qty;
            else orderItems.push({ SizeId: sizeObj.Id, SizeName: sizeObj.Name, ExtraPrice: parseFloat(sizeObj.AdditionalPrice) || 0, Quantity: qty });

            document.getElementById('selected-qty').value = 1;
            renderSelectedSizes();
            calculateLiveTotal();
            toast("تمت الإضافة للسلة بنجاح");
        }

        function removeSizeFromSelection(index) {
            orderItems.splice(index, 1);
            renderSelectedSizes();
            calculateLiveTotal();
        }

        function renderSelectedSizes() {
            const container = document.getElementById('selected-sizes-list');
            if(orderItems.length === 0) {
                container.classList.add('hidden');
                container.innerHTML = '';
                return;
            }

            container.classList.remove('hidden');
            container.innerHTML = "";
            orderItems.forEach((item, index) => {
                container.innerHTML += `
                    <div class="cart-item-modern">
                        <div class="cart-item-info">
                            <span class="cart-item-size">${item.SizeName}</span>
                            <span class="cart-item-qty">الكمية: <b style="color:#fff;">${item.Quantity}</b></span>
                        </div>
                        <button type="button" class="btn-del-cart" onclick="removeSizeFromSelection(${index})"><i class="fas fa-trash-alt"></i></button>
                    </div>`;
            });
        }

        function calculateLiveTotal(isCouponClick = false) {
            if (!currentProduct) return;
            let totalQty = 0; let totalPrice = 0;
            const fabricExtra = parseFloat(document.getElementById('fabric-select').value) || 0;

            orderItems.forEach(item => {
                totalQty += item.Quantity;
                totalPrice += item.Quantity * (currentProduct.BasePrice + item.ExtraPrice + fabricExtra);
            });

            if (currentProduct.IsCustomDesign && totalQty > 0 && totalQty <= 10) totalPrice += (2 * totalQty);

            if (isCouponClick) {
                const code = document.getElementById('coupon-input').value.trim().toUpperCase();
                if (!code) return;
                fetch(`/Home/ValidateCoupon?code=${encodeURIComponent(code)}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.valid) { appliedDiscount = data.discount; activeCouponCode = code; toast(`تم تفعيل الخصم: ${data.discount} ر.ع`); }
                        else { appliedDiscount = 0; activeCouponCode = ""; toast('الكود المدخل غير صحيح', 'error'); }
                        updateDisplay();
                    });
            } else updateDisplay();

            function updateDisplay() {
                let final = Math.max(0, totalPrice - appliedDiscount);
                document.getElementById('total-price-display').innerText = final.toFixed(2);
            }
            return { totalQty, totalPrice: Math.max(0, totalPrice - appliedDiscount) };
        }

        function submitOrderProcess() {
            const customerName = document.getElementById('customer-name').value.trim();
            const customerPhone = document.getElementById('customer-phone').value.trim();

            if(!customerName || !customerPhone) {
                Swal.fire({title: 'بيانات ناقصة', text: 'يرجى إدخال اسمك ورقم هاتفك لنتواصل معك.', icon: 'warning', background: '#141414', color: '#fff'});
                return;
            }

            const { totalQty, totalPrice } = calculateLiveTotal();
            if (totalQty === 0) {
                Swal.fire({title: 'السلة فارغة', text: 'يرجى اختيار مقاس وكمية ثم الضغط على "إضافة" قبل التأكيد.', icon: 'warning', background: '#141414', color: '#fff'});
                return;
            }

            const btn = document.getElementById('submit-btn');
            btn.disabled = true; btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> جاري معالجة الطلب...';

            const fabricSelect = document.getElementById('fabric-select');
            const formData = new FormData();
            formData.append('CustomerName', customerName);
            formData.append('PhoneNumber', customerPhone);
            formData.append('ProductId', currentProduct.Id);
            formData.append('Notes', document.getElementById('order-notes').value || "");
            formData.append('FabricType', fabricSelect.options[fabricSelect.selectedIndex].getAttribute('data-name'));
            formData.append('FabricExtraPrice', parseFloat(fabricSelect.value) || 0);
            formData.append('CouponCode', activeCouponCode);
            formData.append('ItemsJson', JSON.stringify(orderItems.map(i => ({ SizeId: i.SizeId, Quantity: i.Quantity }))));

            const imageInput = document.getElementById('custom-image-input');
            if(imageInput && imageInput.files.length > 0) formData.append('CustomImage', imageInput.files[0]);

            fetch('/Home/SubmitOrder', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeModal();
                    Swal.fire({
                        title: 'تم تأكيد طلبك بنجاح!',
                        html: `<div style="text-align:right; margin-top:20px; line-height: 1.8;">
                                <div style="background:var(--bg-surface-elevated); border:1px dashed var(--gold); border-radius:16px; padding:20px; text-align:center; margin-bottom: 25px;">
                                    <p style="font-size:0.95rem; color:var(--text-secondary); margin-bottom:5px;">رقم الطلب المرجعي</p>
                                    <p style="font-size:2.8rem; font-weight:900; color:var(--gold); margin:0; letter-spacing: 2px; text-shadow: 0 0 10px rgba(212,175,55,0.3);">#${data.orderId}</p>
                                </div>
                                <div style="padding: 0 10px; font-size: 1.1rem;">
                                    <p>الاسم: <strong style="color:#fff;">${customerName}</strong></p>
                                    <p>موعد التسليم المتوقع: <strong style="color:#2ecc71;">${data.deliveryDate}</strong></p>
                                </div>
                                <p style="font-size:0.9rem; color:var(--text-secondary); margin-top:25px; text-align:center; padding-top: 15px; border-top: 1px solid var(--border-subtle);">
                                    يرجى الاحتفاظ برقم الطلب. سيتواصل معك فريق المايسترو قريباً عبر الهاتف لتأكيد الدفع والبدء بالتنفيذ.
                                </p>
                               </div>`,
                        icon: 'success', confirmButtonText: 'حسناً، شكراً لكم',
                        background: '#0a0a0a', color: '#fff',
                        customClass: { confirmButton: 'btn-checkout' }
                    });
                } else {
                    Swal.fire({title: 'خطأ في الإرسال', text: data.message, icon: 'error', background: '#141414', color: '#fff'});
                }
            })
            .catch(() => Swal.fire({title: 'خطأ في الاتصال', text: 'يرجى التحقق من اتصالك بالإنترنت والمحاولة مجدداً.', icon: 'error', background: '#141414', color: '#fff'}))
            .finally(() => { btn.disabled = false; btn.innerHTML = 'تأكيد وإرسال الطلب <i class="fas fa-check-circle"></i>'; });
        }
    </script>
</body>
</html>