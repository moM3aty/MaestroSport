@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>المايسترو للرياضة | الفخامة في التفصيل</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="~/images/logo.png" rel="icon" type="image/x-icon" />

    <style>
        /* ==========================================================================
                           ULTRA PREMIUM DESIGN SYSTEM
                           ========================================================================== */
        :root {
            --gold: #D4AF37;
            --gold-light: #F3E5AB;
            --gold-dark: #aa8c2c;
            --gold-gradient: linear-gradient(135deg, #D4AF37 0%, #aa8c2c 100%);
            --gold-glow: 0 4px 15px rgba(212, 175, 55, 0.25);
            --bg-base: #030303;
            --bg-surface: #0a0a0a;
            --bg-surface-elevated: #1a1a1a;
            --border-subtle: rgba(212, 175, 55, 0.1);
            --border-active: rgba(212, 175, 55, 0.4);
            --text-primary: #ffffff;
            --text-secondary: #9e9e9e;
            --text-tertiary: #666666;
            --insta-grad: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --border-radius-lg: 20px;
            --border-radius-md: 12px;
            --border-radius-sm: 8px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-base);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
            background-image: radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.03) 0%, transparent 50%);
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-base);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--gold-dark);
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: var(--gold);
            }

        .text-gold {
            color: var(--gold) !important;
        }

        .hidden {
            display: none !important;
        }

        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(3, 3, 3, 0.95);
            border-bottom: 1px solid var(--border-subtle);
            z-index: 1000;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 75px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .header-logo {
            width: 45px;
            height: 45px;
            object-fit: contain;
            filter: drop-shadow(0 0 5px rgba(212,175,55,0.4));
        }

        .header-title-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .header-title {
            font-weight: 900;
            font-size: 1.25rem;
            color: var(--text-primary);
            margin: 0;
            line-height: 1.1;
            letter-spacing: -0.5px;
        }

        .header-subtitle {
            font-size: 0.75rem;
            color: var(--gold);
            letter-spacing: 1px;
            font-weight: 600;
            text-transform: uppercase;
        }

        main {
            padding-top: 75px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding-bottom: 80px; /* Space for fab */
        }

        .container {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .app-screen {
            display: none;
            animation: fadeIn 0.4s ease forwards;
        }

            .app-screen.active {
                display: block;
            }
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .announcement-wrapper {
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-subtle);
            padding: 8px 0;
            display: flex;
            align-items: center;
        }

        .announcement-bar {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .announcement-icon {
            color: var(--gold);
            font-size: 1.1rem;
            animation: pulse 2s infinite;
        }

        .announcement-bar marquee {
            flex-grow: 1;
            color: var(--gold-light);
            font-weight: 600;
            font-size: 0.95rem;
        }
        @@keyframes pulse {
            0%

        {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.7;
            transform: scale(1.1);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }

        }

        .hero-banner-container {
            margin: 20px auto;
            border-radius: var(--border-radius-lg);
            overflow: hidden;
            position: relative;
            border: 1px solid var(--border-active);
            box-shadow: var(--gold-glow);
            aspect-ratio: 21/9;
            background-color: var(--bg-surface-elevated);
        }
        @@media (max-width: 768px) {
            .hero-banner-container

        {
            aspect-ratio: 16/9;
        }

        }

        .hero-banner-img {
            height: 100%;
            margin: auto;
            display: block;
        }

        .entry-gate {
            background: var(--bg-surface-elevated);
            border: 2px dashed var(--gold);
            border-radius: var(--border-radius-lg);
            padding: 40px 20px;
            text-align: center;
            cursor: pointer;
            margin: 30px auto 40px auto;
            max-width: 600px;
            transition: var(--transition-smooth);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            position: relative;
            overflow: hidden;
        }

            .entry-gate::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 50%;
                height: 100%;
                background: linear-gradient(to right, transparent, rgba(212,175,55,0.1), transparent);
                transform: skewX(-20deg);
                animation: shine 3s infinite;
            }
        @@keyframes shine {
            100%

        {
            left: 200%;
        }

        }

        .entry-gate:hover, .entry-gate:active {
            background: rgba(212, 175, 55, 0.08);
            border-style: solid;
            transform: translateY(-5px);
            box-shadow: var(--gold-glow);
        }

        .entry-gate-icon {
            width: 70px;
            height: 70px;
            background: var(--gold-gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px auto;
            font-size: 2rem;
            color: var(--bg-base);
            box-shadow: 0 5px 15px rgba(212,175,55,0.4);
        }

        .entry-gate h2 {
            font-size: 1.6rem;
            font-weight: 900;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .entry-gate p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            font-weight: 600;
        }

        .screen-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 25px 0;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border-subtle);
        }

        .screen-title {
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .screen-title::before {
                content: '';
                display: block;
                width: 4px;
                height: 20px;
                background: var(--gold-gradient);
                border-radius: 4px;
            }

        .btn-back-nav {
            background: var(--bg-surface-elevated);
            border: 1px solid var(--border-subtle);
            color: var(--text-primary);
            padding: 8px 15px;
            border-radius: var(--border-radius-md);
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .search-container {
            position: relative;
            margin-bottom: 25px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .search-input {
            width: 100%;
            padding: 15px 45px 15px 15px;
            background: var(--bg-surface-elevated);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            color: var(--text-primary);
            font-family: inherit;
            font-size: 1rem;
            transition: var(--transition-smooth);
        }

            .search-input:focus {
                border-color: var(--gold);
                box-shadow: var(--gold-glow);
                outline: none;
            }

        .search-icon {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        .no-results {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-secondary);
            font-size: 1.1rem;
            grid-column: 1 / -1;
            display: none;
        }

        .grid-layout {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 50px;
        }
        @@media (min-width: 768px) {
            .grid-layout

        {
            grid-template-columns: repeat(2, minmax(0, 400px));
            justify-content: center;
            gap: 25px;
        }

        }

        .category-card {
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            padding: 25px 15px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition-smooth);
        }

            .category-card:hover {
                border-color: var(--gold);
                transform: translateY(-5px);
                background: var(--bg-surface-elevated);
                box-shadow: var(--gold-glow);
            }

        .cat-icon-wrapper {
            font-size: 2.5rem;
            margin-bottom: 15px;
            color: var(--gold);
        }

        .category-name {
            font-weight: 800;
            font-size: 1.1rem;
            color: #fff;
        }

        .product-card {
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            cursor: pointer;
        }

            .product-card:hover {
                border-color: var(--border-active);
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.6);
            }

        .product-img-container {
            position: relative;
            width: 100%;
            padding-top: 130%;
            background: var(--bg-surface-elevated);
        }

            .product-img-container img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .badge-custom {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.8);
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 0.7rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .product-info {
            padding: 15px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-title {
            font-size: 1rem;
            font-weight: 800;
            margin-bottom: 10px;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
            border-top: 1px solid rgba(255,255,255,0.05);
            padding-top: 10px;
        }

        .product-price {
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--gold);
        }

        .btn-order-action {
            background: var(--bg-surface-elevated);
            color: var(--gold);
            border: 1px solid var(--gold);
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .insta-banner-card {
            background: var(--bg-surface);
            border-radius: var(--border-radius-lg);
            padding: 2px;
            position: relative;
            overflow: hidden;
            margin: 20px auto 50px auto;
            max-width: 800px;
        }

            .insta-banner-card::before {
                content: '';
                position: absolute;
                inset: 0;
                background: var(--insta-grad);
                opacity: 0.6;
                filter: blur(25px);
            }

        .insta-banner-inner {
            position: relative;
            background: var(--bg-surface);
            border-radius: 18px;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .insta-icon-large {
            font-size: 4rem;
            background: var(--insta-grad);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
        }

        .insta-btn {
            margin-top: 20px;
            background: var(--insta-grad);
            color: #fff !important;
            text-decoration: none;
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 8px 25px rgba(220, 39, 67, 0.4);
        }

        .premium-footer {
            background: #050505;
            border-top: 1px solid var(--border-subtle);
            padding: 50px 0 20px 0;
            margin-top: auto;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
            margin-bottom: 30px;
            text-align: center;
        }
        @@media (min-width: 768px) {
            .footer-grid

        {
            grid-template-columns: 1fr 1fr;
            text-align: right;
        }

        }

        .footer-logo {
            width: 60px;
            margin-bottom: 15px;
            opacity: 0.8;
            filter: grayscale(1);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.05);
            color: var(--text-tertiary);
            font-size: 0.85rem;
        }

        /* Footer Links Styles */
        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .footer-links li a {
                color: var(--text-secondary);
                text-decoration: none;
                transition: var(--transition-smooth);
                font-weight: 600;
                font-size: 0.95rem;
            }

                .footer-links li a:hover {
                    color: var(--gold);
                    padding-right: 5px;
                }

        /* Legal Pages Styling */
        .legal-content {
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            padding: 30px;
            margin-bottom: 40px;
        }

            .legal-content h3 {
                color: var(--gold);
                margin-bottom: 15px;
                font-weight: 900;
                font-size: 1.2rem;
            }

            .legal-content p, .legal-content li {
                color: var(--text-secondary);
                line-height: 1.8;
                margin-bottom: 15px;
                font-size: 0.95rem;
            }

            .legal-content ul {
                padding-right: 20px;
            }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

            .modal-overlay.show {
                opacity: 1;
                pointer-events: auto;
            }

        .modal-content {
            background: var(--bg-surface);
            width: 100%;
            max-width: 600px;
            max-height: 92vh;
            overflow-y: auto;
            border-radius: 30px 30px 0 0;
            padding: 0 25px 30px 25px;
            border-top: 1px solid var(--border-active);
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
            display: flex;
            flex-direction: column;
            box-shadow: 0 -10px 40px rgba(0,0,0,0.8);
        }

        .modal-overlay.show .modal-content {
            transform: translateY(0);
        }

        .modal-header-sticky {
            position: sticky;
            top: 0;
            background: var(--bg-surface);
            padding: 20px 0 15px 0;
            z-index: 10;
            border-bottom: 1px solid var(--border-subtle);
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .modal-drag-handle {
            width: 50px;
            height: 5px;
            background: var(--bg-surface-elevated);
            border-radius: 5px;
            margin-bottom: 15px;
        }

        .modal-header-content {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 1.25rem;
            font-weight: 900;
            color: var(--gold);
            margin: 0;
        }

        .close-btn {
            background: var(--bg-surface-elevated);
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            color: var(--text-primary);
            cursor: pointer;
            font-size: 1.2rem;
        }

        .step-view {
            display: none;
            animation: fadeIn 0.3s ease;
        }

            .step-view.active {
                display: block;
            }

        .form-section {
            margin-bottom: 25px;
        }

        .section-label {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
            color: var(--text-primary);
            font-weight: 800;
            font-size: 1rem;
        }

            .section-label i {
                color: var(--gold);
            }

        .input-modern {
            width: 100%;
            padding: 15px;
            background: var(--bg-base);
            border: 1px solid var(--border-subtle);
            color: #fff;
            border-radius: var(--border-radius-md);
            font-family: inherit;
            font-size: 1rem;
        }

            .input-modern:focus {
                border-color: var(--gold);
                outline: none;
            }

        .size-selector-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(65px, 1fr));
            gap: 10px;
        }

        .size-btn-modern {
            background: var(--bg-base);
            border: 1px solid var(--border-subtle);
            color: var(--text-primary);
            padding: 12px 5px;
            border-radius: var(--border-radius-md);
            cursor: pointer;
            text-align: center;
            font-weight: 800;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .size-btn-modern.active {
                background: var(--gold-gradient);
                color: var(--bg-base);
                border-color: transparent;
            }

        .size-extra-price {
            font-size: 0.7rem;
            opacity: 0.8;
            margin-top: 4px;
        }

        .size-btn-modern.active .size-extra-price {
            color: rgba(0,0,0,0.7);
            font-weight: 900;
        }

        .add-action-row {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            align-items: center;
        }

        .qty-control-modern {
            display: flex;
            align-items: center;
            background: #1e1e1e;
            border-radius: var(--border-radius-md);
            border: 1px solid var(--gold);
            padding: 5px;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.8);
        }

        .qty-btn-modern {
            background: #2a2a2a;
            border: 1px solid rgba(212,175,55,0.3);
            color: var(--gold);
            width: 45px;
            height: 45px;
            border-radius: var(--border-radius-sm);
            font-size: 1.2rem;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .qty-btn-modern:active {
                background: var(--gold);
                color: #000;
            }

        .qty-input-modern {
            width: 50px;
            background: transparent;
            border: none;
            color: #fff;
            text-align: center;
            font-weight: 900;
            font-size: 1.5rem;
            pointer-events: none;
        }

        .btn-add-cart {
            flex-grow: 1;
            background: var(--gold-gradient);
            border: none;
            color: var(--bg-base);
            border-radius: var(--border-radius-md);
            font-weight: 900;
            font-size: 1.1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            height: 57px;
        }

        .cart-container {
            background: var(--bg-base);
            border-radius: var(--border-radius-md);
            padding: 15px;
            margin-top: 15px;
            border: 1px dashed var(--border-active);
        }

        .cart-item-modern {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

            .cart-item-modern:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

        .cart-item-size {
            background: var(--bg-surface-elevated);
            padding: 5px 12px;
            border-radius: 8px;
            color: var(--gold);
            font-weight: 900;
        }

        .btn-del-cart {
            background: rgba(255,71,87,0.1);
            color: #ff4757;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .file-upload-input {
            width: 100%;
            padding: 15px;
            background: var(--bg-base);
            border: 1px dashed var(--gold);
            border-radius: var(--border-radius-md);
            color: var(--text-primary);
            cursor: pointer;
        }

            .file-upload-input::file-selector-button {
                background: var(--bg-surface-elevated);
                color: var(--gold);
                border: 1px solid var(--gold);
                padding: 8px 16px;
                border-radius: 8px;
                font-weight: bold;
                margin-left: 15px;
                cursor: pointer;
            }

        .delivery-mega-card {
            background: rgba(46, 204, 113, 0.08);
            border: 2px dashed rgba(46, 204, 113, 0.4);
            border-radius: var(--border-radius-md);
            padding: 25px 20px;
            text-align: center;
            margin-bottom: 25px;
        }

        .delivery-mega-icon {
            font-size: 2.5rem;
            color: #2ecc71;
            margin-bottom: 10px;
        }

        .delivery-mega-text {
            display: block;
            color: var(--text-primary);
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .delivery-mega-date {
            display: block;
            color: #2ecc71;
            font-weight: 900;
            font-size: 1.8rem;
            letter-spacing: 2px;
        }

        .summary-card {
            background: var(--bg-base);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-md);
            padding: 20px;
            margin-bottom: 25px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 1rem;
        }

            .summary-row.total {
                margin-top: 15px;
                padding-top: 15px;
                border-top: 1px dashed rgba(255,255,255,0.1);
                font-size: 1.2rem;
                font-weight: 900;
                color: var(--gold);
            }

        .modal-footer-sticky {
            position: sticky;
            bottom: 0;
            background: var(--bg-surface);
            padding: 20px 0 0 0;
            margin-top: auto;
            border-top: 1px solid var(--border-subtle);
        }

        .price-summary {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 15px;
        }

        .price-summary-value {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--gold);
            line-height: 1;
        }

        .btn-wizard {
            width: 100%;
            background: var(--gold-gradient);
            color: var(--bg-base);
            border: none;
            padding: 18px;
            border-radius: var(--border-radius-md);
            font-size: 1.25rem;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: transform 0.2s;
        }

            .btn-wizard:active {
                transform: scale(0.97);
            }

        .btn-wizard-outline {
            width: 100%;
            background: transparent;
            color: var(--text-primary);
            border: 1px solid var(--border-subtle);
            padding: 15px;
            border-radius: var(--border-radius-md);
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-wizard-outline:hover {
                border-color: var(--text-primary);
            }

        .step-2-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .swal2-popup-custom {
            background: var(--bg-surface-elevated) !important;
            border: 1px solid var(--border-active) !important;
            border-radius: var(--border-radius-lg) !important;
            color: #fff !important;
        }

        .whatsapp-float {
            position: fixed;
            bottom: 25px;
            left: 25px;
            background: linear-gradient(135deg, #25D366, #128C7E);
            color: #fff !important;
            border-radius: 50px;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 900;
            font-size: 1.1rem;
            box-shadow: 0 10px 25px rgba(37, 211, 102, 0.4);
            z-index: 998;
            text-decoration: none;
            transition: transform 0.3s, box-shadow 0.3s;
            border: 1px solid rgba(255,255,255,0.2);
        }

            .whatsapp-float:hover, .whatsapp-float:active {
                transform: translateY(-5px) scale(1.05);
                box-shadow: 0 15px 30px rgba(37, 211, 102, 0.6);
            }

            .whatsapp-float i {
                font-size: 1.6rem;
            }

        .cart-float-btn {
            position: fixed;
            bottom: 25px;
            right: 25px;
            background: var(--gold-gradient);
            color: #000 !important;
            border-radius: 50px;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 900;
            font-size: 1.1rem;
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.4);
            z-index: 998;
            text-decoration: none;
            transition: transform 0.3s, box-shadow 0.3s;
            border: 1px solid rgba(255,255,255,0.2);
            cursor: pointer;
            display: none;
        }

            .cart-float-btn:hover, .cart-float-btn:active {
                transform: translateY(-5px) scale(1.05);
                box-shadow: 0 15px 30px rgba(212, 175, 55, 0.6);
            }

        .cart-badge-counter {
            background: #ff4757;
            color: #fff;
            border-radius: 50%;
            padding: 2px 8px;
            font-size: 0.9rem;
            position: absolute;
            top: -8px;
            right: -8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>

    <header class="header">
        <a href="#" class="header-brand" onclick="toggleView('home')">
            <img src="~/images/logo.png" alt="المايسترو" class="header-logo" onerror="this.src='https://placehold.co/100/111/D4AF37?text=M'">
            <div class="header-title-container">
                <h1 class="header-title">المايسترو</h1>
            </div>
        </a>
    </header>

    <main>
        <div class="announcement-wrapper">
            <div class="announcement-bar">
                <i class="fas fa-bolt announcement-icon"></i>
                <marquee behavior="scroll" direction="right" scrollamount="5">@ViewBag.AnnouncementBar</marquee>
            </div>
        </div>

        <!-- ==============================================
             SCREEN 1: THE HOME
             ============================================== -->
        <section id="home-screen" class="app-screen active">
            <div class="container">
                <div class="hero-banner-container" id="main-promo-banner" style="display: none;">
                    <img id="banner-img" src="" alt="عروض المايسترو" class="hero-banner-img">
                </div>
                <div class="entry-gate" onclick="toggleView('categories')">
                    <div class="entry-gate-icon"><i class="fas fa-cut"></i></div>
                    <h2>تفصيل وخياطة الملابس الرياضية</h2>
                    <p>اضغط هنا لبدء الطلب واختيار الأقسام المتاحة</p>
                </div>
                <div class="insta-banner-card">
                    <div class="insta-banner-inner">
                        <i class="fab fa-instagram insta-icon-large"></i>
                        <h3 style="font-size: 1.6rem; font-weight: 900; margin-bottom: 8px; color: #fff;">مجتمع المايسترو</h3>
                        <p style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 20px;">انضم إلينا لتكون أول من يرى أحدث تصاميمنا</p>
                        <a href="https://www.instagram.com/almystro_sport" target="_blank" class="insta-btn">
                            <i class="fab fa-instagram"></i> تابعنا الآن | @@almystro_sport
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==============================================
             SCREEN 2: CATEGORIES & GLOBAL SEARCH
             ============================================== -->
        <section id="categories-screen" class="app-screen">
            <div class="container">
                <div class="screen-header">
                    <h2 class="screen-title">الأقسام المتاحة</h2>
                    <button class="btn-back-nav" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> رجوع للرئيسية</button>
                </div>

                <div class="search-container" id="global-search-container">
                    <input type="text" id="global-search-input" class="search-input" placeholder="ابحث عن أي موديل في جميع الأقسام..." onkeyup="filterGlobalProducts()">
                    <i class="fas fa-search search-icon"></i>
                </div>

                <div class="grid-layout" id="categories-render"></div>

                <div id="global-products-list" class="grid-layout" style="display: none;"></div>

                <div id="global-no-search-results" class="no-results" style="display: none;">
                    <i class="fas fa-search-minus fa-3x" style="opacity:0.3; margin-bottom:15px; display:block;"></i>
                    <p>عذراً، لم نجد أي موديل يطابق بحثك.</p>
                </div>

            </div>
        </section>

        <!-- ==============================================
             SCREEN 3: PRODUCTS INSIDE SPECIFIC CATEGORY
             ============================================== -->
        <section id="shop-screen" class="app-screen">
            <div class="container">
                <div class="screen-header">
                    <h2 class="screen-title" id="current-category-title">الموديلات</h2>
                    <button class="btn-back-nav" onclick="toggleView('categories')"><i class="fas fa-arrow-right"></i> رجوع للأقسام</button>
                </div>

                <div id="products-list" class="grid-layout"></div>
                <div id="no-search-results" class="no-results" style="display: none;"></div>
            </div>
        </section>

        <!-- ==============================================
             LEGAL SCREENS (About, Terms, Privacy, Return)
             ============================================== -->
        <section id="about-screen" class="app-screen">
            <div class="container">
                <div class="screen-header">
                    <h2 class="screen-title">من نحن</h2>
                    <button class="btn-back-nav" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> رجوع</button>
                </div>
                <div class="legal-content">
                    <h3><i class="fas fa-crown"></i> المايسترو للرياضة</h3>
                    <p>نحن علامة تجارية رائدة في سلطنة عمان متخصصة في تفصيل وخياطة الملابس الرياضية بأعلى معايير الجودة والاحترافية. نهدف إلى تقديم تصاميم مريحة وعصرية تليق بالرياضيين والفرق الرياضية.</p>
                    <p>نجمع بين جودة الأقمشة المنتقاة بعناية ودقة التنفيذ لنضمن لك منتجاً يفوق توقعاتك. سواء كنت فرداً يبحث عن التميز أو فريقاً يطمح لتوحيد هويته الرياضية، المايسترو هو خيارك الأول.</p>
                </div>
            </div>
        </section>

        <section id="terms-screen" class="app-screen">
            <div class="container">
                <div class="screen-header">
                    <h2 class="screen-title">الشروط والأحكام</h2>
                    <button class="btn-back-nav" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> رجوع</button>
                </div>
                <div class="legal-content">
                    <h3><i class="fas fa-file-contract"></i> ضوابط الخدمة والتفصيل</h3>
                    <ul>
                        <li>يعتبر الطلب مؤكداً ونهائياً بعد إتمام عملية الدفع ووصول رسالة التأكيد.</li>
                        <li>تبدأ مدة التفصيل المحتسبة من اليوم التالي لتأكيد الدفع واستلام كافة التفاصيل.</li>
                        <li>التصاميم الخاصة المرفقة تخضع لمراجعة الإدارة، ونحتفظ بحق رفض أي تصميم يتعارض مع القوانين والآداب العامة.</li>
                        <li>الأسعار المعروضة قابلة للتغيير، ولكن الطلبات المؤكدة والمدفوعة لا تتأثر بأي تغيير لاحق في الأسعار.</li>
                        <li>يرجى التأكد من اختيار المقاسات الصحيحة بدقة، حيث لا يمكن تعديل المقاس بعد بدء عملية القص والخياطة.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section id="return-screen" class="app-screen">
            <div class="container">
                <div class="screen-header">
                    <h2 class="screen-title">سياسة الاسترجاع</h2>
                    <button class="btn-back-nav" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> رجوع</button>
                </div>
                <div class="legal-content">
                    <h3><i class="fas fa-undo-alt"></i> سياسة الاستبدال والاسترجاع</h3>
                    <p>نظراً لطبيعة عملنا التي تعتمد على "التفصيل الخاص" بناءً على طلب وقياسات الزبون، فإن السياسة المتبعة هي:</p>
                    <ul>
                        <li>لا يمكن استرجاع أو استبدال المنتجات بعد تفصيلها، نظراً لكونها صُنعت خصيصاً للمشتري.</li>
                        <li><strong>استثناء:</strong> يحق للزبون الاستبدال أو تعديل القطعة مجاناً في حالة وجود <strong>عيب مصنعي واضح</strong> أو استلامه مقاساً/تصميماً يختلف عما هو موثق في فاتورة الطلب.</li>
                        <li>في حالة وجود خطأ من طرفنا، يجب إبلاغنا خلال مدة أقصاها <strong>3 أيام</strong> من تاريخ الاستلام ليتم التعامل مع المشكلة بأسرع وقت.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section id="privacy-screen" class="app-screen">
            <div class="container">
                <div class="screen-header">
                    <h2 class="screen-title">سياسة الخصوصية</h2>
                    <button class="btn-back-nav" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> رجوع</button>
                </div>
                <div class="legal-content">
                    <h3><i class="fas fa-user-shield"></i> حماية بياناتك</h3>
                    <p>خصوصية معلوماتك هي أولويتنا في "المايسترو للرياضة".</p>
                    <ul>
                        <li>نقوم بجمع بيانات أساسية فقط (الاسم ورقم الهاتف) لغرض تنفيذ وتوصيل طلبك.</li>
                        <li>لا نقوم بمشاركة، بيع، أو تأجير بياناتك الشخصية لأي طرف ثالث تحت أي ظرف.</li>
                        <li>قد يتم استخدام التصاميم المنفذة للفرق والزبائن كجزء من معرض أعمالنا على حساباتنا الرسمية (مثل إنستجرام)، ما لم يطلب الزبون مسبقاً عدم نشرها.</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="premium-footer">
            <div class="container">
                <div class="footer-grid">
                    <div style="text-align: center; margin-bottom: 20px;">
                        <img src="~/images/logo.png" alt="المايسترو للرياضة" class="footer-logo" onerror="this.style.display='none'" style="margin: 0 auto 15px auto;">
                        <p style="color: var(--text-tertiary); font-size: 0.9rem;">الفخامة في تفصيل الملابس الرياضية</p>
                    </div>

                    <div style="display: flex; justify-content: space-around; text-align: right;">
                        <!-- روابط معلومات الشركة -->
                        <div>
                            <h4 style="color: var(--gold); margin-bottom: 15px; font-size: 1.1rem;">معلومات المتجر</h4>
                            <ul class="footer-links">
                                <li><a href="#" onclick="toggleView('about')"><i class="fas fa-chevron-left" style="font-size: 0.7rem; color:var(--gold); margin-left:5px;"></i> من نحن</a></li>
                                <li><a href="#" onclick="toggleView('terms')"><i class="fas fa-chevron-left" style="font-size: 0.7rem; color:var(--gold); margin-left:5px;"></i> الشروط والأحكام</a></li>
                                <li><a href="#" onclick="toggleView('return')"><i class="fas fa-chevron-left" style="font-size: 0.7rem; color:var(--gold); margin-left:5px;"></i> سياسة الاسترجاع</a></li>
                                <li><a href="#" onclick="toggleView('privacy')"><i class="fas fa-chevron-left" style="font-size: 0.7rem; color:var(--gold); margin-left:5px;"></i> سياسة الخصوصية</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>&copy; 2026 المايسترو للرياضة. جميع الحقوق محفوظة.</p>
                </div>
            </div>
        </footer>
        <div id="product-modal" class="modal-overlay">
            <div class="modal-content" style="max-height: 80vh;">
                <div class="modal-header-sticky">
                    <div class="modal-drag-handle"></div>
                    <div class="modal-header-content">
                        <h3 id="product-modal-name" class="modal-title">اختيار المقاسات</h3>
                        <button class="close-btn" onclick="closeProductModal()"><i class="fas fa-times"></i></button>
                    </div>
                </div>
                <div class="order-form-body">
                    <div id="custom-design-alert" class="hidden" style="background: rgba(212,175,55,0.08); border: 1px dashed var(--gold); padding: 15px; border-radius: var(--border-radius-md); margin-bottom: 25px; display: flex; gap: 12px; align-items: center;">
                        <i class="fas fa-gem text-gold fa-2x"></i>
                        <div>
                            <strong class="text-gold" style="font-size: 1.1rem;">تصميم خاص</strong><br>
                            <span style="color:var(--text-primary); font-size:0.9rem;">يضاف 2 ر.ع لرسوم التصميم. (مجانًا للطلبات الإجمالية 11 قطعة فأكثر)</span>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-label"><i class="fas fa-ruler-combined"></i> تحديد المقاسات</div>
                        <div id="size-options-grid" class="size-selector-grid"></div>

                        <div class="add-action-row">
                            <div class="qty-control-modern">
                                <button type="button" class="qty-btn-modern" onclick="changeQty(-1)"><i class="fas fa-minus"></i></button>
                                <input type="number" id="selected-qty" class="qty-input-modern" value="1" readonly>
                                <button type="button" class="qty-btn-modern" onclick="changeQty(1)"><i class="fas fa-plus"></i></button>
                            </div>
                            <button type="button" class="btn-add-cart" onclick="addSizeToCart()">
                                أضف للسلة <i class="fas fa-cart-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==============================================
             MODAL 2: CHECKOUT WIZARD (إتمام الطلب)
             ============================================== -->
        <div id="order-modal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header-sticky">
                    <div class="modal-drag-handle"></div>
                    <div class="modal-header-content">
                        <h3 class="modal-title">إتمام الطلب</h3>
                        <button class="close-btn" onclick="closeCheckoutModal()"><i class="fas fa-times"></i></button>
                    </div>
                </div>

                <div class="order-form-body">
                    <div id="step-1-details" class="step-view active">

                        <!-- سلة المشتريات المجمعة -->
                        <div class="form-section">
                            <div class="section-label"><i class="fas fa-shopping-bag"></i> محتويات السلة</div>
                            <div id="global-cart-list" class="cart-container"></div>
                        </div>

                        <div class="form-section">
                            <div class="section-label"><i class="fas fa-address-card"></i> بيانات الاستلام</div>
                            <input type="text" id="customer-name" class="input-modern" placeholder="الاسم الكريم" style="margin-bottom: 12px;">
                            <input type="tel" id="customer-phone" class="input-modern" placeholder="رقم الهاتف للتواصل (مثال: 90000000)">
                        </div>

                        <div id="custom-image-section" class="form-section">
                            <div class="section-label"><i class="fas fa-cloud-upload-alt"></i> إرفاق التصميم أو الشعار للطلب (اختياري)</div>
                            <div class="file-upload-wrapper">
                                <input type="file" id="custom-image-input" accept="image/*" class="file-upload-input">
                            </div>
                        </div>

                        <div class="form-section">
                            <div class="section-label"><i class="fas fa-layer-group"></i> اختيار القماش (يطبق على كل الطلب)</div>
                            <select id="fabric-select" class="input-modern" onchange="calculateLiveTotal()"></select>
                        </div>

                        <div class="form-section">
                            <div class="section-label"><i class="fas fa-pen-nib"></i> تفاصيل إضافية للطلب بالكامل</div>
                            <textarea id="order-notes" class="input-modern" rows="3" placeholder="اكتب الأسماء، الأرقام المطلوبة، أو حدد ملاحظات لكل موديل..."></textarea>
                        </div>

                        <div class="form-section" style="display: flex; gap: 10px;">
                            <input type="text" id="coupon-input" class="input-modern" placeholder="لديك كود خصم؟">
                            <button type="button" onclick="calculateLiveTotal(true)" style="background:var(--bg-surface-elevated); border:1px solid var(--gold); color:var(--gold); border-radius:var(--border-radius-md); padding:0 25px; font-weight:900; cursor:pointer; transition: 0.3s;">تطبيق</button>
                        </div>
                    </div>

                    <div id="step-2-confirmation" class="step-view">
                        <div class="delivery-mega-card">
                            <i class="fas fa-calendar-check delivery-mega-icon"></i>
                            <span class="delivery-mega-text">موعد تسليم طلبك التقريبي</span>
                            <span class="delivery-mega-date" id="expected-date-display">---</span>
                        </div>

                        <div class="summary-card">
                            <h4 style="color:var(--gold); margin-bottom:15px; border-bottom:1px solid var(--border-subtle); padding-bottom:10px;">مراجعة الطلب</h4>
                            <div class="summary-row">
                                <span style="color:var(--text-secondary);">إجمالي القطع:</span>
                                <span id="summary-total-qty" style="font-weight:bold;">0 قطعة</span>
                            </div>
                            <div class="summary-row total">
                                <span>الإجمالي النهائي:</span>
                                <span><span id="summary-total-price">0</span> ر.ع</span>
                            </div>
                        </div>

                        <div style="background: rgba(212,175,55,0.05); padding: 15px; border-radius: 12px; margin-bottom: 20px; font-size: 0.9rem; color: var(--text-secondary); text-align: center;">
                            <i class="fas fa-info-circle text-gold"></i> سيتم تحويل طلبك للإدارة، وسنقوم بالتواصل معك لتأكيد الدفع وبدء التفصيل.
                        </div>
                    </div>
                </div>

                <div class="modal-footer-sticky">
                    <div id="footer-step-1">
                        <div class="price-summary">
                            <div style="display:flex; flex-direction:column;">
                                <span style="color:var(--text-primary); font-weight:800; font-size:1.1rem;">الإجمالي:</span>
                                <span id="discount-display" class="hidden" style="color: #2ecc71; font-size: 0.85rem; font-weight: bold; margin-top: 3px;"></span>
                            </div>
                            <div>
                                <span class="price-summary-value" id="total-price-display">0</span>
                                <span style="font-size:1.2rem; font-weight:700; color:var(--gold); margin-right:5px;">ر.ع</span>
                            </div>
                        </div>
                        <button class="btn-wizard" onclick="goToStep2()">
                            مواصلة الدفع <i class="fas fa-arrow-left"></i>
                        </button>
                    </div>

                    <div id="footer-step-2" class="step-2-actions hidden">
                        <button class="btn-wizard" onclick="submitOrderProcess()" id="submit-btn">
                            تأكيد الدفع والطلب <i class="fas fa-credit-card"></i>
                        </button>
                        <button class="btn-wizard-outline" onclick="goToStep1()">
                            رجوع للتعديل <i class="fas fa-pen"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <a href="https://wa.me/96892111393?text=مرحباً، لدي استفسار بخصوص تفصيل الملابس الرياضية" target="_blank" class="whatsapp-float">
            <i class="fab fa-whatsapp"></i>
            <span>للاستفسار</span>
        </a>

        <!-- زر السلة العائم -->
        <div id="cart-float-btn" class="cart-float-btn" onclick="openCheckoutModal()">
            <i class="fas fa-shopping-cart"></i> السلة
            <span id="cart-badge-counter" class="cart-badge-counter">0</span>
        </div>

    </main>

    <script>
        const categoriesData = @Html.Raw(ViewBag.CategoriesJson ?? "[]");
        const sizesData = @Html.Raw(ViewBag.SizesJson ?? "[]");
        const fabricsData = @Html.Raw(ViewBag.FabricsJson ?? "[]");
        const promoBannerUrl = '@Html.Raw(ViewBag.PromoBannerUrl ?? "")';

        let allProducts = [];
        let globalCart = []; // السلة الشاملة
        let currentModalProduct = null;
        let currentSelectedSizeId = null;

        // متغيرات الكوبون
        let activeCouponCode = "";
        let appliedDiscountPercent = 0;
        let appliedFreePiece = false;

        window.onload = () => {
            initPromoBanner();

            categoriesData.forEach(cat => {
                if(cat.Products && cat.Products.length > 0) {
                    allProducts = allProducts.concat(cat.Products);
                }
            });

            renderCategoriesGrid();
            renderFabrics();
            toggleView('home');
            updateCartBadge();
        };

        function initPromoBanner() {
            const bannerContainer = document.getElementById('main-promo-banner');
            const bannerImg = document.getElementById('banner-img');
            if(promoBannerUrl && promoBannerUrl !== "") {
                bannerImg.src = "/" + promoBannerUrl;
                bannerContainer.style.display = "block";
            }
        }

        function renderFabrics() {
            const select = document.getElementById('fabric-select');
            if (!select) return;
            select.innerHTML = '<option value="0" data-name="بدون قماش إضافي">بدون إضافات (مشمول)</option>';
            fabricsData.forEach(f => {
                select.innerHTML += `<option value="${f.AdditionalPrice}" data-name="${f.Name}">${f.Name} (+${f.AdditionalPrice} ر.ع)</option>`;
            });
        }

        function toast(title, icon = 'success') {
            Swal.fire({ title: title, icon: icon, timer: 2500, showConfirmButton: false, toast: true, position: 'top', background: '#1a1a1a', color: '#ffffff', customClass: { popup: 'swal2-popup-custom' } });
        }

        function toggleView(screenId) {
            document.querySelectorAll('.app-screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId + '-screen').classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });

            if(screenId === 'categories') {
                document.getElementById('global-search-input').value = "";
                document.getElementById('categories-render').style.display = "grid";
                document.getElementById('global-products-list').style.display = "none";
                document.getElementById('global-no-search-results').style.display = "none";
            }
        }

        function renderCategoriesGrid() {
            const container = document.getElementById('categories-render');
            if (!container) return;
            container.innerHTML = "";
            categoriesData.forEach(cat => {
                container.innerHTML += `
                    <div class="category-card" onclick="loadCategory(${cat.Id})">
                        <div class="cat-icon-wrapper"><i class="fas ${cat.IconClass}"></i></div>
                        <div class="category-name">${cat.Name}</div>
                    </div>`;
            });
        }

        function filterGlobalProducts() {
            const searchText = document.getElementById('global-search-input').value.toLowerCase().trim();
            const categoriesGrid = document.getElementById('categories-render');
            const resultsList = document.getElementById('global-products-list');
            const noResults = document.getElementById('global-no-search-results');

            if (searchText === '') {
                categoriesGrid.style.display = 'grid';
                resultsList.style.display = 'none';
                noResults.style.display = 'none';
                return;
            }

            categoriesGrid.style.display = 'none';
            const filtered = allProducts.filter(p => p.Name.toLowerCase().includes(searchText));
            resultsList.innerHTML = "";

            if (filtered.length === 0) {
                resultsList.style.display = 'none';
                noResults.style.display = 'block';
            } else {
                resultsList.style.display = 'grid';
                noResults.style.display = 'none';
                filtered.forEach(item => {
                    resultsList.innerHTML += `
                        <div class="product-card product-item-card" onclick="openProductModal(${item.Id})">
                            <div class="product-img-container">
                                ${item.IsCustomDesign ? '<div class="badge-custom"><i class="fas fa-crown"></i> خاص</div>' : ''}
                                <img src="/${item.ImageUrl}" onerror="this.src='https://placehold.co/400x500/1e1e1e/D4AF37?text=Maestro'">
                            </div>
                            <div class="product-info">
                                <h3 class="product-title">${item.Name}</h3>
                                <div class="product-footer">
                                    <div class="price-container">
                                        <span class="product-price">${item.BasePrice} <small>ر.ع</small></span>
                                    </div>
                                    <div class="btn-order-action"><i class="fas fa-cart-plus"></i></div>
                                </div>
                            </div>
                        </div>`;
                });
            }
        }

        function loadCategory(catId) {
            const cat = categoriesData.find(c => c.Id === catId);
            if (!cat) return;

            document.getElementById('current-category-title').innerText = cat.Name;
            const list = document.getElementById('products-list');
            const noResults = document.getElementById('no-search-results');

            list.innerHTML = "";

            if (!cat.Products || cat.Products.length === 0) {
                list.style.display = 'none';
                noResults.style.display = 'block';
                noResults.innerHTML = `<i class="fas fa-boxes fa-4x" style="opacity:0.3; margin-bottom:20px; display:block; color:var(--gold);"></i><p style="font-size: 1.2rem; font-weight: bold;">تشكيلة جديدة قريباً!</p>`;
            } else {
                list.style.display = 'grid';
                noResults.style.display = 'none';
                cat.Products.forEach(item => {
                    list.innerHTML += `
                        <div class="product-card product-item-card" onclick="openProductModal(${item.Id})">
                            <div class="product-img-container">
                                ${item.IsCustomDesign ? '<div class="badge-custom"><i class="fas fa-crown"></i> خاص</div>' : ''}
                                <img src="/${item.ImageUrl}" onerror="this.src='https://placehold.co/400x500/1e1e1e/D4AF37?text=Maestro'">
                            </div>
                            <div class="product-info">
                                <h3 class="product-title">${item.Name}</h3>
                                <div class="product-footer">
                                    <div class="price-container">
                                        <span class="product-price">${item.BasePrice} <small>ر.ع</small></span>
                                    </div>
                                    <div class="btn-order-action"><i class="fas fa-cart-plus"></i></div>
                                </div>
                            </div>
                        </div>`;
                });
            }
            toggleView('shop');
        }

        function getExpectedDeliveryDate() {
            const date = new Date();
            date.setDate(date.getDate() + 2);
            const yyyy = date.getFullYear();
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            return `${yyyy}/${mm}/${dd}`;
        }

        // ==========================================
        // Modal & Cart Logic
        // ==========================================

        function openProductModal(productId) {
            currentModalProduct = allProducts.find(p => p.Id === productId);
            if (!currentModalProduct) return;

            document.getElementById('product-modal-name').innerText = currentModalProduct.Name;
            document.getElementById('custom-design-alert').classList.toggle('hidden', !currentModalProduct.IsCustomDesign);

            currentSelectedSizeId = null;
            document.getElementById('selected-qty').value = 1;
            renderSizeOptions();

            const overlay = document.getElementById('product-modal');
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            setTimeout(() => overlay.classList.add('show'), 10);
        }

        function closeProductModal() {
            const overlay = document.getElementById('product-modal');
            overlay.classList.remove('show');
            document.body.style.overflow = '';
            setTimeout(() => overlay.classList.add('hidden'), 400);
        }

        function renderSizeOptions() {
            const container = document.getElementById('size-options-grid');
            container.innerHTML = "";
            sizesData.forEach((s, idx) => {
                if(idx === 0) currentSelectedSizeId = s.Id;
                let extra = parseFloat(s.AdditionalPrice);
                let extraText = extra > 0 ? `+${extra}` : (extra < 0 ? `${extra}` : "");
                container.innerHTML += `
                    <div class="size-btn-modern ${idx === 0 ? 'active' : ''}" onclick="selectSizeBtn(${s.Id}, this)">
                        ${s.Name}
                        ${extraText ? `<span class="size-extra-price">${extraText}</span>` : ''}
                    </div>`;
            });
        }

        function selectSizeBtn(id, btnElement) {
            currentSelectedSizeId = id;
            document.querySelectorAll('.size-btn-modern').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');
        }

        function changeQty(delta) {
            let input = document.getElementById('selected-qty');
            let val = parseInt(input.value) + delta;
            input.value = val < 1 ? 1 : val;
        }

        function addSizeToCart() {
            if(!currentSelectedSizeId) { toast("يرجى اختيار المقاس", "warning"); return; }
            const qty = parseInt(document.getElementById('selected-qty').value);
            const sizeObj = sizesData.find(s => s.Id === currentSelectedSizeId);

            const existing = globalCart.find(i => i.ProductId === currentModalProduct.Id && i.SizeId === currentSelectedSizeId);

            if(existing) {
                existing.Quantity += qty;
            } else {
                globalCart.push({
                    ProductId: currentModalProduct.Id,
                    ProductName: currentModalProduct.Name,
                    ProductImage: currentModalProduct.ImageUrl,
                    BasePrice: currentModalProduct.BasePrice,
                    IsCustomDesign: currentModalProduct.IsCustomDesign,
                    CategoryId: currentModalProduct.CategoryId,
                    SizeId: sizeObj.Id,
                    SizeName: sizeObj.Name,
                    ExtraPrice: parseFloat(sizeObj.AdditionalPrice) || 0,
                    Quantity: qty
                });
            }

            updateCartBadge();
            closeProductModal();
            toast("تمت الإضافة للسلة بنجاح 🛒");
        }

        function updateCartBadge() {
            let count = globalCart.reduce((sum, item) => sum + item.Quantity, 0);
            document.getElementById('cart-badge-counter').innerText = count;

            const floatBtn = document.getElementById('cart-float-btn');
            if(count > 0) floatBtn.style.display = 'flex';
            else floatBtn.style.display = 'none';
        }

        function openCheckoutModal() {
            if(globalCart.length === 0) {
                toast("السلة فارغة", "warning");
                return;
            }

            // تهيئة شاشة الدفع
            document.getElementById('expected-date-display').innerText = getExpectedDeliveryDate();
            renderCartItems();
            calculateLiveTotal();
            goToStep1();

            const overlay = document.getElementById('order-modal');
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            setTimeout(() => overlay.classList.add('show'), 10);
        }

        function closeCheckoutModal() {
            const overlay = document.getElementById('order-modal');
            overlay.classList.remove('show');
            document.body.style.overflow = '';
            setTimeout(() => overlay.classList.add('hidden'), 400);
        }

        function renderCartItems() {
            const container = document.getElementById('global-cart-list');
            container.innerHTML = "";
            globalCart.forEach((item, index) => {
                container.innerHTML += `
                    <div class="cart-item-modern" style="background: rgba(255,255,255,0.02); border-radius: 10px; margin-bottom: 10px; border: 1px solid var(--accent);">
                        <img src="/${item.ProductImage}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; margin-left: 10px;" onerror="this.src='https://placehold.co/100/111/D4AF37?text=M'" />
                        <div style="flex-grow: 1;">
                            <h4 style="margin: 0; color: var(--gold); font-size: 1rem;">${item.ProductName}</h4>
                            <div style="display: flex; align-items: center; gap: 15px; margin-top: 5px;">
                                <span class="cart-item-size">${item.SizeName}</span>
                                <span style="color: var(--text-secondary); font-size: 0.95rem;">الكمية: <b style="color:#fff;">${item.Quantity}</b></span>
                            </div>
                        </div>
                        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 5px;">
                            <span style="color: #fff; font-weight: bold;">${(item.BasePrice + item.ExtraPrice) * item.Quantity} ر.ع</span>
                            <button type="button" class="btn-del-cart" onclick="removeSizeFromCart(${index})" style="width: 25px; height: 25px;"><i class="fas fa-trash-alt" style="font-size: 0.8rem;"></i></button>
                        </div>
                    </div>`;
            });
        }

        function removeSizeFromCart(index) {
            globalCart.splice(index, 1);
            updateCartBadge();
            if(globalCart.length === 0) {
                closeCheckoutModal();
            } else {
                renderCartItems();
                calculateLiveTotal();
            }
        }

        function calculateLiveTotal(isCouponClick = false) {
            let totalQty = 0; let totalPrice = 0;
            let hasCustomDesign = false;
            let firstProductBasePrice = globalCart.length > 0 ? globalCart[0].BasePrice : 0;
            let firstCategoryId = globalCart.length > 0 ? globalCart[0].CategoryId : null;

            const fabricSelect = document.getElementById('fabric-select');
            const fabricExtra = parseFloat(fabricSelect.value) || 0;
            const currentFabricName = fabricSelect.options[fabricSelect.selectedIndex]?.getAttribute('data-name') || "";

            globalCart.forEach(item => {
                totalQty += item.Quantity;
                totalPrice += item.Quantity * (item.BasePrice + item.ExtraPrice + fabricExtra);
                if (item.IsCustomDesign) hasCustomDesign = true;
            });

            if (hasCustomDesign && totalQty > 0 && totalQty <= 10) totalPrice += (2 * totalQty);

            if (isCouponClick) {
                const code = document.getElementById('coupon-input').value.trim().toUpperCase();
                if (!code) { toast('يرجى إدخال الكود أولاً', 'warning'); return; }

                const url = `/Home/ValidateCoupon?code=${encodeURIComponent(code)}&totalQty=${totalQty}&categoryId=${firstCategoryId || ''}&fabricName=${encodeURIComponent(currentFabricName)}`;

                fetch(url)
                    .then(res => res.json())
                    .then(data => {
                        if (data.valid) {
                            if(data.isFreePiece) {
                                appliedFreePiece = true;
                                appliedDiscountPercent = 0;
                                activeCouponCode = code;
                                toast(`تم تفعيل الكوبون: ستحصل على قطعة مجانية! 🎁`);
                            } else {
                                appliedFreePiece = false;
                                appliedDiscountPercent = data.discountPercentage;
                                activeCouponCode = code;
                                toast(`تم تفعيل الخصم: ${data.discountPercentage}%`);
                            }
                        }
                        else {
                            appliedDiscountPercent = 0;
                            appliedFreePiece = false;
                            activeCouponCode = "";
                            document.getElementById('coupon-input').value = "";
                            toast(data.message || 'الكود غير صحيح', 'error');
                        }
                        updateDisplay();
                    }).catch(() => toast('خطأ في الاتصال بالسيرفر', 'error'));
            } else { updateDisplay(); }

            function updateDisplay() {
                let discountAmount = 0;
                if (appliedFreePiece && totalQty > 0) {
                    discountAmount = firstProductBasePrice + fabricExtra;
                } else {
                    discountAmount = totalPrice * (appliedDiscountPercent / 100);
                }

                let final = Math.max(0, totalPrice - discountAmount);
                document.getElementById('total-price-display').innerText = final.toFixed(2);
                document.getElementById('summary-total-price').innerText = final.toFixed(2);
                document.getElementById('summary-total-qty').innerText = `${totalQty} قطعة`;

                const discDisplay = document.getElementById('discount-display');
                if (discountAmount > 0 && totalQty > 0) {
                    discDisplay.innerText = `(وفرت ${discountAmount.toFixed(2)} ر.ع)`;
                    discDisplay.classList.remove('hidden');
                } else { discDisplay.classList.add('hidden'); }
            }

            let finalDiscountAmount = appliedFreePiece ? (firstProductBasePrice + fabricExtra) : (totalPrice * (appliedDiscountPercent / 100));
            return { totalQty, totalPrice: Math.max(0, totalPrice - finalDiscountAmount) };
        }

        function goToStep2() {
            const customerName = document.getElementById('customer-name').value.trim();
            const customerPhone = document.getElementById('customer-phone').value.trim();

            if(!customerName || !customerPhone) {
                Swal.fire({title: 'بيانات ناقصة', text: 'يرجى إدخال اسمك ورقم هاتفك لنتواصل معك.', icon: 'warning', background: '#1a1a1a', color: '#fff'});
                return;
            }

            document.getElementById('step-1-details').classList.remove('active');
            document.getElementById('step-2-confirmation').classList.add('active');

            document.getElementById('footer-step-1').classList.add('hidden');
            document.getElementById('footer-step-2').classList.remove('hidden');

            document.querySelector('.modal-content').scrollTo({ top: 0, behavior: 'smooth' });
        }

        function goToStep1() {
            document.getElementById('step-2-confirmation').classList.remove('active');
            document.getElementById('step-1-details').classList.add('active');

            document.getElementById('footer-step-2').classList.add('hidden');
            document.getElementById('footer-step-1').classList.remove('hidden');
        }

        function submitOrderProcess() {
            const btn = document.getElementById('submit-btn');
            btn.disabled = true; btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> جاري إرسال الطلب...';

            const fabricSelect = document.getElementById('fabric-select');
            const formData = new FormData();
            formData.append('CustomerName', document.getElementById('customer-name').value.trim());
            formData.append('PhoneNumber', document.getElementById('customer-phone').value.trim());
            formData.append('Notes', document.getElementById('order-notes').value || "");
            formData.append('FabricType', fabricSelect.options[fabricSelect.selectedIndex]?.getAttribute('data-name') || "قياسي");
            formData.append('FabricExtraPrice', parseFloat(fabricSelect.value) || 0);
            formData.append('CouponCode', activeCouponCode);

            // تجميع السلة لتتوافق مع الـ Backend
            let groupedCart = [];
            globalCart.forEach(item => {
                let existingProduct = groupedCart.find(p => p.ProductId === item.ProductId);
                if(existingProduct) {
                    existingProduct.Sizes.push({ SizeId: item.SizeId, Quantity: item.Quantity });
                } else {
                    groupedCart.push({
                        ProductId: item.ProductId,
                        Sizes: [{ SizeId: item.SizeId, Quantity: item.Quantity }]
                    });
                }
            });

            formData.append('CartJson', JSON.stringify(groupedCart));

            const imageInput = document.getElementById('custom-image-input');
            if(imageInput && imageInput.files.length > 0) formData.append('CustomImage', imageInput.files[0]);

            fetch('/Home/SubmitOrder', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    globalCart = [];
                    updateCartBadge();
                    closeCheckoutModal();

                    let giftHtml = "";
                    if (data.giftCode) {
                        giftHtml = `
                            <div style="margin-top: 20px; padding: 15px; background: rgba(46, 204, 113, 0.1); border: 1px dashed #2ecc71; border-radius: 16px;">
                                <h4 style="color: #2ecc71; margin-bottom: 5px; font-weight: 900;"><i class="fas fa-gift"></i> مبروك! كسبت قطعة مجانية</h4>
                                <p style="font-size: 0.9rem; color: #fff;">بما أن طلبك 10 قطع فأكثر، استخدم هذا الكود في طلبك القادم للحصول على قطعة مجانية تماماً:</p>
                                <div style="font-size: 2rem; font-weight: 900; letter-spacing: 3px; color: var(--gold); background: #000; padding: 10px; border-radius: 10px; margin-top: 10px;">${data.giftCode}</div>
                                <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 10px; margin-bottom: 0;">(احتفظ بالكود، صالح للاستخدام مرة واحدة فقط)</p>
                            </div>
                        `;
                    }

                    Swal.fire({
                        title: 'تم تأكيد طلبك بنجاح!',
                        html: `<div style="text-align:right; margin-top:20px; line-height: 1.8;">
                                <div style="background:var(--bg-surface-elevated); border:1px dashed var(--gold); border-radius:16px; padding:20px; text-align:center; margin-bottom: 15px;">
                                    <p style="font-size:0.95rem; color:var(--text-secondary); margin-bottom:5px;">رقم الطلب المرجعي</p>
                                    <p style="font-size:2.8rem; font-weight:900; color:var(--gold); margin:0; letter-spacing: 2px; text-shadow: 0 0 10px rgba(212,175,55,0.3);">#${data.orderId}</p>
                                </div>
                                ${giftHtml}
                                <div style="padding: 0 10px; font-size: 1.1rem; margin-top: 20px;">
                                    <p>الاسم: <strong style="color:#fff;">${document.getElementById('customer-name').value.trim()}</strong></p>
                                    <p>موعد التسليم المتوقع: <strong style="color:#2ecc71;">${data.deliveryDate}</strong></p>
                                </div>
                                <p style="font-size:0.9rem; color:var(--text-secondary); margin-top:20px; text-align:center; padding-top: 15px; border-top: 1px solid var(--border-subtle);">
                                    سيتواصل معك فريق المايسترو قريباً لتأكيد الدفع والبدء بالتنفيذ.
                                </p>
                               </div>`,
                        icon: 'success', confirmButtonText: 'حسناً، شكراً لكم',
                        background: '#0a0a0a', color: '#fff',
                        customClass: { confirmButton: 'btn-checkout' }
                    });
                } else {
                    Swal.fire({title: 'خطأ في الإرسال', text: data.message, icon: 'error', background: '#1a1a1a', color: '#fff'});
                    btn.disabled = false; btn.innerHTML = 'تأكيد الدفع والطلب <i class="fas fa-credit-card"></i>';
                }
            })
            .catch(() => {
                Swal.fire({title: 'خطأ في الاتصال', text: 'يرجى التحقق من اتصالك بالإنترنت والمحاولة مجدداً.', icon: 'error', background: '#1a1a1a', color: '#fff'});
                btn.disabled = false; btn.innerHTML = 'تأكيد الدفع والطلب <i class="fas fa-credit-card"></i>';
            });
        }
    </script>
</body>
</html>