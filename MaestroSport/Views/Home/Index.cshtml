@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المايسترو للرياضة | المتجر المتكامل</title>
    <!-- المكتبات الخارجية -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --gold: #D4AF37;
            --black: #080808;
            --royal-blue: #002366;
            --royal-green: #004225;
            --dark-grey: #151515;
            --white: #ffffff;
        }

        /* --- Professional Scrollbar Style --- */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--black);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, var(--gold), #b5952f);
            border-radius: 10px;
            border: 2px solid var(--black);
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #f3d56a;
            }

        .hidden {
            display: none !important;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Cairo', sans-serif;
            background-color: var(--black);
            color: var(--white);
            direction: rtl;
        }

        /* --- Style Guard: منع النصوص الرمادية والشفافة --- */
        p, span, label, small, h1, h2, h3, h4, h5, h6, td, th, li, .swal2-html-container {
            color: var(--white) !important;
            opacity: 1 !important;
        }

        .text-gold, .product-price, #total-price-display, th, .cat-icon i, .swal2-title {
            color: var(--gold) !important;
        }

        /* السماح بألوان الأيقونات من قاعدة البيانات وعدم إجبارها على الذهبي */
        .cat-icon.blue i {
            color: #3498db !important;
        }

        .cat-icon.green i {
            color: #2ecc71 !important;
        }

        .cat-icon.gold i {
            color: var(--gold) !important;
        }

        .cat-icon.red i {
            color: #e74c3c !important;
        }

        .cat-icon.purple i {
            color: #9b59b6 !important;
        }

        .cat-icon.orange i {
            color: #e67e22 !important;
        }

        .cat-icon.cyan i {
            color: #1abc9c !important;
        }

        .cat-icon.pink i {
            color: #fd79a8 !important;
        }

        /* --- Header --- */
        header {
            background: linear-gradient(to bottom, #1a1a1a, var(--black));
            padding: 30px;
            text-align: center;
            border-bottom: 2px solid var(--gold);
        }

        .logo-area {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .main-logo {
            width: 110px;
            height: auto;
            filter: drop-shadow(0 0 10px rgba(212, 175, 55, 0.4));
        }

        .text-group h1 {
            color: var(--gold) !important;
            font-weight: 900;
            font-size: 2.5rem;
            margin: 0;
        }

        /* --- Announcement Bar --- */
        .shipping-bar {
            background: var(--royal-blue);
            color: var(--gold) !important;
            padding: 10px 0;
            border-bottom: 1px solid var(--gold);
            font-weight: bold;
            font-size: 1.1rem;
        }

            .shipping-bar marquee {
                color: var(--gold) !important;
            }

        /* --- Screens --- */
        .active-screen {
            display: block;
            animation: fadeIn 0.5s ease;
        }
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
        }

        to {
            opacity: 1;
        }

        }

        /* --- Hero Gate --- */
        .hero-gate {
            margin: 50px auto;
            width: 90%;
            max-width: 450px;
            background: var(--royal-green);
            border: 3px solid var(--gold);
            border-radius: 25px;
            padding: 60px 20px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        }

            .hero-gate:hover {
                transform: scale(1.03);
                background: #005631;
            }

            .hero-gate i {
                font-size: 5rem;
                color: var(--gold) !important;
                margin-bottom: 20px;
            }

            .hero-gate h2 {
                font-weight: 900;
                font-size: 1.8rem;
            }

        .container {
            padding: 20px;
            max-width: 1100px;
            margin: auto;
        }

        .section-title {
            color: var(--gold) !important;
            text-align: center;
            margin-bottom: 40px;
            border-right: 5px solid var(--gold);
            padding-right: 20px;
            font-size: 2rem;
            font-weight: 800;
        }

        /* --- Grid Systems --- */
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 25px;
        }

        .category-card {
            background: var(--dark-grey);
            padding: 30px 20px;
            border-radius: 20px;
            text-align: center;
            cursor: pointer;
            border: 1px solid #333;
            transition: 0.3s;
        }

            .category-card:hover {
                border-color: var(--gold);
                transform: translateY(-8px);
                box-shadow: 0 10px 20px rgba(212, 175, 55, 0.1);
            }

        .cat-icon {
            font-size: 2.8rem;
            margin-bottom: 15px;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }

        .product-item {
            background: #111;
            border-radius: 25px;
            overflow: hidden;
            border: 1px solid #222;
            transition: 0.4s;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
        }

        .product-img {
            width: 100%;
            height: 280px;
            background: #1a1a1a;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .product-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .product-info {
            padding: 25px;
            background: linear-gradient(to top, #000, #111);
            text-align: center;
        }

            .product-info h3 {
                font-size: 1.4rem;
                margin-bottom: 12px;
            }

        .btn-order {
            background: #25D366;
            color: white !important;
            padding: 15px;
            border-radius: 15px;
            font-weight: bold;
            cursor: pointer;
            border: none;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            font-size: 1.1rem;
        }

        /* --- Modal & Forms --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 5000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #151515;
            border: 2px solid var(--gold);
            border-radius: 25px;
            width: 95%;
            max-width: 550px;
            padding: 35px;
            position: relative;
            max-height: 85vh;
            overflow-y: auto;
        }

        .close-modal {
            position: absolute;
            top: 20px;
            left: 20px;
            font-size: 35px;
            color: var(--gold) !important;
            cursor: pointer;
        }

        .form-section {
            margin-bottom: 25px;
            text-align: right;
        }

            .form-section label {
                display: block;
                margin-bottom: 12px;
                color: var(--gold) !important;
                font-weight: bold;
                font-size: 1.1rem;
            }

        textarea, select, .coupon-row input {
            width: 100%;
            padding: 14px;
            background: #000 !important;
            border: 1px solid var(--gold) !important;
            color: var(--white) !important;
            border-radius: 10px;
            font-family: inherit;
            font-size: 1.1rem;
        }

        .coupon-row {
            display: flex;
            gap: 10px;
        }

            .coupon-row button {
                background: var(--gold);
                border: none;
                padding: 0 25px;
                border-radius: 10px;
                font-weight: bold;
                cursor: pointer;
                color: #000 !important;
            }

        .order-summary {
            background: #000;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 25px;
            border: 1px dashed var(--gold);
            text-align: right;
        }

        .summary-item.total {
            font-size: 1.6rem;
            color: var(--gold) !important;
            font-weight: 900;
        }

        .whatsapp-confirm-btn {
            background: #25D366;
            color: white !important;
            width: 100%;
            padding: 18px;
            border: none;
            border-radius: 15px;
            font-size: 1.3rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(37, 211, 102, 0.3);
        }

        /* --- WhatsApp Float --- */
        .whatsapp-float {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background: #25D366;
            color: #fff !important;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 35px;
            z-index: 1000;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

        .back-btn-small {
            background: var(--gold);
            color: #000 !important;
            border: none;
            padding: 12px 25px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 800;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* --- SweetAlert Custom Design & Z-Index Fix --- */
        .swal2-container {
            z-index: 10000 !important; /* التأكد أن التنبيه يظهر فوق الفورم دائماً */
        }

        .swal2-popup {
            background: #151515 !important;
            border: 1px solid var(--gold) !important;
            border-radius: 20px !important;
            color: #ffffff !important;
        }

        .swal2-title, .swal2-html-container {
            color: #ffffff !important;
        }

        .swal2-confirm {
            background: var(--gold) !important;
            color: #000 !important;
            font-weight: 900 !important;
            border-radius: 10px !important;
        }

        .swal2-cancel {
            background: #333 !important;
            color: #fff !important;
            border-radius: 10px !important;
        }

        /* --- Table Styling --- */
        .sizes-table {
            width: 100%;
            margin-bottom: 20px;
            border-collapse: collapse;
        }

            .sizes-table th, .sizes-table td {
                padding: 12px;
                border-bottom: 1px solid #333;
                text-align: right;
            }

        .qty-input {
            width: 75px;
            background: #000 !important;
            color: var(--gold) !important;
            border: 1px solid var(--gold) !important;
            border-radius: 8px;
            text-align: center;
            padding: 8px;
            font-weight: bold;
        }

        .design-fee-notice {
            background: rgba(212, 175, 55, 0.1);
            border-right: 5px solid var(--gold);
            padding: 15px;
            margin-bottom: 20px;
            font-size: 1rem;
            border-radius: 8px;
            line-height: 1.5;
        }

        footer {
            text-align: center;
            padding: 50px 20px;
            margin-top: 60px;
            background: #000;
            border-top: 1px solid #222;
        }

        .features-section {
            display: flex;
            justify-content: center;
            gap: 60px;
            padding: 40px 20px;
            background: #111;
            margin: 50px auto;
            max-width: 900px;
            border-radius: 20px;
            flex-wrap: wrap;
        }

        .feature-item {
            text-align: center;
            flex: 1;
            min-width: 200px;
        }

            .feature-item i {
                color: var(--gold);
                font-size: 2.5rem;
                margin-bottom: 15px;
            }

            .feature-item h4 {
                color: var(--gold);
                margin: 10px 0;
                font-size: 1.3rem;
            }

        .social-section {
            padding: 20px;
            text-align: center;
        }

        .insta-btn-premium {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            background: linear-gradient(45deg, #f09433 0%, #bc1888 100%);
            color: white !important;
            padding: 15px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

            .insta-btn-premium:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(188, 24, 136, 0.4);
            }
    </style>
</head>
<body>

    <a href="https://wa.me/96892111393" class="whatsapp-float" target="_blank"><i class="fab fa-whatsapp"></i></a>

    <header>
        <div class="logo-area">
            <img src="~/images/logo.png" alt="المايسترو" class="main-logo" onerror="this.src='https://placehold.co/120/111/D4AF37?text=M'">
            <div class="text-group">
                <h1>المايسترو للرياضة</h1>
                <p><i class="fas fa-map-marker-alt" style="color:var(--gold) !important;"></i> سلطنة عمان - جعلان بني بوعلي</p>
            </div>
        </div>
    </header>

    <main>
        <div class="shipping-bar">
            <marquee style="text-align:center" behavior="scroll" direction="right" scrollamount="6">@ViewBag.AnnouncementBar</marquee>
        </div>

        <!-- البوابة الرئيسية -->
        <section id="home-screen" class="active-screen">
            <div class="hero-gate" onclick="toggleView('categories')">
                <i class="fas fa-cut"></i>
                <h2>تفصيل وخياطة الملابس الرياضية</h2>
                <p>انقر هنا لاستعراض الموديلات والأقسام وبدء الطلب</p>
            </div>
        </section>

        <!-- شاشة الأقسام -->
        <section id="categories-screen" class="hidden">
            <div class="container">
                <h2 class="section-title">اختر القسم المطلوب</h2>
                <div class="categories-grid" id="categories-render"></div>
                <div style="text-align:center; margin-top:40px;">
                    <button class="back-btn-small" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> العودة للرئيسية</button>
                </div>
            </div>
        </section>

        <!-- شاشة الموديلات -->
        <section id="shop-screen" class="hidden">
            <div class="container">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; border-bottom:1px solid #333; padding-bottom:15px;">
                    <h2 id="cat-display-name" style="margin:0; border:none;" class="section-title">موديلات</h2>
                    <button class="back-btn-small" onclick="toggleView('categories')"><i class="fas fa-arrow-right"></i> رجوع</button>
                </div>
                <div id="products-list" class="products-grid"></div>
            </div>
        </section>

        <!-- نافذة الطلب -->
        <div id="order-modal" class="modal-overlay hidden">
            <div class="modal-content">
                <span class="close-modal" onclick="closeModal()">&times;</span>
                <h2 id="modal-item-name" style="color:var(--gold)!important;">تفاصيل التفصيل</h2>

                <div id="custom-design-alert" class="design-fee-notice hidden">
                    <i class="fas fa-gem"></i> هذا الموديل (تصميم خاص) يضاف <strong>2 ريال</strong> لرسوم التصميم للقطعة الواحد.<br>
                    <span style="color:#2ecc71!important; font-size:0.9rem;">(رسوم التصميم مجانية إذا كان الطلب 11 قطعة فأكثر)</span>
                </div>

                <div class="order-form-body">
                    <div class="form-section">
                        <label><i class="fas fa-ruler-combined"></i> القياسات والكميات:</label>
                        <div style="max-height: 250px; overflow-y: auto; border: 1px solid #333; border-radius: 15px;">
                            <table class="sizes-table" id="sizes-table-body" style="margin:0;"></table>
                        </div>
                    </div>

                    <div class="form-section">
                        <label><i class="fas fa-scroll"></i> نوع القماش:</label>
                        <select id="fabric-select" onchange="calculateLiveTotal()">
                            <option value="0" data-name="قماش رياضي قياسي">قماش رياضي قياسي (مشمول)</option>
                            <option value="3" data-name="قماش ديواني ملكي">قماش ديواني ملكي (+3 ريال)</option>
                            <option value="5" data-name="قماش نخب أول أصلي">قماش نخب أول أصلي (+5 ريال)</option>
                            <option value="2" data-name="قماش تبريد مسامي">قماش تبريد مسامي (+2 ريال)</option>
                        </select>
                    </div>

                    <div class="form-section">
                        <label><i class="fas fa-pen"></i> ملاحظات خاصة (الأسماء، الأرقام):</label>
                        <textarea id="order-notes" rows="2" placeholder="اكتب ملاحظاتك، قياساتك، أو أي طلب خاص هنا..."></textarea>
                    </div>

                    <div class="form-section coupon-row">
                        <input type="text" id="coupon-input" placeholder="كود الخصم">
                        <button type="button" id="apply-coupon-btn" onclick="applyCouponLogic()">تطبيق</button>
                    </div>

                    <div class="order-summary">
                        <div class="summary-item total">الإجمالي التقريبي: <span id="total-price-display">0</span> ريال</div>
                        <small style="font-size:0.85rem;">* السعر النهائي وموعد الاستلام يتحدد بعد الحفظ</small>
                    </div>

                    <button class="whatsapp-confirm-btn" onclick="submitOrderProcess()" id="submit-btn">
                        <i class="fab fa-whatsapp"></i> اعتماد الطلب وإرسال للواتساب
                    </button>
                </div>
            </div>
        </div>
        <section class="features-section">
            <div class="feature-item"><i class="fas fa-award text-gold"></i><h4>جودة ملكية</h4><p>نستخدم أفضل الخامات العالمية</p></div>
            <div class="feature-item"><i class="fas fa-bolt text-gold"></i><h4>سرعة التنفيذ</h4><p>دقة ومواعيد تسليم منضبطة</p></div>
        </section>

        <section class="social-section">
            <a href="https://www.instagram.com/almystro_sport" target="_blank" class="insta-btn-premium">
                <i class="fab fa-instagram"></i> <span>تابعونا على انستجرام للجديد</span>
            </a>
        </section>
    </main>

    <footer>
        <p>© 2024 المايسترو للرياضة - جعلان بني بوعلي | خيارك الأول للأناقة الرياضية</p>
    </footer>

    <script>
        const categoriesData = @Html.Raw(ViewBag.CategoriesJson ?? "[]");
        const sizesData = @Html.Raw(ViewBag.SizesJson ?? "[]");

        let currentProduct = null;
        let appliedDiscount = 0;
        let activeCouponCode = "";

        function renderCategories() {
            const container = document.getElementById('categories-render');
            if(!container) return;
            container.innerHTML = "";
            categoriesData.forEach(cat => {
                container.innerHTML += `
                    <div class="category-card" onclick="loadCategory(${cat.Id})">
                        <div class="cat-icon ${cat.ColorClass}"><i class="fas ${cat.IconClass}"></i></div>
                        <span style="font-weight:bold; font-size:1.2rem;">تفصيل ${cat.Name}</span>
                    </div>`;
            });
        }

        function toggleView(screenId) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            const target = document.getElementById(screenId + '-screen');
            if(target) target.classList.remove('hidden');
            if(screenId === 'categories') renderCategories();
            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        function loadCategory(catId) {
            const cat = categoriesData.find(c => c.Id === catId);
            if (!cat) return;
            document.getElementById('cat-display-name').innerText = "قسم " + cat.Name;
            const list = document.getElementById('products-list');
            list.innerHTML = cat.Products.length === 0 ? "<p style='grid-column:1/-1; text-align:center; font-size:1.2rem;'>لا توجد موديلات مضافة في هذا القسم حالياً.</p>" : "";
            cat.Products.forEach(item => {
                list.innerHTML += `
                    <div class="product-item">
                        <div class="product-img"><img src="/${item.ImageUrl}" onerror="this.src='https://placehold.co/400x500/111/D4AF37?text=No+Image'"></div>
                        <div class="product-info">
                            <h3>${item.Name} ${item.IsCustomDesign ? '<br><small style="color:var(--gold)!important; font-size:0.8rem;">(تصميم خاص)</small>' : ''}</h3>
                            <p class="product-price" style="font-size:1.5rem; font-weight:900;">${item.BasePrice} ريال</p>
                            <button class="btn-order" onclick="openOrderModal(${item.Id})"><i class="fas fa-magic"></i> اطلب تفصيل الآن</button>
                        </div>
                    </div>`;
            });
            toggleView('shop');
        }

        function openOrderModal(productId) {
            currentProduct = null;
            categoriesData.forEach(c => {
                const found = c.Products.find(p => p.Id === productId);
                if(found) currentProduct = found;
            });
            if (!currentProduct) return;

            document.getElementById('modal-item-name').innerText = "طلب تفصيل: " + currentProduct.Name;
            document.getElementById('custom-design-alert').classList.toggle('hidden', !currentProduct.IsCustomDesign);

            const tbody = document.getElementById('sizes-table-body');
            tbody.innerHTML = `<tr><th>المقاس</th><th style="text-align:center;">إضافي</th><th style="text-align:center;">الكمية</th></tr>`;
            sizesData.forEach(s => {
                tbody.innerHTML += `
                    <tr>
                        <td>${s.Name} <br><small style="opacity:0.8; font-size:0.75rem;">(${s.GroupName})</small></td>
                        <td style="color:var(--gold)!important; text-align:center;">${s.AdditionalPrice > 0 ? '+'+s.AdditionalPrice : (s.AdditionalPrice < 0 ? s.AdditionalPrice : 'مجاني')}</td>
                        <td style="text-align:center;"><input type="number" min="0" value="0" class="qty-input" data-size-id="${s.Id}" data-extra="${s.AdditionalPrice}" onchange="calculateLiveTotal()" onkeyup="calculateLiveTotal()"></td>
                    </tr>`;
            });

            appliedDiscount = 0;
            activeCouponCode = "";
            document.getElementById('coupon-input').value = "";
            document.getElementById('order-notes').value = "";
            calculateLiveTotal();
            document.getElementById('order-modal').classList.remove('hidden');
        }

        function calculateLiveTotal() {
            if(!currentProduct) return;
            let totalQty = 0;
            let totalPrice = 0;
            const fabricSelect = document.getElementById('fabric-select');
            const fabricExtra = fabricSelect ? parseFloat(fabricSelect.value) : 0;

            document.querySelectorAll('.qty-input').forEach(input => {
                const qty = parseInt(input.value) || 0;
                const extra = parseFloat(input.getAttribute('data-extra'));
                if (qty > 0) {
                    totalQty += qty;
                    totalPrice += qty * (currentProduct.BasePrice + extra + fabricExtra);
                }
            });

            if (currentProduct.IsCustomDesign && totalQty > 0 && totalQty <= 10) {
                totalPrice += (2 * totalQty);
            }

            let finalPrice = totalPrice - appliedDiscount;
            document.getElementById('total-price-display').innerText = Math.max(0, finalPrice).toFixed(2);
            return { totalQty, finalPrice };
        }

        function applyCouponLogic() {
            const codeInput = document.getElementById('coupon-input');
            const code = codeInput.value.trim().toUpperCase();
            if(!code) return;

            const btn = document.getElementById('apply-coupon-btn');
            btn.disabled = true;
            btn.innerText = "...";

            fetch(`/Home/ValidateCoupon?code=${encodeURIComponent(code)}`)
                .then(res => res.json())
                .then(data => {
                    if(data.valid) {
                        appliedDiscount = data.discount;
                        activeCouponCode = code;
                        Swal.fire({ title: 'تم تفعيل الخصم!', text: `مبروك، حصلت على خصم بقيمة ${data.discount} ريال`, icon: 'success' });
                    } else {
                        appliedDiscount = 0;
                        activeCouponCode = "";
                        Swal.fire({ title: 'عفواً!', text: 'كود الخصم غير صحيح أو منتهي الصلاحية', icon: 'error' });
                    }
                    calculateLiveTotal();
                })
                .catch(() => Swal.fire('خطأ', 'فشل الاتصال بالخادم للتحقق من الكوبون', 'error'))
                .finally(() => { btn.disabled = false; btn.innerText = "تطبيق"; });
        }

        async function submitOrderProcess() {
            try {
                const { totalQty, finalPrice } = calculateLiveTotal();
                if (totalQty === 0) {
                    Swal.fire({ title: 'تنبيه', text: 'يرجى اختيار كمية واحدة على الأقل للمتابعة', icon: 'warning' });
                    return;
                }

                // التنبيه سيظهر الآن فوق الفورم بفضل z-index: 10000
                const result = await Swal.fire({
                    title: 'تأكيد الطلب الملكي',
                    text: `هل تود إرسال طلب لعدد ${totalQty} قطعة؟`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'نعم، أرسل الطلب',
                    cancelButtonText: 'إلغاء'
                });

                if (result.isConfirmed) {
                    const btn = document.getElementById('submit-btn');
                    const originalText = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';

                    const items = [];
                    document.querySelectorAll('.qty-input').forEach(input => {
                        const qty = parseInt(input.value) || 0;
                        if(qty > 0) {
                            items.push({
                                SizeId: parseInt(input.getAttribute('data-size-id')),
                                Quantity: qty
                            });
                        }
                    });

                    const fabricEl = document.getElementById('fabric-select');
                    const fabricName = fabricEl.options[fabricEl.selectedIndex].getAttribute('data-name');

                    const payload = {
                        ProductId: currentProduct.Id,
                        Notes: document.getElementById('order-notes').value || "",
                        FabricType: fabricName,
                        FabricExtraPrice: parseFloat(fabricEl.value),
                        CouponCode: activeCouponCode,
                        Items: items
                    };

                    const response = await fetch('/Home/SubmitOrder', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) throw new Error('فشل الاتصال بالسيرفر');

                    const data = await response.json();

                    if(data.success) {
                        await Swal.fire({
                            title: 'تم الحفظ بنجاح!',
                            text: 'جاري تحويلك للواتساب لإتمام عملية الدفع...',
                            icon: 'success',
                            timer: 2500,
                            showConfirmButton: false
                        });

                        const msg = `*طلب تفصيل جديد من متجر المايسترو رقم ${data.orderId}*%0A---------------------------%0A*الموديل:* ${currentProduct.Name}%0A*نوع القماش:* ${fabricName}%0A*إجمالي القطع:* ${totalQty}%0A*موعد الاستلام المتوقع:* ${data.deliveryDate}%0A*الإجمالي النهائي:* ${data.totalPrice} ريال%0A---------------------------%0A*ملاحظات:* ${payload.Notes || 'لا توجد'}`;
                        window.location.href = `https://wa.me/96892111393?text=${msg}`;
                        closeModal();
                    } else {
                        Swal.fire('خطأ', data.message || 'حدثت مشكلة أثناء حفظ الطلب', 'error');
                    }
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            } catch (err) {
                console.error(err);
                Swal.fire('خطأ تقني', 'حدث خطأ غير متوقع، يرجى المحاولة لاحقاً أو التأكد من اتصال الانترنت.', 'error');
                const btn = document.getElementById('submit-btn');
                if(btn) { btn.disabled = false; btn.innerHTML = '<i class="fab fa-whatsapp"></i> اعتماد الطلب وإرسال للواتساب'; }
            }
        }

        function closeModal() { document.getElementById('order-modal').classList.add('hidden'); }
    </script>
</body>
</html>