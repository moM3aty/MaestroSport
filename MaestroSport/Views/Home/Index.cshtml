@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المايسترو للرياضة | المتجر المتكامل</title>
    <!-- المكتبات الخارجية -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="~/images/logo.png" rel="icon" type="image/x-icon" />

    <style>
        :root {
            --gold: #D4AF37;
            --black: #080808;
            --royal-blue: #002366;
            --royal-green: #004225;
            --dark-grey: #151515;
            --white: #ffffff;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--black);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, var(--gold), #b5952f);
            border-radius: 10px;
            border: 2px solid var(--black);
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #f3d56a;
            }

        .hidden { display: none !important; }
        * { box-sizing: border-box; }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Cairo', sans-serif;
            background-color: var(--black);
            color: var(--white);
            direction: rtl;
        }

        /* --- Style Guard --- */
        p, span, label, small, h1, h2, h3, h4, h5, h6, td, th, li {
            color: var(--white) !important;
            opacity: 1 !important;
        }
        a{
            text-decoration:none;
        }
        .text-gold, .product-price, #total-price-display, th { color: var(--gold) !important; }

        /* --- Header --- */
        header { background: linear-gradient(to bottom, #1a1a1a, var(--black)); padding: 30px; text-align: center; border-bottom: 2px solid var(--gold); }
        .logo-area { display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; }
        .main-logo { width: 110px; height: auto; filter: drop-shadow(0 0 10px rgba(212, 175, 55, 0.4)); }
        .text-group h1 { color: var(--gold) !important; font-weight: 900; font-size: 2.5rem; margin: 0; }

        /* --- Announcement Bar --- */
        .shipping-bar { background: var(--royal-blue); color: var(--gold) !important; padding: 10px 0; border-bottom: 1px solid var(--gold); font-weight: bold; font-size: 1.1rem; }
        .shipping-bar marquee { color: var(--gold) !important; }

        /* --- Screens --- */
        .active-screen { display: block; animation: fadeIn 0.5s ease; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* --- Hero Gate --- */
        .hero-gate { margin: 50px auto; width: 90%; max-width: 450px; background: var(--royal-green); border: 3px solid var(--gold); border-radius: 25px; padding: 60px 20px; text-align: center; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6); }
        .hero-gate:hover { transform: scale(1.03); background: #005631; }
        .hero-gate i { font-size: 5rem; color: var(--gold) !important; margin-bottom: 20px; }
        .hero-gate h2 { font-weight: 900; font-size: 1.8rem; }

        .container { padding: 20px; max-width: 1100px; margin: auto; }
        .section-title { color: var(--gold) !important; text-align: center; margin-bottom: 40px; border-right: 5px solid var(--gold); padding-right: 20px; font-size: 2rem; font-weight: 800; }

        /* --- Grid Systems & Colors --- */
        .categories-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 25px; }
        .category-card { background: var(--dark-grey); padding: 30px 20px; border-radius: 20px; text-align: center; cursor: pointer; border: 1px solid #333; transition: 0.3s; }
        .category-card:hover { border-color: var(--gold); transform: translateY(-8px); box-shadow: 0 10px 20px rgba(212, 175, 55, 0.1); }
        .cat-icon { font-size: 2.8rem; margin-bottom: 15px; }
        .cat-icon.blue i { color: #3498db !important; }
        .cat-icon.green i { color: #2ecc71 !important; }
        .cat-icon.gold i { color: var(--gold) !important; }
        .cat-icon.red i { color: #e74c3c !important; }
        .cat-icon.purple i { color: #9b59b6 !important; }
        .cat-icon.orange i { color: #e67e22 !important; }
        .cat-icon.cyan i { color: #1abc9c !important; }
        .cat-icon.pink i { color: #fd79a8 !important; }

        .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; }
        .product-item { background: #111; border-radius: 25px; overflow: hidden; border: 1px solid #222; transition: 0.4s; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5); }
        .product-img { width: 100%; height: 280px; background: #1a1a1a; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .product-img img { width: 100%; height: 100%; object-fit: cover; }
        .product-info { padding: 25px; background: linear-gradient(to top, #000, #111); text-align: center; }
        .product-info h3 { font-size: 1.4rem; margin-bottom: 12px; }
        .btn-order { background: #25D366; color: white !important; padding: 15px; border-radius: 15px; font-weight: bold; cursor: pointer; border: none; width: 100%; display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 1.1rem; }

        /* --- Modal & Forms --- */
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.95); z-index: 5000; display: flex; align-items: center; justify-content: center; }
        .modal-content { background: #151515; border: 2px solid var(--gold); border-radius: 25px; width: 95%; max-width: 550px; padding: 35px; position: relative; max-height: 90vh; overflow-y: auto; }
        .close-modal { position: absolute; top: 20px; left: 20px; font-size: 35px; color: var(--gold) !important; cursor: pointer; }

        .form-section { margin-bottom: 25px; text-align: right; }
        .form-section label { display: block; margin-bottom: 12px; color: var(--gold) !important; font-weight: bold; font-size: 1.1rem; }
        textarea, select, .coupon-row input { width: 100%; padding: 14px; background: #000 !important; border: 1px solid var(--gold) !important; color: var(--white) !important; border-radius: 10px; font-family: inherit; font-size: 1.1rem; }

        /* --- Customer UI Enhancements for Sizes --- */
        .size-selection-area { background: #0a0a0a; border: 1px solid #333; padding: 20px; border-radius: 15px; }
        .size-options-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(70px, 1fr)); gap: 10px; margin-bottom: 15px; }
        .size-btn { background: #151515; border: 1px solid #444; color: #fff; padding: 12px 5px; border-radius: 10px; cursor: pointer; transition: 0.3s; text-align: center; font-weight: bold; }
        .size-btn:hover { border-color: var(--gold); }
        .size-btn.active { background: rgba(212, 175, 55, 0.2); border-color: var(--gold); color: var(--gold) !important; box-shadow: 0 0 10px rgba(212, 175, 55, 0.2); }
        .size-btn small { display: block; font-size: 0.7rem; color: var(--gold) !important; margin-top: 5px; }

        .qty-controls { display: flex; align-items: center; justify-content: space-between; gap: 15px; margin-bottom: 15px; }
        .qty-wrapper { display: flex; align-items: center; background: #151515; border: 1px solid #444; border-radius: 10px; padding: 5px; }
        .qty-wrapper button { background: #222; border: none; color: var(--gold); width: 40px; height: 40px; border-radius: 8px; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center;}
        .qty-wrapper input { width: 50px; background: transparent; border: none; color: #fff !important; text-align: center; font-size: 1.2rem; font-weight: bold; outline: none; pointer-events: none;}

        .btn-add-size { background: var(--gold); color: #000 !important; border: none; padding: 12px 20px; border-radius: 10px; font-weight: bold; cursor: pointer; flex: 1; font-size: 1.1rem; display: flex; justify-content: center; align-items: center; gap: 10px;}

        .selected-sizes-list { background: #000; border-radius: 10px; padding: 15px; border: 1px dashed #444; margin-top: 15px; max-height: 200px; overflow-y: auto; }
        .selected-size-item { display: flex; justify-content: space-between; align-items: center; background: #151515; padding: 12px 15px; border-radius: 8px; margin-bottom: 10px; border-right: 3px solid var(--gold); }
        .selected-size-item:last-child { margin-bottom: 0; }
        .btn-remove-size { background: rgba(255, 71, 87, 0.1); border: 1px solid #ff4757; color: #ff4757 !important; border-radius: 8px; width: 35px; height: 35px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.3s;}
        .btn-remove-size:hover { background: #ff4757; color: #fff !important; }
        .empty-list-msg { color: #666 !important; text-align: center; font-size: 0.9rem; margin: 0; padding: 10px 0; }

        /* Custom File Input Styling */
        input[type="file"] { padding: 10px !important; }
        input[type="file"]::file-selector-button { background: var(--gold); color: #000; border: none; padding: 8px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; margin-left: 10px; transition: 0.3s; }
        input[type="file"]::file-selector-button:hover { background: #f3d56a; }

        .coupon-row { display: flex; gap: 10px; }
        .coupon-row button { background: var(--gold); border: none; padding: 0 25px; border-radius: 10px; font-weight: bold; cursor: pointer; color: #000 !important; }

        .order-summary { background: #000; padding: 20px; border-radius: 15px; margin-bottom: 25px; border: 1px dashed var(--gold); text-align: right; }
        .summary-item.total { font-size: 1.6rem; color: var(--gold) !important; font-weight: 900; }
        .whatsapp-confirm-btn { background: #25D366; color: white !important; width: 100%; padding: 18px; border: none; border-radius: 15px; font-size: 1.3rem; font-weight: bold; cursor: pointer; box-shadow: 0 8px 20px rgba(37, 211, 102, 0.3); }

        .whatsapp-float { position: fixed; bottom: 30px; left: 30px; background: #25D366; color: #fff !important; width: 65px; height: 65px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 35px; z-index: 1000; box-shadow: 0 10px 25px rgba(0,0,0,0.5); }
        .back-btn-small { background: var(--gold); color: #000 !important; border: none; padding: 12px 25px; border-radius: 12px; cursor: pointer; font-weight: 800; font-size: 1rem; display: flex; align-items: center; gap: 10px; }

        .swal2-container { z-index: 10000 !important; }
        .swal2-popup { background: #151515 !important; border: 1px solid var(--gold) !important; border-radius: 20px !important; color: #ffffff !important; }
        .swal2-title, .swal2-html-container { color: #ffffff !important; }
        .swal2-confirm { background: var(--gold) !important; color: #000 !important; font-weight: 900 !important; border-radius: 10px !important; }
        .swal2-cancel { background: #333 !important; color: #fff !important; border-radius: 10px !important; }

        .design-fee-notice { background: rgba(212, 175, 55, 0.1); border-right: 5px solid var(--gold); padding: 15px; margin-bottom: 20px; font-size: 1rem; border-radius: 8px; line-height: 1.5; }

        .features-section {
            display: flex;
            justify-content: center;
            gap: 60px;
            padding: 40px 20px;
            background: #111;
            margin: 50px auto;
            max-width: 900px;
            border-radius: 20px;
            flex-wrap: wrap;
        }

        .feature-item {
            text-align: center;
            flex: 1;
            min-width: 200px;
        }

            .feature-item i {
                color: var(--gold);
                font-size: 2.5rem;
                margin-bottom: 15px;
            }

            .feature-item h4 {
                color: var(--gold);
                margin: 10px 0;
                font-size: 1.3rem;
            }

        .social-section {
            padding: 20px;
            text-align: center;
        }

        .insta-btn-premium {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            background: linear-gradient(45deg, #f09433 0%, #bc1888 100%);
            color: white !important;
            padding: 15px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

            .insta-btn-premium:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(188, 24, 136, 0.4);
            }
        footer { text-align: center; padding: 50px 20px; margin-top: 60px; background: #000; border-top: 1px solid #222; }
    </style>
</head>
<body>

    <a href="https://wa.me/96892111393" class="whatsapp-float" target="_blank"><i class="fab fa-whatsapp"></i></a>

    <header>
        <div class="logo-area">
            <img src="~/images/logo.png" alt="المايسترو" class="main-logo" onerror="this.src='https://placehold.co/120/111/D4AF37?text=M'">
            <div class="text-group">
                <h1>المايسترو للرياضة</h1>
                <p><i class="fas fa-map-marker-alt" style="color:var(--gold) !important;"></i> سلطنة عمان - جعلان بني بوعلي</p>
            </div>
        </div>
    </header>

    <main>
        <div class="shipping-bar">
            <marquee style="text-align:center;" behavior="scroll" direction="right" scrollamount="6">@ViewBag.AnnouncementBar</marquee>
        </div>

        <section id="home-screen" class="active-screen">
            <div class="hero-gate" onclick="toggleView('categories')">
                <i class="fas fa-cut"></i>
                <h2>تفصيل وخياطة الملابس الرياضية</h2>
                <p>انقر هنا لاستعراض الموديلات والأقسام وبدء الطلب</p>
            </div>
        </section>

        <section id="categories-screen" class="hidden">
            <div class="container">
                <h2 class="section-title">اختر القسم المطلوب</h2>
                <div class="categories-grid" id="categories-render"></div>
                <div style="text-align:center; margin-top:40px;">
                    <button class="back-btn-small" onclick="toggleView('home')"><i class="fas fa-arrow-right"></i> العودة للرئيسية</button>
                </div>
            </div>
        </section>

        <section id="shop-screen" class="hidden">
            <div class="container">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; border-bottom:1px solid #333; padding-bottom:15px;">
                    <h2 id="cat-display-name" style="margin:0; border:none;" class="section-title">موديلات</h2>
                    <button class="back-btn-small" onclick="toggleView('categories')"><i class="fas fa-arrow-right"></i> رجوع</button>
                </div>
                <div id="products-list" class="products-grid"></div>
            </div>
        </section>

        <!-- نافذة الطلب -->
        <div id="order-modal" class="modal-overlay hidden">
            <div class="modal-content">
                <span class="close-modal" onclick="closeModal()">&times;</span>
                <h2 id="modal-item-name" style="color:var(--gold)!important; border-bottom: 1px solid #333; padding-bottom: 15px; margin-bottom: 20px;">تفاصيل التفصيل</h2>

                <div id="custom-design-alert" class="design-fee-notice hidden">
                    <i class="fas fa-gem"></i> هذا الموديل (تصميم خاص) يضاف <strong>2 ريال</strong> لرسوم التصميم للقطعة الواحدة.<br>
                    <span style="color:#2ecc71!important; font-size:0.9rem;">(رسوم التصميم مجانية إذا كان الطلب 11 قطعة فأكثر)</span>
                </div>

                <div class="order-form-body">

                    <!-- واجهة المقاسات والكميات الجديدة (Customer UI) -->
                    <div class="form-section size-selection-area">
                        <label><i class="fas fa-ruler-combined"></i> 1. اختر المقاس:</label>
                        <div id="size-options-grid" class="size-options-grid">
                            <!-- سيتم تعبئة الأزرار هنا -->
                        </div>

                        <label style="margin-top: 15px;"><i class="fas fa-sort-numeric-up"></i> 2. حدد الكمية واضغط إضافة:</label>
                        <div class="qty-controls">
                            <div class="qty-wrapper">
                                <button type="button" onclick="changeQty(-1)"><i class="fas fa-minus"></i></button>
                                <input type="number" id="selected-qty" value="1" readonly>
                                <button type="button" onclick="changeQty(1)"><i class="fas fa-plus"></i></button>
                            </div>
                            <button type="button" class="btn-add-size" onclick="addSizeToSelection()">
                                إضافة للسلة <i class="fas fa-cart-plus"></i>
                            </button>
                        </div>

                        <label style="margin-top: 15px;"><i class="fas fa-box-open"></i> سلة المقاسات المضافة:</label>
                        <div id="selected-sizes-list" class="selected-sizes-list">
                            <!-- المقاسات المختارة تظهر هنا -->
                        </div>
                    </div>

                    <!-- إرفاق صورة للتصميم الخاص -->
                    <div id="custom-image-section" class="form-section hidden" style="background: rgba(212, 175, 55, 0.05); padding: 15px; border-radius: 12px; border: 1px solid var(--gold);">
                        <label><i class="fas fa-image"></i> إرفاق صورة للتصميم (اختياري):</label>
                        <input type="file" id="custom-image-input" accept="image/*" class="form-control">
                        <small style="color: var(--text-dim); display: block; margin-top: 8px;">هل لديك شعار أو تصميم معين؟ ارفق الصورة هنا لمساعدتنا في التفصيل.</small>
                    </div>

                    <div class="form-section">
                        <label><i class="fas fa-scroll"></i> 3. نوع القماش:</label>
                        <select id="fabric-select" onchange="calculateLiveTotal()">
                            <option value="0" data-name="قماش رياضي قياسي">قماش رياضي قياسي (مشمول)</option>
                            <option value="3" data-name="قماش ديواني ملكي">قماش ديواني ملكي (+3 ريال)</option>
                            <option value="5" data-name="قماش نخب أول أصلي">قماش نخب أول أصلي (+5 ريال)</option>
                            <option value="2" data-name="قماش تبريد مسامي">قماش تبريد مسامي (+2 ريال)</option>
                        </select>
                    </div>

                    <div class="form-section">
                        <label><i class="fas fa-pen"></i> 4. ملاحظات خاصة (الأسماء، الأرقام):</label>
                        <textarea id="order-notes" rows="2" placeholder="اكتب ملاحظاتك، الأسماء المطلوبة على الظهر، أو أي طلب خاص..."></textarea>
                    </div>

                    <div class="form-section coupon-row">
                        <input type="text" id="coupon-input" placeholder="هل لديك كود خصم؟">
                        <button type="button" id="apply-coupon-btn" onclick="applyCouponLogic()">تطبيق</button>
                    </div>

                    <div class="order-summary">
                        <div class="summary-item total">الإجمالي التقريبي: <span id="total-price-display">0</span> ريال</div>
                        <small style="font-size:0.85rem;">* السعر النهائي يتم تأكيده في الواتساب</small>
                    </div>

                    <button class="whatsapp-confirm-btn" onclick="submitOrderProcess()" id="submit-btn">
                        <i class="fab fa-whatsapp"></i> تأكيد الطلب وإرسال للواتساب
                    </button>
                </div>
            </div>
        </div>
        <section class="features-section">
            <div class="feature-item"><i class="fas fa-award text-gold"></i><h4>جودة ملكية</h4><p>نستخدم أفضل الخامات العالمية</p></div>
            <div class="feature-item"><i class="fas fa-bolt text-gold"></i><h4>سرعة التنفيذ</h4><p>دقة ومواعيد تسليم منضبطة</p></div>
        </section>

        <section class="social-section">
            <a href="https://www.instagram.com/almystro_sport" target="_blank" class="insta-btn-premium">
                <i class="fab fa-instagram"></i> <span>تابعونا على انستجرام للجديد</span>
            </a>
        </section>
    </main>

    <footer>
        <p>© 2024 المايسترو للرياضة - جعلان بني بوعلي | خيارك الأول للأناقة الرياضية</p>
        <p>تم التصميم والتطوير   بواسطة GMTWEB</p>
    </footer>

    <script>    
        const categoriesData = @Html.Raw(ViewBag.CategoriesJson ?? "[]");
        const sizesData = @Html.Raw(ViewBag.SizesJson ?? "[]");

        let currentProduct = null;
        let appliedDiscount = 0;
        let activeCouponCode = "";

        // متغيرات واجهة العميل للسلة
        let currentSelectedSizeId = null;
        let orderItems = [];

        function toast(title, icon = 'success') {
            Swal.fire({
                title: title, icon: icon, timer: 2000, showConfirmButton: false, toast: true,
                position: 'top-end', background: '#151515', color: '#ffffff'
            });
        }

        function renderCategories() {
            const container = document.getElementById('categories-render');
            if (!container) return;
            container.innerHTML = "";
            categoriesData.forEach(cat => {
                container.innerHTML += `
                    <div class="category-card" onclick="loadCategory(${cat.Id})">
                        <div class="cat-icon ${cat.ColorClass}"><i class="fas ${cat.IconClass}"></i></div>
                        <span style="color: #ffffff; font-weight: bold; font-size:1.2rem;">تفصيل ${cat.Name}</span>
                    </div>`;
            });
        }

        function toggleView(screenId) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            const targetScreen = document.getElementById(screenId + '-screen');
            if (targetScreen) targetScreen.classList.remove('hidden');
            if (screenId === 'categories') renderCategories();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function loadCategory(catId) {
            const cat = categoriesData.find(c => c.Id === catId);
            if (!cat) return;

            document.getElementById('cat-display-name').innerText = "تفصيل " + cat.Name;
            const list = document.getElementById('products-list');
            list.innerHTML = "";

            if (!cat.Products || cat.Products.length === 0) {
                list.innerHTML = `<p style="text-align:center; width:100%; color:#D4AF37; font-size: 1.2rem;">لا توجد موديلات في هذا القسم حالياً.</p>`;
            } else {
                cat.Products.forEach(item => {
                    list.innerHTML += `
                        <div class="product-item">
                            <div class="product-img"><img src="/${item.ImageUrl}" onerror="this.src='https://placehold.co/400x500/111/D4AF37?text=No+Image'"></div>
                            <div class="product-info">
                                <h3 style="color: #ffffff;">${item.Name} ${item.IsCustomDesign ? '<br><small style="color:#D4AF37; font-size:0.8rem;">(تصميم خاص)</small>' : ''}</h3>
                                <p style="color:#D4AF37; font-weight:900; font-size:1.5rem; margin-bottom:15px;">${item.BasePrice} ريال</p>
                                <button class="btn-order" onclick="openOrderModal(${item.Id})"><i class="fas fa-magic"></i> اطلب تفصيل الآن</button>
                            </div>
                        </div>`;
                });
            }
            toggleView('shop');
        }

        function openOrderModal(productId) {
            categoriesData.forEach(c => {
                const found = c.Products.find(p => p.Id === productId);
                if (found) currentProduct = found;
            });
            if (!currentProduct) return;

            document.getElementById('modal-item-name').innerText = "طلب تفصيل: " + currentProduct.Name;

            // إظهار المرفقات والتنبيه إذا كان تصميم خاص
            document.getElementById('custom-design-alert').classList.toggle('hidden', !currentProduct.IsCustomDesign);
            document.getElementById('custom-image-section').classList.toggle('hidden', !currentProduct.IsCustomDesign);

            // تصفير البيانات
            orderItems = [];
            currentSelectedSizeId = null;
            document.getElementById('selected-qty').value = 1;
            document.getElementById('custom-image-input').value = "";
            document.getElementById('order-notes').value = "";
            document.getElementById('fabric-select').value = "0";
            appliedDiscount = 0;
            activeCouponCode = "";
            document.getElementById('coupon-input').value = "";

            renderSizeOptions();
            renderSelectedSizes();
            calculateLiveTotal();

            document.getElementById('order-modal').classList.remove('hidden');
        }

        // 1. رسم أزرار المقاسات
        function renderSizeOptions() {
            const container = document.getElementById('size-options-grid');
            container.innerHTML = "";
            sizesData.forEach((s, idx) => {
                if(idx === 0) currentSelectedSizeId = s.Id;
                let extra = parseFloat(s.AdditionalPrice);
                let extraText = extra > 0 ? `+${extra}` : (extra < 0 ? `${extra}` : "");

                container.innerHTML += `
                    <button type="button" class="size-btn ${idx === 0 ? 'active' : ''}" onclick="selectSizeBtn(${s.Id}, this)">
                        ${s.Name}
                        ${extraText ? `<small>${extraText}</small>` : ''}
                    </button>
                `;
            });
        }

        // 2. اختيار المقاس
        function selectSizeBtn(id, btnElement) {
            currentSelectedSizeId = id;
            document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');
        }

        // 3. التحكم بالكمية
        function changeQty(delta) {
            let input = document.getElementById('selected-qty');
            let val = parseInt(input.value) + delta;
            if(val < 1) val = 1;
            input.value = val;
        }

        // 4. إضافة المقاس للسلة
        function addSizeToSelection() {
            if(!currentSelectedSizeId) return;
            const qty = parseInt(document.getElementById('selected-qty').value);
            const sizeObj = sizesData.find(s => s.Id === currentSelectedSizeId);

            const existing = orderItems.find(i => i.SizeId === currentSelectedSizeId);
            if(existing) {
                existing.Quantity += qty;
            } else {
                orderItems.push({
                    SizeId: sizeObj.Id,
                    SizeName: sizeObj.Name,
                    ExtraPrice: parseFloat(sizeObj.AdditionalPrice) || 0,
                    Quantity: qty
                });
            }

            document.getElementById('selected-qty').value = 1; // إرجاع الكمية لـ 1
            renderSelectedSizes();
            calculateLiveTotal();
            toast("تمت الإضافة للسلة بنجاح");
        }

        // 5. إزالة من السلة
        function removeSizeFromSelection(index) {
            orderItems.splice(index, 1);
            renderSelectedSizes();
            calculateLiveTotal();
        }

        // 6. رسم السلة المصغرة
        function renderSelectedSizes() {
            const list = document.getElementById('selected-sizes-list');
            list.innerHTML = "";
            if(orderItems.length === 0) {
                list.innerHTML = '<p class="empty-list-msg">لم تقم بإضافة أي مقاسات بعد.</p>';
                return;
            }

            orderItems.forEach((item, index) => {
                list.innerHTML += `
                    <div class="selected-size-item">
                        <div>
                            <span style="color:var(--gold); font-weight:bold; font-size:1.1rem; margin-left:10px;">${item.SizeName}</span>
                            <span style="color:#ccc;">الكمية: <strong>${item.Quantity}</strong></span>
                        </div>
                        <button type="button" class="btn-remove-size" onclick="removeSizeFromSelection(${index})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;
            });
        }

        function calculateLiveTotal(isCouponClick = false) {
            if (!currentProduct) return;

            let totalQty = 0;
            let totalPrice = 0;
            const fabricSelect = document.getElementById('fabric-select');
            const fabricExtra = fabricSelect ? parseFloat(fabricSelect.value) : 0;

            orderItems.forEach(item => {
                totalQty += item.Quantity;
                totalPrice += item.Quantity * (currentProduct.BasePrice + item.ExtraPrice + fabricExtra);
            });

            if (currentProduct.IsCustomDesign && totalQty > 0 && totalQty <= 10) {
                totalPrice += (2 * totalQty);
            }

            if (isCouponClick) {
                const codeInput = document.getElementById('coupon-input');
                const code = codeInput ? codeInput.value.trim().toUpperCase() : "";
                if (!code) return;

                fetch(`/Home/ValidateCoupon?code=${encodeURIComponent(code)}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.valid) {
                            appliedDiscount = data.discount;
                            activeCouponCode = code;
                            Swal.fire({ title: 'تم التفعيل!', text: `خصم ${data.discount} ريال`, icon: 'success', background:'#151515', color:'#fff' });
                        } else {
                            appliedDiscount = 0; activeCouponCode = "";
                            Swal.fire({ title: 'عفواً!', text: 'كود غير صحيح', icon: 'error', background:'#151515', color:'#fff' });
                        }
                        updateDisplay();
                    });
            } else {
                updateDisplay();
            }

            function updateDisplay() {
                let final = totalPrice - appliedDiscount;
                if (final < 0) final = 0;
                document.getElementById('total-price-display').innerText = final.toFixed(2);
            }

            return { totalQty, totalPrice: (totalPrice - appliedDiscount) };
        }

        function closeModal() { document.getElementById('order-modal').classList.add('hidden'); }

        function submitOrderProcess() {
            const { totalQty, totalPrice } = calculateLiveTotal();
            if (totalQty === 0) {
                Swal.fire({ title: 'تنبيه', text: 'يرجى إضافة مقاس واحد على الأقل للسلة', icon: 'warning', background:'#151515', color:'#fff' });
                return;
            }

            Swal.fire({
                title: 'تأكيد الطلب',
                text: `سيتم إرسال طلب لـ ${totalQty} قطعة، هل أنت متأكد؟`,
                icon: 'question', showCancelButton: true, confirmButtonText: 'نعم، اعتمد الطلب', cancelButtonText: 'تراجع',
                background: '#151515', color: '#ffffff', confirmButtonColor: '#25D366'
            }).then((result) => {
                if (result.isConfirmed) {
                    const btn = document.getElementById('submit-btn');
                    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري إرسال الطلب...';

                    const fabricSelect = document.getElementById('fabric-select');
                    const fabricName = fabricSelect.options[fabricSelect.selectedIndex].getAttribute('data-name');

                    const formData = new FormData();
                    formData.append('ProductId', currentProduct.Id);
                    formData.append('Notes', document.getElementById('order-notes').value || "");
                    formData.append('FabricType', fabricName);
                    formData.append('FabricExtraPrice', parseFloat(fabricSelect.value) || 0);
                    formData.append('CouponCode', activeCouponCode);
                    formData.append('ItemsJson', JSON.stringify(orderItems.map(i => ({ SizeId: i.SizeId, Quantity: i.Quantity }))));

                    const imageInput = document.getElementById('custom-image-input');
                    if(imageInput && imageInput.files.length > 0) {
                        formData.append('CustomImage', imageInput.files[0]);
                    }

                    fetch('/Home/SubmitOrder', {
                        method: 'POST',
                        body: formData
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({ title: 'نجاح!', text: 'جاري تحويلك للواتساب...', icon: 'success', showConfirmButton: false, timer: 2000, background: '#151515', color: '#fff' })
                            .then(() => {
                                const msg = `*طلب تفصيل من المايسترو رقم ${data.orderId}*%0A*الموديل:* ${currentProduct.Name}%0A*القطع:* ${totalQty}%0A*الإجمالي:* ${data.totalPrice} ريال`;
                                window.location.href = `https://wa.me/96892111393?text=${msg}`;
                            });
                            closeModal();
                        } else {
                            Swal.fire('خطأ', data.message || 'حدثت مشكلة', 'error');
                        }
                    })
                    .catch(err => {
                        Swal.fire('خطأ', 'فشل الاتصال بالخادم', 'error');
                    })
                    .finally(() => {
                        btn.disabled = false; btn.innerHTML = '<i class="fab fa-whatsapp"></i> تأكيد الطلب وإرسال للواتساب';
                    });
                }
            });
        }
    </script>
</body>
</html>