@model IEnumerable<MaestroSport.Models.Order>
@{
    ViewData["Title"] = "إدارة الطلبات";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card-premium">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 15px;">
        <div>
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-shopping-bag" style="margin-left: 10px;"></i> سجل الطلبات الملكي</h3>
            <p style="color: var(--text-dim); font-size: 0.9rem;">تتبع وإدارة كافة طلبات التفصيل الخاصة بزبائنك</p>
        </div>
        <div style="display: flex; gap: 10px;">
            <button class="btn-premium btn-outline" style="border-color: #333; color: #fff;">تصفية النتائج <i class="fas fa-filter"></i></button>
        </div>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>رقم الطلب</th>
                    <th>بيانات الزبون</th>
                    <th>تاريخ الطلب</th>
                    <th>الإجمالي</th>
                    <th>تاريخ الاستلام</th>
                    <th>الحالة</th>
                    <th style="text-align: left;">إجراء</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: 900; color: var(--gold); font-size: 1.1rem;">#@item.Id</td>
                        <td>
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-weight: bold; font-size: 1.05rem;">@(item.CustomerName ?? "غير مسجل")</span>
                                <span style="font-size: 0.85rem; color: var(--text-dim);"><i class="fas fa-phone-alt"></i> @(item.PhoneNumber ?? "---")</span>
                            </div>
                        </td>
                        <td style="color: var(--text-dim);">@item.CreatedAt.ToString("yyyy/MM/dd")</td>
                        <td style="font-weight: bold; color: var(--white); font-size: 1.1rem;">@item.TotalAmount ر.ع</td>
                        <td style="color: #3498db; font-weight: bold;">@item.ExpectedDeliveryDate.ToString("yyyy/MM/dd")</td>
                        <td>
                            <span class="badge @(item.Status == "قيد المراجعة" ? "badge-pending" : "badge-success")">
                                @item.Status
                            </span>
                        </td>
                        <td style="text-align: left;">
                            <div style="display: flex; gap: 8px; justify-content: flex-end;">

                                <!-- زر الاستلام للعمال (يظهر فقط إذا كان الطلب قيد المراجعة) -->
                                @if (User.IsInRole("Worker") && item.Status == "قيد المراجعة")
                                {
                                    <form asp-controller="Orders" asp-action="UpdateStatus" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="status" value="جاري التفصيل" />
                                        <button type="submit" class="btn-premium" style="background: #2ecc71; color: #fff; padding: 8px 15px; border: none;" title="استلام الطلب للبدء فيه">
                                            <i class="fas fa-clipboard-check"></i> استلام
                                        </button>
                                    </form>
                                }

                                <!-- زر التفاصيل (يظهر للجميع) -->
                                <a href="/Orders/Details/@item.Id" class="btn-premium btn-gold" style="padding: 8px 15px;" title="عرض التفاصيل">
                                    <i class="fas fa-eye"></i>
                                </a>

                                <!-- زر الحذف (يظهر للأدمن فقط) -->
                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-controller="Orders" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا الطلب نهائياً وإلغائه؟');">
                                        <button type="submit" class="btn-premium btn-outline" style="padding: 8px 15px; border-color: #ff4757; color: #ff4757;" title="حذف الطلب">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 80px; color: var(--text-dim);">
                            <i class="fas fa-box-open fa-3x" style="display: block; margin-bottom: 20px; opacity: 0.2;"></i>
                            لا توجد طلبات مسجلة حتى الآن.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>