@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>المايسترو للرياضة | الفخامة في التفصيل</title>
    <!-- الأيقونات والخطوط -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;500;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* ==========================================================================
                   PREMIUM DESIGN SYSTEM (ADVANCED)
                   ========================================================================== */
        :root {
            --gold: #D4AF37;
            --gold-light: #F3E5AB;
            --gold-gradient: linear-gradient(135deg, #D4AF37 0%, #aa8c2c 100%);
            --black-bg: #050505;
            --dark-surface: rgba(20, 20, 20, 0.7);
            --dark-border: rgba(255, 255, 255, 0.08);
            --glass-bg: rgba(15, 15, 15, 0.6);
            --glass-border: rgba(212, 175, 55, 0.2);
            --text-main: #ffffff;
            --text-muted: #a0a0a0;
            --insta-grad: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            --transition-smooth: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--black-bg);
            color: var(--text-main);
            background-image: radial-gradient(circle at 15% 50%, rgba(212, 175, 55, 0.05), transparent 25%), radial-gradient(circle at 85% 30%, rgba(212, 175, 55, 0.03), transparent 25%);
            background-attachment: fixed;
            line-height: 1.6;
        }

        /* --- Typography & Utilities --- */
        .text-gold {
            color: var(--gold) !important;
        }

        .hidden {
            display: none !important;
        }

        /* --- Sticky Premium Header --- */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(5, 5, 5, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--dark-border);
            z-index: 1000;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 70px;
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .header-logo {
            width: 45px;
            height: 45px;
            object-fit: contain;
            filter: drop-shadow(0 0 8px rgba(212,175,55,0.4));
        }

        .header-title {
            font-weight: 900;
            font-size: 1.4rem;
            color: var(--text-main);
            letter-spacing: 0.5px;
            margin: 0;
        }

            .header-title span {
                color: var(--gold);
            }

        /* --- Main Layout --- */
        main {
            padding-top: 70px;
            min-height: calc(100vh - 100px);
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        /* --- Hero Section & Marquee --- */
        .hero-section {
            text-align: center;
            padding: 40px 20px;
            background: radial-gradient(ellipse at bottom, rgba(212,175,55,0.1) 0%, transparent 60%);
            border-bottom: 1px solid var(--dark-border);
            margin-bottom: 30px;
        }

        .hero-title {
            font-size: 2.2rem;
            font-weight: 900;
            margin-bottom: 10px;
            text-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        .hero-subtitle {
            color: var(--text-muted);
            font-size: 1rem;
            max-width: 600px;
            margin: 0 auto 25px auto;
        }

        .promo-marquee {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 50px;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            max-width: 800px;
            margin: 0 auto;
            backdrop-filter: blur(5px);
        }

            .promo-marquee i {
                color: var(--gold);
                margin-left: 10px;
                font-size: 1.2rem;
            }

            .promo-marquee marquee {
                color: var(--gold-light);
                font-weight: 700;
                font-size: 0.95rem;
            }

        /* --- Section Titles --- */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .section-title::before {
                content: '';
                display: block;
                width: 4px;
                height: 24px;
                background: var(--gold-gradient);
                border-radius: 4px;
            }

        /* --- Grid Layout (2 Columns Mobile, 4 Desktop) --- */
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }
        @@media (min-width: 768px) {
            .grid-layout

        {
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
        }

        }

        /* --- Category Cards (Glassmorphism) --- */
        .category-card {
            background: var(--dark-surface);
            border: 1px solid var(--dark-border);
            border-radius: 20px;
            padding: 25px 15px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition-smooth);
            backdrop-filter: blur(10px);
        }

            .category-card:hover, .category-card:active {
                border-color: var(--gold);
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(212, 175, 55, 0.15);
                background: rgba(30, 30, 30, 0.8);
            }

        .cat-icon-wrapper {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: rgba(255,255,255,0.03);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px auto;
            font-size: 1.8rem;
            transition: var(--transition-smooth);
        }

        .category-card:hover .cat-icon-wrapper {
            background: rgba(212, 175, 55, 0.1);
            color: var(--gold);
            transform: scale(1.1);
        }

        .category-name {
            font-weight: 700;
            font-size: 1rem;
            color: #fff;
        }

        /* Dynamic Icons Colors Base */
        .cat-icon-wrapper.blue {
            color: #3498db;
        }

        .cat-icon-wrapper.green {
            color: #2ecc71;
        }

        .cat-icon-wrapper.gold {
            color: var(--gold);
        }

        .cat-icon-wrapper.red {
            color: #e74c3c;
        }

        /* --- Product Cards --- */
        .product-card {
            background: var(--dark-surface);
            border: 1px solid var(--dark-border);
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: var(--transition-smooth);
        }

            .product-card:hover {
                border-color: var(--gold);
                box-shadow: 0 8px 25px rgba(0,0,0,0.5);
            }

        .product-img-box {
            position: relative;
            width: 100%;
            padding-top: 120%; /* Aspect ratio for clothes */
            background: #111;
            overflow: hidden;
        }

            .product-img-box img {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
            }

        .product-card:hover .product-img-box img {
            transform: scale(1.05);
        }

        .custom-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(5px);
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 0.7rem;
            font-weight: 900;
        }

        .product-details {
            padding: 15px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-title {
            font-size: 0.95rem;
            font-weight: 700;
            margin-bottom: auto;
            line-height: 1.4;
            color: #fff;
        }

        .product-action-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            border-top: 1px solid var(--dark-border);
            padding-top: 12px;
        }

        .product-price {
            font-size: 1.1rem;
            font-weight: 900;
            color: var(--gold);
        }

        .btn-add {
            background: var(--gold-gradient);
            color: #000;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(212,175,55,0.3);
            transition: var(--transition-smooth);
        }

            .btn-add:hover, .btn-add:active {
                transform: scale(1.1);
            }

        /* --- Instagram Premium Banner --- */
        .instagram-banner {
            margin: 50px auto 20px auto;
            max-width: 1200px;
            border-radius: 20px;
            background: var(--insta-grad);
            padding: 2px; /* For border effect */
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(220, 39, 67, 0.2);
        }

        .insta-content {
            background: var(--black-bg);
            border-radius: 18px;
            padding: 30px 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .insta-icon {
            font-size: 3rem;
            background: var(--insta-grad);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
        }

        .insta-text {
            font-size: 1.5rem;
            font-weight: 900;
            margin-bottom: 5px;
            color: #fff;
        }

        .insta-sub {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 20px;
        }

        .btn-insta {
            background: var(--insta-grad);
            color: #fff;
            text-decoration: none;
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: bold;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: var(--transition-smooth);
        }

            .btn-insta:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(255,255,255,0.2);
                color: #fff;
            }

        /* --- Modal (Bottom Sheet Style) --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            z-index: 5000;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }

            .modal-overlay.show {
                opacity: 1;
                pointer-events: auto;
            }

        .modal-content {
            background: #0f0f0f;
            width: 100%;
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
            border-radius: 30px 30px 0 0;
            padding: 30px 20px;
            border-top: 1px solid var(--glass-border);
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        @@media (min-width: 768px) {
            .modal-overlay

        {
            align-items: center;
        }

        .modal-content {
            border-radius: 20px;
            border: 1px solid var(--glass-border);
        }

        }

        .modal-overlay.show .modal-content {
            transform: translateY(0);
        }

        .modal-drag-handle {
            width: 40px;
            height: 5px;
            background: #333;
            border-radius: 5px;
            margin: 0 auto 20px auto;
        }

        .close-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(255,255,255,0.1);
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            color: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-title {
            font-size: 1.4rem;
            font-weight: 900;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--dark-border);
            text-align: right;
        }

        /* Form Elements inside Modal */
        .input-group {
            margin-bottom: 20px;
        }

        .input-label {
            display: block;
            margin-bottom: 8px;
            color: var(--gold-light);
            font-weight: 700;
            font-size: 0.9rem;
            text-align: right;
        }

        .form-control {
            width: 100%;
            padding: 15px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 12px;
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.3s;
            text-align: right;
        }

            .form-control:focus {
                border-color: var(--gold);
                outline: none;
                background: rgba(255,255,255,0.05);
            }

        /* Sizes Area */
        .size-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 15px;
        }

        .pill {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 10px;
            border-radius: 10px;
            color: #fff;
            cursor: pointer;
            flex-grow: 1;
            text-align: center;
            font-weight: 700;
            transition: 0.3s;
        }

            .pill.active {
                background: rgba(212,175,55,0.15);
                border-color: var(--gold);
                color: var(--gold);
            }

        .qty-row {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 15px;
        }

        .qty-stepper {
            display: flex;
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
            overflow: hidden;
        }

        .qty-btn {
            background: transparent;
            border: none;
            color: var(--gold);
            width: 45px;
            height: 45px;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .qty-input {
            width: 50px;
            background: transparent;
            border: none;
            color: #fff;
            text-align: center;
            font-weight: 900;
            font-size: 1.1rem;
            pointer-events: none;
        }

        .btn-add-cart-mini {
            background: var(--gold-gradient);
            border: none;
            color: #000;
            border-radius: 12px;
            font-weight: 900;
            flex-grow: 1;
            height: 45px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .cart-items-list {
            background: rgba(0,0,0,0.5);
            border-radius: 12px;
            padding: 10px;
            border: 1px dashed #333;
            max-height: 150px;
            overflow-y: auto;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255,255,255,0.03);
            padding: 10px 15px;
            border-radius: 8px;
            margin-bottom: 8px;
            border-right: 3px solid var(--gold);
        }

        .cart-item-del {
            background: rgba(255,71,87,0.1);
            color: #ff4757;
            border: none;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* File Upload */
        input[type="file"] {
            padding: 10px;
        }

            input[type="file"]::file-selector-button {
                background: var(--gold);
                color: #000;
                border: none;
                padding: 8px 16px;
                border-radius: 8px;
                font-weight: bold;
                margin-left: 15px;
                cursor: pointer;
            }

        /* Total & Submit */
        .total-box {
            background: var(--gold-gradient);
            border-radius: 15px;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 25px;
            margin-bottom: 15px;
        }

            .total-box span {
                color: #000;
                font-weight: 900;
                font-size: 1.2rem;
            }

        .total-val {
            font-size: 1.8rem !important;
        }

        .btn-submit-order {
            width: 100%;
            background: #fff;
            color: #000;
            border: none;
            padding: 18px;
            border-radius: 15px;
            font-size: 1.2rem;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: 0.3s;
        }

            .btn-submit-order:active {
                transform: scale(0.98);
            }

        .btn-back {
            background: transparent;
            border: 1px solid var(--dark-border);
            color: #fff;
            padding: 8px 15px;
            border-radius: 10px;
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Custom SweetAlert */
        .swal2-popup {
            background: #111 !important;
            border: 1px solid var(--glass-border) !important;
            border-radius: 20px !important;
            color: #fff !important;
        }

        .swal2-confirm {
            background: var(--gold) !important;
            color: #000 !important;
            font-weight: 900 !important;
            border-radius: 10px !important;
        }

        footer {
            text-align: center;
            padding: 30px;
            border-top: 1px solid var(--dark-border);
            margin-top: 40px;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="#" class="header-brand" onclick="toggleView('categories')">
            <img src="~/images/logo.png" alt="المايسترو" class="header-logo" onerror="this.src='https://placehold.co/100/111/D4AF37?text=M'">
            <h1 class="header-title">المايسترو <span>للرياضة</span></h1>
        </a>
    </header>

    <main>
        <!-- Hero Section -->
        <section id="categories-screen" class="active-screen">
            <div class="hero-section">
                <h2 class="hero-title">تفصيل يليق <span class="text-gold">بالأبطال</span></h2>
                <p class="hero-subtitle">اختر الموديل، حدد مقاساتك، واترك الجودة علينا. نوفر شحن لجميع الولايات ودول الخليج.</p>
                <div class="promo-marquee">
                    <i class="fas fa-bolt"></i>
                    <marquee behavior="scroll" direction="right" scrollamount="5">@ViewBag.AnnouncementBar</marquee>
                </div>
            </div>

            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">التصنيفات</h2>
                </div>
                <div class="grid-layout" id="categories-render">
                    <!-- Categories Injected via JS -->
                </div>
            </div>

            <!-- Instagram Premium Banner -->
            <div class="container">
                <div class="instagram-banner">
                    <div class="insta-content">
                        <i class="fab fa-instagram insta-icon"></i>
                        <h3 class="insta-text">تابعنا على إنستجرام</h3>
                        <p class="insta-sub">اكتشف أحدث التصاميم والعروض الحصرية قبل الجميع</p>
                        <a href="https://www.instagram.com/almystro_sport" target="_blank" class="btn-insta">
                            <i class="fab fa-instagram"></i> @@almystro_sport
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Products Section -->
        <section id="shop-screen" class="hidden">
            <div class="container">
                <div class="section-header" style="margin-top: 20px;">
                    <h2 id="cat-display-name" class="section-title">الموديلات</h2>
                    <button class="btn-back" onclick="toggleView('categories')">
                        رجوع <i class="fas fa-arrow-left"></i>
                    </button>
                </div>
                <div id="products-list" class="grid-layout">
                    <!-- Products Injected via JS -->
                </div>
            </div>
        </section>

        <!-- App-Style Order Modal -->
        <div id="order-modal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-drag-handle"></div>
                <button class="close-btn" onclick="closeModal()"><i class="fas fa-times"></i></button>

                <h3 id="modal-item-name" class="modal-title">تفاصيل الطلب</h3>

                <div id="custom-design-alert" class="hidden" style="background: rgba(212,175,55,0.1); border-right: 3px solid var(--gold); padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 0.85rem;">
                    <i class="fas fa-gem text-gold"></i> تصميم خاص: يضاف <strong>2 ريال</strong> للقطعة. (مجاناً للطلبات 11 قطعة فأكثر)
                </div>

                <div class="order-form-body">
                    <!-- 1. Customer Info -->
                    <div class="input-group">
                        <label class="input-label"><i class="fas fa-user-circle"></i> بيانات الاستلام</label>
                        <input type="text" id="customer-name" class="form-control" placeholder="الاسم الكريم" style="margin-bottom: 10px;">
                        <input type="tel" id="customer-phone" class="form-control" placeholder="رقم الهاتف (مثال: 90000000)">
                    </div>

                    <!-- 2. Sizes & Cart -->
                    <div class="input-group" style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 15px; border: 1px solid var(--dark-border);">
                        <label class="input-label"><i class="fas fa-ruler"></i> المقاسات</label>
                        <div id="size-options-grid" class="size-pills"></div>

                        <div class="qty-row">
                            <div class="qty-stepper">
                                <button type="button" class="qty-btn" onclick="changeQty(-1)"><i class="fas fa-minus"></i></button>
                                <input type="number" id="selected-qty" class="qty-input" value="1" readonly>
                                <button type="button" class="qty-btn" onclick="changeQty(1)"><i class="fas fa-plus"></i></button>
                            </div>
                            <button type="button" class="btn-add-cart-mini" onclick="addSizeToSelection()">
                                <i class="fas fa-cart-plus"></i> إضافة
                            </button>
                        </div>
                        <div id="selected-sizes-list" class="cart-items-list"></div>
                    </div>

                    <!-- 3. Image Upload (Conditional) -->
                    <div id="custom-image-section" class="input-group hidden">
                        <label class="input-label"><i class="fas fa-upload"></i> إرفاق الشعار/التصميم</label>
                        <input type="file" id="custom-image-input" accept="image/*" class="form-control">
                    </div>

                    <!-- 4. Fabric & Notes -->
                    <div class="input-group">
                        <label class="input-label"><i class="fas fa-layer-group"></i> نوع القماش</label>
                        <select id="fabric-select" class="form-control" onchange="calculateLiveTotal()">
                            <option value="0" data-name="قماش رياضي قياسي">قياسي (مشمول)</option>
                            <option value="3" data-name="قماش ديواني ملكي">ديواني ملكي (+3 ريال)</option>
                            <option value="5" data-name="قماش نخب أول أصلي">نخب أول (+5 ريال)</option>
                            <option value="2" data-name="قماش تبريد مسامي">تبريد مسامي (+2 ريال)</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label class="input-label"><i class="fas fa-pen-alt"></i> ملاحظات / أسماء وأرقام</label>
                        <textarea id="order-notes" class="form-control" rows="2" placeholder="اكتب الأسماء والأرقام المطلوبة هنا..."></textarea>
                    </div>

                    <div class="input-group" style="display: flex; gap: 10px;">
                        <input type="text" id="coupon-input" class="form-control" placeholder="كود الخصم">
                        <button type="button" onclick="applyCouponLogic()" style="background:var(--dark-surface); border:1px solid var(--gold); color:var(--gold); border-radius:12px; padding:0 20px; font-weight:bold; cursor:pointer;">تفعيل</button>
                    </div>

                    <div class="total-box">
                        <span>الإجمالي</span>
                        <span class="total-val"><span id="total-price-display">0</span> <small style="font-size:1rem;">ر.ع</small></span>
                    </div>

                    <button class="btn-submit-order" onclick="submitOrderProcess()" id="submit-btn">
                        إرسال الطلب <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>

    </main>

    <footer>
        <img src="~/images/logo.png" style="width: 40px; filter: grayscale(1) opacity(0.5); margin-bottom: 10px;" onerror="this.style.display='none'">
        <p>© 2024 المايسترو للرياضة - جميع الحقوق محفوظة</p>
    </footer>

    <script>
        const categoriesData = @Html.Raw(ViewBag.CategoriesJson ?? "[]");
        const sizesData = @Html.Raw(ViewBag.SizesJson ?? "[]");

        let currentProduct = null;
        let appliedDiscount = 0;
        let activeCouponCode = "";
        let currentSelectedSizeId = null;
        let orderItems = [];

        window.onload = () => { renderCategories(); };

        function renderCategories() {
            const container = document.getElementById('categories-render');
            if (!container) return;
            container.innerHTML = "";
            categoriesData.forEach(cat => {
                container.innerHTML += `
                    <div class="category-card" onclick="loadCategory(${cat.Id})">
                        <div class="cat-icon-wrapper ${cat.ColorClass}"><i class="fas ${cat.IconClass}"></i></div>
                        <div class="category-name">${cat.Name}</div>
                    </div>`;
            });
        }

        function toggleView(screenId) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(screenId + '-screen').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function loadCategory(catId) {
            const cat = categoriesData.find(c => c.Id === catId);
            if (!cat) return;

            document.getElementById('cat-display-name').innerText = cat.Name;
            const list = document.getElementById('products-list');
            list.innerHTML = "";

            if (!cat.Products || cat.Products.length === 0) {
                list.innerHTML = `<div style="grid-column: 1/-1; text-align:center; padding: 50px 0; color:var(--text-muted);"><i class="fas fa-box-open fa-3x" style="opacity:0.3; margin-bottom:15px;"></i><p>الموديلات قريباً...</p></div>`;
            } else {
                cat.Products.forEach(item => {
                    list.innerHTML += `
                        <div class="product-card">
                            <div class="product-img-box">
                                ${item.IsCustomDesign ? '<span class="custom-badge"><i class="fas fa-star"></i> خاص</span>' : ''}
                                <img src="/${item.ImageUrl}" onerror="this.src='https://placehold.co/400x500/111/D4AF37?text=Maestro'">
                            </div>
                            <div class="product-details">
                                <h3 class="product-title">${item.Name}</h3>
                                <div class="product-action-row">
                                    <span class="product-price">${item.BasePrice} <small style="font-size:0.7rem;">ر.ع</small></span>
                                    <button class="btn-add" onclick="openOrderModal(${item.Id})"><i class="fas fa-plus"></i></button>
                                </div>
                            </div>
                        </div>`;
                });
            }
            toggleView('shop');
        }

        // --- Modal Logic ---
        function openOrderModal(productId) {
            categoriesData.forEach(c => {
                const found = c.Products.find(p => p.Id === productId);
                if (found) currentProduct = found;
            });
            if (!currentProduct) return;

            document.getElementById('modal-item-name').innerText = currentProduct.Name;
            document.getElementById('custom-design-alert').classList.toggle('hidden', !currentProduct.IsCustomDesign);
            document.getElementById('custom-image-section').classList.toggle('hidden', !currentProduct.IsCustomDesign);

            // Reset
            orderItems = []; currentSelectedSizeId = null; appliedDiscount = 0; activeCouponCode = "";
            document.getElementById('selected-qty').value = 1;
            document.getElementById('custom-image-input').value = "";
            document.getElementById('order-notes').value = "";
            document.getElementById('fabric-select').value = "0";
            document.getElementById('coupon-input').value = "";

            renderSizeOptions(); renderSelectedSizes(); calculateLiveTotal();

            // Show modal
            const overlay = document.getElementById('order-modal');
            overlay.classList.remove('hidden');
            // Timeout to allow display:block to apply before adding opacity class for animation
            setTimeout(() => overlay.classList.add('show'), 10);
        }

        function closeModal() {
            const overlay = document.getElementById('order-modal');
            overlay.classList.remove('show');
            setTimeout(() => overlay.classList.add('hidden'), 400); // match transition time
        }

        function renderSizeOptions() {
            const container = document.getElementById('size-options-grid');
            container.innerHTML = "";
            sizesData.forEach((s, idx) => {
                if(idx === 0) currentSelectedSizeId = s.Id;
                let extra = parseFloat(s.AdditionalPrice);
                let extraText = extra > 0 ? `+${extra}` : (extra < 0 ? `${extra}` : "");
                container.innerHTML += `
                    <div class="pill ${idx === 0 ? 'active' : ''}" onclick="selectSizeBtn(${s.Id}, this)">
                        ${s.Name}
                        ${extraText ? `<span style="display:block; font-size:0.7rem;">${extraText}</span>` : ''}
                    </div>`;
            });
        }

        function selectSizeBtn(id, btnElement) {
            currentSelectedSizeId = id;
            document.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');
        }

        function changeQty(delta) {
            let input = document.getElementById('selected-qty');
            let val = parseInt(input.value) + delta;
            input.value = val < 1 ? 1 : val;
        }

        function addSizeToSelection() {
            if(!currentSelectedSizeId) return;
            const qty = parseInt(document.getElementById('selected-qty').value);
            const sizeObj = sizesData.find(s => s.Id === currentSelectedSizeId);

            const existing = orderItems.find(i => i.SizeId === currentSelectedSizeId);
            if(existing) existing.Quantity += qty;
            else orderItems.push({ SizeId: sizeObj.Id, SizeName: sizeObj.Name, ExtraPrice: parseFloat(sizeObj.AdditionalPrice) || 0, Quantity: qty });

            document.getElementById('selected-qty').value = 1;
            renderSelectedSizes(); calculateLiveTotal();
        }

        function removeSizeFromSelection(index) {
            orderItems.splice(index, 1);
            renderSelectedSizes(); calculateLiveTotal();
        }

        function renderSelectedSizes() {
            const list = document.getElementById('selected-sizes-list');
            list.innerHTML = "";
            if(orderItems.length === 0) { list.innerHTML = '<p style="text-align:center; color:#666; font-size:0.9rem; margin:0;">السلة فارغة.</p>'; return; }
            orderItems.forEach((item, index) => {
                list.innerHTML += `
                    <div class="cart-item">
                        <div style="display:flex; align-items:center; gap:15px;">
                            <span style="color:var(--gold); font-weight:900; font-size:1.1rem;">${item.SizeName}</span>
                            <span style="color:#aaa; font-size:0.9rem;">الكمية: <b style="color:#fff;">${item.Quantity}</b></span>
                        </div>
                        <button type="button" class="cart-item-del" onclick="removeSizeFromSelection(${index})"><i class="fas fa-trash"></i></button>
                    </div>`;
            });
        }

        function calculateLiveTotal(isCouponClick = false) {
            if (!currentProduct) return;
            let totalQty = 0; let totalPrice = 0;
            const fabricExtra = parseFloat(document.getElementById('fabric-select').value) || 0;

            orderItems.forEach(item => {
                totalQty += item.Quantity;
                totalPrice += item.Quantity * (currentProduct.BasePrice + item.ExtraPrice + fabricExtra);
            });

            if (currentProduct.IsCustomDesign && totalQty > 0 && totalQty <= 10) totalPrice += (2 * totalQty);

            if (isCouponClick) {
                const code = document.getElementById('coupon-input').value.trim().toUpperCase();
                if (!code) return;
                fetch(`/Home/ValidateCoupon?code=${encodeURIComponent(code)}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.valid) { appliedDiscount = data.discount; activeCouponCode = code; Swal.fire({ title: 'تم الخصم!', text: `وفرت ${data.discount} ريال`, icon: 'success', background:'#111', color:'#fff', toast: true, position:'top', showConfirmButton:false, timer: 2000 }); }
                        else { appliedDiscount = 0; activeCouponCode = ""; Swal.fire({ title: 'عفواً', text: 'كود غير صحيح', icon: 'error', background:'#111', color:'#fff', toast: true, position:'top', showConfirmButton:false, timer: 2000 }); }
                        updateDisplay();
                    });
            } else updateDisplay();

            function updateDisplay() {
                let final = Math.max(0, totalPrice - appliedDiscount);
                document.getElementById('total-price-display').innerText = final.toFixed(2);
            }
            return { totalQty, totalPrice: Math.max(0, totalPrice - appliedDiscount) };
        }

        function submitOrderProcess() {
            const customerName = document.getElementById('customer-name').value.trim();
            const customerPhone = document.getElementById('customer-phone').value.trim();

            if(!customerName || !customerPhone) {
                Swal.fire('تنبيه', 'يرجى كتابة الاسم ورقم الهاتف للتواصل.', 'warning');
                return;
            }

            const { totalQty, totalPrice } = calculateLiveTotal();
            if (totalQty === 0) {
                Swal.fire('تنبيه', 'السلة فارغة. يرجى إضافة مقاس واحد على الأقل.', 'warning');
                return;
            }

            const btn = document.getElementById('submit-btn');
            btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإرسال...';

            const fabricSelect = document.getElementById('fabric-select');
            const formData = new FormData();
            formData.append('CustomerName', customerName);
            formData.append('PhoneNumber', customerPhone);
            formData.append('ProductId', currentProduct.Id);
            formData.append('Notes', document.getElementById('order-notes').value || "");
            formData.append('FabricType', fabricSelect.options[fabricSelect.selectedIndex].getAttribute('data-name'));
            formData.append('FabricExtraPrice', parseFloat(fabricSelect.value) || 0);
            formData.append('CouponCode', activeCouponCode);
            formData.append('ItemsJson', JSON.stringify(orderItems.map(i => ({ SizeId: i.SizeId, Quantity: i.Quantity }))));

            const imageInput = document.getElementById('custom-image-input');
            if(imageInput && imageInput.files.length > 0) formData.append('CustomImage', imageInput.files[0]);

            fetch('/Home/SubmitOrder', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeModal();
                    Swal.fire({
                        title: 'تم استلام طلبك بنجاح!',
                        html: `<div style="text-align:right; margin-top:20px;">
                                <div style="background:rgba(212,175,55,0.1); border:1px solid var(--gold); border-radius:15px; padding:20px; text-align:center;">
                                    <p style="font-size:1rem; color:var(--text-muted); margin-bottom:5px;">رقم الطلب الخاص بك</p>
                                    <p style="font-size:2rem; font-weight:900; color:var(--gold); margin:0;">#${data.orderId}</p>
                                </div>
                                <div style="margin-top:20px; font-size:1.1rem;">
                                    <p>الاسم: <strong style="color:#fff;">${customerName}</strong></p>
                                    <p>التسليم المتوقع: <strong style="color:#3498db;">${data.deliveryDate}</strong></p>
                                </div>
                                <p style="font-size:0.9rem; color:var(--text-muted); margin-top:20px; text-align:center;">يرجى الاحتفاظ برقم الطلب. سيقوم فريق المايسترو بالتواصل معك لتأكيد عملية الدفع والبدء بالتفصيل.</p>
                               </div>`,
                        icon: 'success', confirmButtonText: 'حسناً، شكراً لكم', background: '#111', color: '#fff'
                    });
                } else Swal.fire('خطأ', data.message, 'error');
            })
            .catch(() => Swal.fire('خطأ', 'فشل الاتصال، تحقق من الانترنت', 'error'))
            .finally(() => { btn.disabled = false; btn.innerHTML = 'إرسال الطلب <i class="fas fa-paper-plane"></i>'; });
        }
    </script>
</body>
</html>