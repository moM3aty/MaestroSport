@model IEnumerable<MaestroSport.Models.SiteSetting>
@{
    ViewData["Title"] = "إعدادات المتجر العامة";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var announcement = Model?.FirstOrDefault(s => s.Key == "AnnouncementBar")?.Value;
    var promoBanner = Model?.FirstOrDefault(s => s.Key == "PromoBannerUrl")?.Value;
}

<div style="max-width: 900px; margin: 0 auto;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(46, 204, 113, 0.1); border: 1px solid #2ecc71; color: #2ecc71; padding: 20px; border-radius: 15px; margin-bottom: 30px; display: flex; align-items: center; gap: 15px;">
            <i class="fas fa-check-circle fa-lg"></i>
            <span style="font-weight: bold;">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- إعدادات شريط الإعلانات -->
    <div class="card-premium">
        <div style="border-bottom: 1px solid var(--accent); padding-bottom: 20px; margin-bottom: 30px;">
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-bullhorn" style="margin-left: 10px;"></i> شريط الأخبار المتحرك</h3>
            <p style="color: var(--text-dim);">هذا النص يظهر متحركاً في أعلى الموقع لجذب انتباه الزبائن</p>
        </div>

        <form asp-action="UpdateAnnouncement" method="post">
            <div class="form-group">
                <textarea name="announcementValue" class="form-control" rows="3" style="font-size: 1.1rem;" placeholder="اكتب نص الإعلان هنا...">@announcement</textarea>
            </div>
            <button type="submit" class="btn-premium btn-gold" style="width: auto;">
                <i class="fas fa-save"></i> حفظ النص
            </button>
        </form>
    </div>

    <!-- إعدادات البانر الإعلاني الرئيسي (جديد) -->
    <div class="card-premium">
        <div style="border-bottom: 1px solid var(--accent); padding-bottom: 20px; margin-bottom: 30px;">
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-image" style="margin-left: 10px;"></i> البانر الإعلاني الرئيسي</h3>
            <p style="color: var(--text-dim);">الصورة الكبيرة التي تظهر في الصفحة الرئيسية (ينصح بمقاس عرضي مثل 1200x500)</p>
        </div>

        <form asp-action="UpdatePromoBanner" method="post" enctype="multipart/form-data">

            @if (!string.IsNullOrEmpty(promoBanner))
            {
                <div style="margin-bottom: 20px;">
                    <p style="color: var(--text-dim); margin-bottom: 10px;">البانر الحالي:</p>
                    <img src="/@promoBanner" style="max-width: 100%; height: auto; border-radius: 15px; border: 1px solid var(--gold);" />
                </div>
            }

            <div class="form-group">
                <label class="form-label">اختر صورة جديدة للبانر</label>
                <input type="file" name="bannerImage" class="form-control" accept="image/*" style="padding: 10px;" />
            </div>

            <div style="display: flex; gap: 15px;">
                <button type="submit" class="btn-premium btn-gold">
                    <i class="fas fa-upload"></i> رفع وحفظ البانر
                </button>
                @if (!string.IsNullOrEmpty(promoBanner))
                {
                    <a asp-action="RemovePromoBanner" class="btn-premium btn-outline" style="color: #ff4757; border-color: #ff4757;" onclick="return confirm('هل تريد إزالة البانر نهائياً؟')">
                        <i class="fas fa-trash"></i> إزالة البانر
                    </a>
                }
            </div>
        </form>
    </div>
</div>