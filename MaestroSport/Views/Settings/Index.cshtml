@model MaestroSport.Models.SiteSetting
@{
    ViewData["Title"] = "إعدادات المتجر";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 900px; margin: 0 auto;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(46, 204, 113, 0.1); border: 1px solid #2ecc71; color: #2ecc71; padding: 20px; border-radius: 15px; margin-bottom: 30px; display: flex; align-items: center; gap: 15px;">
            <i class="fas fa-check-double fa-lg"></i>
            <span style="font-weight: bold;">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="card-premium">
        <div style="border-bottom: 1px solid var(--accent); padding-bottom: 20px; margin-bottom: 30px;">
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-bullhorn" style="margin-left: 10px;"></i> شريط الإعلانات المتحرك</h3>
            <p style="color: var(--text-dim);">هذا النص يظهر في أعلى الموقع لجذب انتباه الزبائن (عروض، شحن، تنبيهات)</p>
        </div>

        <form asp-action="UpdateAnnouncement" method="post">
            <div class="form-group">
                <label class="form-label">نص الإعلان الحالي:</label>
                <textarea name="announcementValue" class="form-control" rows="4" style="font-size: 1.2rem; font-weight: bold;" placeholder="اكتب نص الإعلان هنا...">@(Model?.Value)</textarea>
                <p style="margin-top: 10px; font-size: 0.85rem; color: var(--text-dim);">
                    <i class="fas fa-info-circle"></i> يفضل استخدام الرموز التعبيرية (Emoji) لجعل النص أكثر حيوية.
                </p>
            </div>

            <!-- معاينة حية -->
            <div style="margin: 30px 0; padding: 20px; background: var(--black); border: 1px solid var(--accent); border-radius: 15px;">
                <p style="font-size: 0.8rem; color: var(--gold); margin-bottom: 10px; font-weight: bold;">معاينة حية لشكل الشريط:</p>
                <div style="background: var(--royal-blue); color: var(--gold); padding: 10px; border: 1px solid var(--gold); border-radius: 5px; font-weight: bold;">
                    <marquee behavior="scroll" direction="right">@(Model?.Value ?? "سيظهر النص التجريبي هنا...")</marquee>
                </div>
            </div>

            <div style="padding-top: 20px; border-top: 1px solid var(--accent);">
                <button type="submit" class="btn-premium btn-gold" style="padding: 15px 40px; font-size: 1.1rem; width: 100%; justify-content: center;">
                    <i class="fas fa-save" style="margin-left: 10px;"></i> حفظ ونشر الإعلان فوراً
                </button>
            </div>
        </form>
    </div>

   
</div>