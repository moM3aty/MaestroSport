@{
    ViewData["Title"] = "تغيير كلمة المرور";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 600px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h2 style="font-weight: 900; color: var(--gold); margin: 0;">أمان الحساب</h2>
        <a href="/Settings" class="btn-premium btn-outline">
            <i class="fas fa-arrow-right"></i> العودة للإعدادات
        </a>
    </div>

    <div class="card-premium">
        <div style="border-bottom: 1px solid var(--accent); padding-bottom: 20px; margin-bottom: 30px;">
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-key" style="margin-left: 10px;"></i> تغيير الرقم السري</h3>
            <p style="color: var(--text-dim);">قم بتحديث كلمة المرور الخاصة بحسابك (الرقم السري الافتراضي هو Admin@123)</p>
        </div>

        <form asp-action="ChangePassword" method="post">
            <!-- مساحة لعرض الأخطاء إن وجدت -->
            <div asp-validation-summary="All" class="text-danger mb-4" style="font-weight: bold; background: rgba(255, 71, 87, 0.1); padding: 10px; border-radius: 8px;"></div>

            <div class="form-group mb-4">
                <label class="form-label">كلمة المرور الحالية</label>
                <input type="password" name="currentPassword" class="form-control" required placeholder="أدخل كلمة المرور القديمة" />
            </div>

            <div class="form-group mb-4">
                <label class="form-label">كلمة المرور الجديدة</label>
                <input type="password" name="newPassword" class="form-control" required placeholder="أدخل كلمة المرور الجديدة" />
                <small style="color: var(--text-dim); display: block; margin-top: 5px;"><i class="fas fa-info-circle"></i> يجب أن تتكون من 6 أحرف أو أرقام على الأقل.</small>
            </div>

            <div class="form-group mb-5">
                <label class="form-label">تأكيد كلمة المرور الجديدة</label>
                <input type="password" name="confirmPassword" class="form-control" required placeholder="أعد إدخال كلمة المرور الجديدة" />
            </div>

            <button type="submit" class="btn-premium btn-gold w-100 justify-content-center" style="font-size: 1.1rem; padding: 15px;">
                <i class="fas fa-save"></i> حفظ التغييرات
            </button>
        </form>
    </div>
</div>