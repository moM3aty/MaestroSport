@model MaestroSport.Models.Category
@{
    ViewData["Title"] = "إضافة قسم جديد";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 800px; margin: 0 auto;">
    <div class="card-premium">
        <div style="border-bottom: 1px solid var(--accent); padding-bottom: 20px; margin-bottom: 30px;">
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-plus-circle"></i> إنشاء قسم جديد</h3>
            <p style="color: var(--text-dim);">أضف تصنيفاً جديداً لمنتجات المايسترو</p>
        </div>

        <form asp-action="Create">
            <div class="form-group">
                <label asp-for="Name" class="form-label">اسم القسم (بالعربي)</label>
                <input asp-for="Name" class="form-control" placeholder="مثال: بدلات شتوية، أطقم تدريب..." />
                <span asp-validation-for="Name" style="color: #ff4757; font-size: 0.8rem;"></span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label asp-for="IconClass" class="form-label">كود الأيقونة (FontAwesome)</label>
                    <input asp-for="IconClass" class="form-control" placeholder="مثال: fa-tshirt" />
                </div>
                <div class="form-group">
                    <label asp-for="ColorClass" class="form-label">اللون التعريفي</label>
                    <select asp-for="ColorClass" class="form-control">
                        <option value="gold">ذهبي</option>
                        <option value="blue">أزرق</option>
                        <option value="green">أخضر</option>
                        <option value="red">أحمر</option>
                        <option value="purple">بنفسجي</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="DisplayOrder" class="form-label">ترتيب العرض في الموقع</label>
                <input asp-for="DisplayOrder" type="number" class="form-control" value="1" />
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px; border-top: 1px solid var(--accent); pt-30px; padding-top: 25px;">
                <button type="submit" class="btn-premium btn-gold"><i class="fas fa-save"></i> حفظ القسم</button>
                <a asp-action="Index" class="btn-premium btn-outline">إلغاء والعودة</a>
            </div>
        </form>
    </div>
</div>