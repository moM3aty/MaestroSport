@model MaestroSport.Models.Product
@{
    ViewData["Title"] = "إضافة موديل جديد";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 900px; margin: 0 auto;">
    <div class="card-premium">
        <div style="border-bottom: 1px solid var(--accent); padding-bottom: 20px; margin-bottom: 30px;">
            <h3 style="font-weight: 900; color: var(--gold);"><i class="fas fa-tshirt"></i> إضافة موديل إلى الكتالوج</h3>
            <p style="color: var(--text-dim);">قم بتعبئة بيانات الموديل الرياضي الجديد</p>
        </div>

        <form asp-action="Create" enctype="multipart/form-data">
            <div class="form-group">
                <label asp-for="Name" class="form-label">اسم الموديل</label>
                <input asp-for="Name" class="form-control" placeholder="مثال: طقم المايسترو برو 2024" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label asp-for="CategoryId" class="form-label">القسم التابع له</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
                </div>
                <div class="form-group">
                    <label asp-for="BasePrice" class="form-label">السعر الأساسي (ر.ع)</label>
                    <input asp-for="BasePrice" type="number" step="0.5" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ImageFile" class="form-label">صورة الموديل</label>
                <input asp-for="ImageFile" type="file" class="form-control" style="padding: 10px;" accept="image/*" />
                <p style="font-size: 0.8rem; color: var(--text-dim); mt-2">يفضل استخدام صور بخلفية شفافة أو داكنة</p>
            </div>

            <div class="form-group" style="background: rgba(212, 175, 55, 0.05); padding: 20px; border-radius: 15px; border: 1px dashed var(--gold);">
                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer;">
                    <input asp-for="IsCustomDesign" type="checkbox" style="width: 20px; height: 20px; accent-color: var(--gold);" />
                    <div>
                        <span style="font-weight: bold; color: var(--gold);">تصميم خاص (Custom Design)</span>
                        <p style="font-size: 0.85rem; margin: 0; color: #fff;">تفعيل هذا الخيار سيضيف رسوم تصميم (2 ريال) تلقائياً للطلبات الأقل من 11 قطعة.</p>
                    </div>
                </label>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 40px;">
                <button type="submit" class="btn-premium btn-gold" style="padding: 15px 40px; font-size: 1.1rem;">
                    <i class="fas fa-check-double"></i> اعتماد الموديل ونشره
                </button>
                <a asp-action="Index" class="btn-premium btn-outline" style="padding: 15px 30px;">إلغاء</a>
            </div>
        </form>
    </div>
</div>